// Формирует сведения об указанном юридическом или физическом лице.
// К сведениям относятся: наименование, адрес, номер телефона, банковские реквизиты.
//
// Параметры: 
//  Сведения - Структура - собранные сведения.
//  Реквизиты - Структура - реквизиты ЮрФизЛице.
//  ЮрФизЛицо   - организация или физическое лицо, о котором собираются сведения.
//  ДатаПериода - дата, на которую выбираются сведения о ЮрФизЛице.
//
Процедура ДополнитьСведенияОЮрФизЛице(Сведения, Реквизиты, ЮрФизЛицо, ДатаПериода) Экспорт
	//++ Локализация
    Если ЗначениеЗаполнено(ЮрФизЛицо)
       И (ТипЗнч(ЮрФизЛицо) = Тип("СправочникСсылка.Организации")
    	ИЛИ ТипЗнч(ЮрФизЛицо) = Тип("СправочникСсылка.Контрагенты")) Тогда
    
    	Если ТипЗнч(ЮрФизЛицо) = Тип("СправочникСсылка.Организации") Тогда
    	ИначеЕсли ТипЗнч(ЮрФизЛицо) = Тип("СправочникСсылка.Контрагенты") Тогда
    		Сведения.Вставить("НалоговыйНомерВСтранеРегистрации", Реквизиты.НалоговыйНомер);
    		Сведения.Вставить("СтранаРегистрации", Реквизиты.СтранаРегистрации);
    	КонецЕсли;
        РеквизитЮрФизЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЮрФизЛицо, "ЮрФизЛицо");
		//++ НЕ БЗК
		Сведения.Вставить("ИНН", 						 Реквизиты.ИННПлательщикаНДС);
		//-- НЕ БЗК
		Если РеквизитЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
			Сведения.Вставить("КодПоЕДРПОУ", Реквизиты.КодПоЕДРПОУ);
		ИначеЕсли РеквизитЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент Тогда
			Сведения.Вставить("КодПоЕДРПОУ", Реквизиты.КодПоЕДРПОУ);
		Иначе
			Сведения.Вставить("КодПоДРФО", Реквизиты.КодПоЕДРПОУ);
        КонецЕсли;
		//++ НЕ БЗК
        Сведения.Вставить("НомерСвидетельства", Реквизиты.НомерСвидетельстваПлательщикаНДС);
		Если ТипЗнч(ЮрФизЛицо) = Тип("СправочникСсылка.Организации") Тогда
			Сведения.Вставить("ИнформацияОСтатусеПлательщикаНалогов", Реквизиты.ИнформацияОСтатусеПлательщикаНалогов);
		Иначе
			Сведения.Вставить("ИнформацияОСтатусеПлательщикаНалогов", "");			
		КонецЕсли;
    	Если РеквизитЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
            Сведения.Вставить("КодФилиала", Реквизиты.КодФилиала);
    	Иначе
            Сведения.Вставить("КодФилиала", "");
		КонецЕсли;
		//-- НЕ БЗК
    	
    КонецЕсли;
    
    //-- Локализация
КонецПроцедуры

