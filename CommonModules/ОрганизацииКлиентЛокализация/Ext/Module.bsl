		Возврат;
	КонецЕсли;
	
	ПараметрыОповещения = Новый Структура();
	ИмяСобытия = "ЗаписьНастроекНалоговУчетныхПолитик";
	Оповестить(ИмяСобытия, ПараметрыОповещения);
	
КонецПроцедуры

