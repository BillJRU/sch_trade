#Область ОбновлениеНовыхВерсийИБ

// Добавляет в список процедуры-обработчики обновления данных ИБ
// для всех поддерживаемых версий библиотеки или конфигурации.
// Вызывается перед началом обновления данных ИБ для построения плана обновления.
//
//  Обработчики - ТаблицаЗначений - описание полей, см. в процедуре
//                ОбновлениеИнформационнойБазы.НоваяТаблицаОбработчиковОбновления.
//
// Пример добавления процедуры-обработчика в список:
//  Обработчик = Обработчики.Добавить();
//  Обработчик.Версия              = "1.1.0.0";
//  Обработчик.Процедура           = "ОбновлениеИБ.ПерейтиНаВерсию_1_1_0_0";
//  Обработчик.МонопольныйРежим    = Ложь;
//
// Параметры:
// 	Обработчики - см. ОбновлениеИнформационнойБазы.НоваяТаблицаОбработчиковОбновления
//
Процедура ОписаниеОбработчиковОбновления(Обработчики) Экспорт

	Обработчик = Обработчики.Добавить();
	Обработчик.Версия = "3.5.4.400";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Процедура = "ОбновлениеИнформационнойБазыУТПереопределяемый.ПереместитьДанныеДокументаРегламентированныхОтчетовВНовыеОбъекты";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("5450f192-8c8d-488c-9f4e-63a4885707ae");
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "ОбновлениеИнформационнойБазыУТПереопределяемый.ПереместитьДанныеДокументаРегламентированныхОтчетовВНовыеОбъекты_ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.ЗапускатьТолькоВГлавномУзле = Истина;
	Обработчик.ЧитаемыеОбъекты = "Документ.УдалитьРегламентированныйОтчет";
	Обработчик.ИзменяемыеОбъекты = "Документ.УдалитьРегламентированныйОтчет";
	Обработчик.БлокируемыеОбъекты = "Документ.УдалитьРегламентированныйОтчет";
	Обработчик.Комментарий = НСтр("ru='Выполняет перенос данных из документа ""(не используется) Регламентированный отчет"" в документ ""Регламентированный отчет"".';"
		"uk='Виконує перенесення даних із документу ""(не використовується) Регламентований звіт"" у документ ""Регламентований звіт"".'");
	Обработчик.ПриоритетыВыполнения = ОбновлениеИнформационнойБазы.ПриоритетыВыполненияОбработчика();

	НоваяСтрока = Обработчик.ПриоритетыВыполнения.Добавить();
	НоваяСтрока.Процедура = "ОбновлениеИнформационнойБазыУТПереопределяемый.ПереместитьДанныеДокументаВыгрузкаРегламентированныхОтчетовВНовыеОбъекты";
	НоваяСтрока.Порядок = "До";
	
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Версия = "3.5.4.400";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Процедура = "ОбновлениеИнформационнойБазыУТПереопределяемый.ПереместитьДанныеДокументаВыгрузкаРегламентированныхОтчетовВНовыеОбъекты";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("1699bea4-5e71-4a6b-8e69-328dc0ac0630");
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "ОбновлениеИнформационнойБазыУТПереопределяемый.ПереместитьДанныеДокументаВыгрузкаРегламентированныхОтчетовВНовыеОбъекты_ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.ЗапускатьТолькоВГлавномУзле = Истина;
	Обработчик.ЧитаемыеОбъекты = "Документ.УдалитьВыгрузкаРегламентированныхОтчетов,"
		+ "Документ.УдалитьРегламентированныйОтчет";
	Обработчик.ИзменяемыеОбъекты = "Документ.УдалитьВыгрузкаРегламентированныхОтчетов";
	Обработчик.БлокируемыеОбъекты = "Документ.УдалитьВыгрузкаРегламентированныхОтчетов";
	Обработчик.Комментарий = НСтр("ru='Выполняет перенос данных из документа ""(не используется) Выгрузка регламентированных отчетов"" в документ ""Выгрузка регламентированных отчетов"".';"
		"uk='Виконує перенесення даних із документу ""(не використовується) Вивантаження регламентованих звітів"" у документ ""Вивантаження регламентованих звітів"".'");
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Версия = "3.5.4.400";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Процедура = "ОбновлениеИнформационнойБазыУТПереопределяемый.ПеренестиУточнениеНаименованияФизлиц";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("6c9dcf37-c638-435b-8be4-e568c077c657");
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "ОбновлениеИнформационнойБазыУТПереопределяемый.ПеренестиУточнениеНаименованияФизлиц_ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.ЧитаемыеОбъекты = "Справочник.ФизическиеЛица";
	Обработчик.ИзменяемыеОбъекты = "Справочник.ФизическиеЛица";
	Обработчик.БлокируемыеОбъекты = "Справочник.ФизическиеЛица";
	Обработчик.Комментарий = НСтр("ru='Переносит уточнение наименования физлиц в новый реквизит.';"
		"uk='Переносить уточнення найменування фізичних осіб в новий реквізит.'");
	Обработчик.ПриоритетыВыполнения = ОбновлениеИнформационнойБазы.ПриоритетыВыполненияОбработчика();

	НоваяСтрока = Обработчик.ПриоритетыВыполнения.Добавить();
	НоваяСтрока.Процедура = "Справочники.КлючиРеестраДокументов.ОбработатьДанныеДляПереходаНаНовуюВерсию";
	НоваяСтрока.Порядок = "Любой";

КонецПроцедуры

Процедура ПереместитьДанныеДокументаРегламентированныхОтчетовВНовыеОбъекты_ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	УдалитьРегламентированныйОтчет.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.УдалитьРегламентированныйОтчет КАК УдалитьРегламентированныйОтчет
	|ГДЕ
	|	УдалитьРегламентированныйОтчет.Объект35 = ЗНАЧЕНИЕ(Документ.РегламентированныйОтчет.ПустаяСсылка)";
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(
		Параметры, 
		Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка")
	);
	
КонецПроцедуры

Процедура ПереместитьДанныеДокументаРегламентированныхОтчетовВНовыеОбъекты(Параметры) Экспорт

	ПолноеИмяОбъекта = "Документ.УдалитьРегламентированныйОтчет";
	МетаданныеОбъекта = Метаданные.Документы.УдалитьРегламентированныйОтчет;
	
	Выборка = ОбновлениеИнформационнойБазы.ВыбратьСсылкиДляОбработки(Параметры.Очередь, ПолноеИмяОбъекта);
	
	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			Блокировка.Заблокировать();
			
		Исключение
			
			ОтменитьТранзакцию();
			ТекстСообщения = НСтр("ru='Не удалось заблокировать %Документ% по причине: %Причина%';uk='Не вдалося заблокувати %Документ% по причині: %Причина%'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Документ%", Выборка.Ссылка);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Причина%", ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ЗаписьЖурналаРегистрации(
				ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			    УровеньЖурналаРегистрации.Предупреждение,
			    МетаданныеОбъекта,
			    Выборка.Ссылка,
			    ТекстСообщения
			);
			
			Продолжить;
			
		КонецПопытки;
		
		УдалитьОбъект = Выборка.Ссылка.ПолучитьОбъект();
		
		Если УдалитьОбъект = Неопределено Тогда
			
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			ЗафиксироватьТранзакцию();
			Продолжить;
			
		КонецЕсли; 
		
		Если ЗначениеЗаполнено(УдалитьОбъект.Объект35) Тогда
			
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			ЗафиксироватьТранзакцию();
			Продолжить;
			
		КонецЕсли;
		
		НовыйОбъект = Документы.РегламентированныйОтчет.СоздатьДокумент();

		ЗаполнитьЗначенияСвойств(НовыйОбъект, УдалитьОбъект);
		Если ЗначениеЗаполнено(УдалитьОбъект.ВидОтчетности) Тогда
			НовыйОбъект.ВидОтчетности = Перечисления.ВидыОтчетности[ОбщегоНазначения.ИмяЗначенияПеречисления(УдалитьОбъект.ВидОтчетности)];
		КонецЕсли;
		Если ЗначениеЗаполнено(УдалитьОбъект.ЕдиницаИзмерения) Тогда
			НовыйОбъект.ЕдиницаИзмерения = Перечисления.ПорядкиОкругленияОтчетности[ОбщегоНазначения.ИмяЗначенияПеречисления(УдалитьОбъект.ЕдиницаИзмерения)];
		КонецЕсли;
		
		Попытка
			
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(НовыйОбъект, Истина);
			
			УдалитьОбъект.Объект35 = НовыйОбъект.Ссылка;
			УдалитьОбъект.ПометкаУдаления = Истина;
			
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(УдалитьОбъект);
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			ТекстСообщения = НСтр("ru='Не удалось обработать: %Документ% по причине: %Причина%';uk='Не вдалося обробити: %Документ% з причини: %Причина%'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Документ%", Выборка.Ссылка);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Причина%", ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ЗаписьЖурналаРегистрации(
				ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			    УровеньЖурналаРегистрации.Предупреждение,
			    МетаданныеОбъекта,
			    Выборка.Ссылка,
			    ТекстСообщения
			);
			
		КонецПопытки;
		
	КонецЦикла;
	
	Параметры.ОбработкаЗавершена = НЕ ОбновлениеИнформационнойБазы.ЕстьДанныеДляОбработки(Параметры.Очередь, ПолноеИмяОбъекта);
	
КонецПроцедуры

Процедура ПереместитьДанныеДокументаВыгрузкаРегламентированныхОтчетовВНовыеОбъекты_ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	УдалитьВыгрузкаРегламентированныхОтчетов.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.УдалитьВыгрузкаРегламентированныхОтчетов КАК УдалитьВыгрузкаРегламентированныхОтчетов
	|ГДЕ
	|	УдалитьВыгрузкаРегламентированныхОтчетов.Объект35 = ЗНАЧЕНИЕ(Документ.ВыгрузкаРегламентированныхОтчетов.ПустаяСсылка)";
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(
		Параметры, 
		Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка")
	);
	
КонецПроцедуры

Процедура ПереместитьДанныеДокументаВыгрузкаРегламентированныхОтчетовВНовыеОбъекты(Параметры) Экспорт

	ПолноеИмяОбъекта = "Документ.УдалитьВыгрузкаРегламентированныхОтчетов";
	МетаданныеОбъекта = Метаданные.Документы.УдалитьВыгрузкаРегламентированныхОтчетов;
	
	Выборка = ОбновлениеИнформационнойБазы.ВыбратьСсылкиДляОбработки(Параметры.Очередь, ПолноеИмяОбъекта);
	
	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			Блокировка.Заблокировать();
			
		Исключение
			
			ОтменитьТранзакцию();
			ТекстСообщения = НСтр("ru='Не удалось заблокировать %Документ% по причине: %Причина%';uk='Не вдалося заблокувати %Документ% по причині: %Причина%'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Документ%", Выборка.Ссылка);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Причина%", ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ЗаписьЖурналаРегистрации(
				ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			    УровеньЖурналаРегистрации.Предупреждение,
			    МетаданныеОбъекта,
			    Выборка.Ссылка,
			    ТекстСообщения
			);
			
			Продолжить;
			
		КонецПопытки;
		
		УдалитьОбъект = Выборка.Ссылка.ПолучитьОбъект();
		
		Если УдалитьОбъект = Неопределено Тогда
			
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			ЗафиксироватьТранзакцию();
			Продолжить;
			
		КонецЕсли; 
		
		Если ЗначениеЗаполнено(УдалитьОбъект.Объект35) Тогда
			
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			ЗафиксироватьТранзакцию();
			Продолжить;
			
		КонецЕсли;
		
		НовыйОбъект = Документы.ВыгрузкаРегламентированныхОтчетов.СоздатьДокумент();

		ЗаполнитьЗначенияСвойств(НовыйОбъект, УдалитьОбъект);
		
		НовыйОбъект.Основание = УдалитьОбъект.Основание.Объект35;
		
		Для каждого СтрокаТЧ Из УдалитьОбъект.Основная Цикл
			
			НоваяСтрока = НовыйОбъект.Основная.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			НоваяСтрока.Основание = СтрокаТЧ.Основание.Объект35;
			
		КонецЦикла;

		Для каждого СтрокаТЧ Из УдалитьОбъект.Выгрузки Цикл
			
			НоваяСтрока = НовыйОбъект.Выгрузки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);     
			Если СтрокаТЧ.Тип = Перечисления.УдалитьВерсииФорматовВыгрузки.ГНСУ_XML Тогда
				НоваяСтрока.Тип = Перечисления.ВерсииФорматовВыгрузки.ГНСУ_XML;
			КонецЕсли;
			
		КонецЦикла;
	
		Попытка
			
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(НовыйОбъект, Истина);
			
