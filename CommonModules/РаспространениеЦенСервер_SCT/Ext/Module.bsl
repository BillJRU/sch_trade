#Если Сервер Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Обработчик подписки на ПриЗаписи Справочник.ХарактеристикиНоменклатуры.
// Запускает фоновое задание распространения цен с эталонной характеристики
// (доп. реквизит из Константы.ДопРеквизитЕстьПокраска_SCT, значение = ЛОЖЬ)
// на новую характеристику того же ВидаНоменклатуры.
//
// Параметры:
//	Источник - СправочникОбъект.ХарактеристикиНоменклатуры - записываемый элемент
//	Отказ    - Булево - стандартный параметр события (не модифицируем)
//
Процедура ПриЗаписиХарактеристикиНоменклатуры(Источник, Отказ) Экспорт

	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	Если Источник.ЭтоГруппа Тогда
		Возврат;
	КонецЕсли;
	Если Источник.ПометкаУдаления Тогда
		Возврат;
	КонецЕсли;
	// Распространение работает только для общих характеристик ВидаНоменклатуры
	Если ТипЗнч(Источник.Владелец) <> Тип("СправочникСсылка.ВидыНоменклатуры") Тогда
		Возврат;
	КонецЕсли;
	// Фича отключена, если константа не настроена администратором
	Если НЕ ЗначениеЗаполнено(Константы.ДопРеквизитЕстьПокраска_SCT.Получить()) Тогда
		Возврат;
	КонецЕсли;

	ПараметрыЗадания = Новый Массив;
	ПараметрыЗадания.Добавить(Источник.Ссылка);
	ИмяЗадания = НСтр("ru='Распространение цен по характеристике ';uk='Розповсюдження цін за характеристикою '")
		+ Строка(Источник.Наименование);

	Попытка
		ФоновыеЗадания.Выполнить(
			"РаспространениеЦенСервер_SCT.ВыполнитьВФоне",
			ПараметрыЗадания,
			,
			ИмяЗадания);
	Исключение
		ЗаписьЖурналаРегистрации(
			"Schueco.РаспространениеЦен",
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Справочники.ХарактеристикиНоменклатуры,
			Источник.Ссылка,
			НСтр("ru='Не удалось поставить фоновое задание: ';uk='Не вдалося поставити фонове завдання: '")
				+ ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// Точка входа фонового задания. Распространяет цены с эталонной характеристики
// того же ВидаНоменклатуры на переданную характеристику для всех ВидовЦен,
// в которых у эталонной характеристики есть актуальные записи.
//
// Параметры:
//	Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры
//
Процедура ВыполнитьВФоне(Характеристика) Экспорт

	УстановитьПривилегированныйРежим(Истина);

	// Защита от старта с уже невалидной ссылкой (откат внешней транзакции записи)
	Если НЕ ЗначениеЗаполнено(Характеристика) Тогда
		Возврат;
	КонецЕсли;
	Если Характеристика.ПометкаУдаления Тогда
		Возврат;
	КонецЕсли;

	ДопРеквизит = Константы.ДопРеквизитЕстьПокраска_SCT.Получить();
	Если НЕ ЗначениеЗаполнено(ДопРеквизит) Тогда
		Возврат;
	КонецЕсли;

	// 1. Защита: эта характеристика — НЕ сама эталонная (значение доп.реквизита = ЛОЖЬ)
	ЗапросЭталонностиСамой = Новый Запрос;
	ЗапросЭталонностиСамой.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ИСТИНА КАК Признак
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры.ДополнительныеРеквизиты КАК ДопРекв
		|ГДЕ
		|	ДопРекв.Ссылка = &Характеристика
		|	И ДопРекв.Свойство = &Свойство
		|	И ДопРекв.Значение = ЛОЖЬ";
	ЗапросЭталонностиСамой.УстановитьПараметр("Характеристика", Характеристика);
	ЗапросЭталонностиСамой.УстановитьПараметр("Свойство", ДопРеквизит);
	Если НЕ ЗапросЭталонностиСамой.Выполнить().Пустой() Тогда
		Возврат;
	КонецЕсли;

	// 2. Определить ВидНоменклатуры
	ВидНоменклатуры = Неопределено;
	Владелец = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Характеристика, "Владелец");
	Если ТипЗнч(Владелец) = Тип("СправочникСсылка.ВидыНоменклатуры") Тогда
		ВидНоменклатуры = Владелец;
	ИначеЕсли ТипЗнч(Владелец) = Тип("СправочникСсылка.Номенклатура") Тогда
		ВидНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Владелец, "ВидНоменклатуры");
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		ЗаписьЖурналаРегистрации(
			"Schueco.РаспространениеЦен",
			УровеньЖурналаРегистрации.Предупреждение,
			Метаданные.Справочники.ХарактеристикиНоменклатуры,
			Характеристика,
			НСтр("ru='Не определён Вид номенклатуры — распространение пропущено.';uk='Не визначено Вид номенклатури — розповсюдження пропущено.'"));
		Возврат;
	КонецЕсли;

	// 3. Эталонная характеристика того же ВидаНоменклатуры
	ЗапросЭталон = Новый Запрос;
	ЗапросЭталон.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Хар.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры.ДополнительныеРеквизиты КАК ДопРекв
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК Хар
		|		ПО ДопРекв.Ссылка = Хар.Ссылка
		|ГДЕ
		|	Хар.Владелец = &ВидНоменклатуры
		|	И НЕ Хар.ПометкаУдаления
		|	И ДопРекв.Свойство = &Свойство
		|	И ДопРекв.Значение = ЛОЖЬ";
	ЗапросЭталон.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры);
	ЗапросЭталон.УстановитьПараметр("Свойство", ДопРеквизит);
	ВыборкаЭталона = ЗапросЭталон.Выполнить().Выбрать();
	Если НЕ ВыборкаЭталона.Следующий() Тогда
		ЗаписьЖурналаРегистрации(
			"Schueco.РаспространениеЦен",
			УровеньЖурналаРегистрации.Предупреждение,
			Метаданные.Справочники.ХарактеристикиНоменклатуры,
			Характеристика,
			НСтр("ru='Не найдена эталонная характеристика для Вида ';uk='Не знайдено еталонну характеристику для Виду '")
				+ Строка(ВидНоменклатуры));
		Возврат;
	КонецЕсли;
	ЭталоннаяХарактеристика = ВыборкаЭталона.Ссылка;

	// 4. Срез цен эталонной характеристики, исключая пары (Номенклатура × ВидЦены),
	//    для которых у нашей характеристики уже есть запись (ручная установка
	//    или предыдущее частичное распространение). Так одна ручная цена не блокирует
	//    распространение для остальных номенклатур того же вида.
	ЗапросСреза = Новый Запрос;
	ЗапросСреза.Текст =
		"ВЫБРАТЬ
		|	Эталон.Период       КАК Период,
		|	Эталон.Номенклатура КАК Номенклатура,
		|	Эталон.ВидЦены      КАК ВидЦены,
		|	Эталон.Упаковка     КАК Упаковка,
		|	Эталон.Цена         КАК Цена
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ТекДата, Характеристика = &ЭталоннаяХарактеристика) КАК Эталон
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ТекДата, Характеристика = &Характеристика) КАК Цель
		|		ПО Цель.Номенклатура = Эталон.Номенклатура
		|		И Цель.ВидЦены = Эталон.ВидЦены
		|ГДЕ
		|	Эталон.Цена > 0
		|	И Цель.Номенклатура ЕСТЬ NULL
		|УПОРЯДОЧИТЬ ПО
		|	Период,
		|	ВидЦены,
		|	Номенклатура";
	ЗапросСреза.УстановитьПараметр("ТекДата", ТекущаяДатаСеанса());
	ЗапросСреза.УстановитьПараметр("ЭталоннаяХарактеристика", ЭталоннаяХарактеристика);
	ЗапросСреза.УстановитьПараметр("Характеристика", Характеристика);
	ТаблицаЦен = ЗапросСреза.Выполнить().Выгрузить();

	Если ТаблицаЦен.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	// 5. Группировка по (Период, ВидЦены) — один документ на группу
	Группы = ТаблицаЦен.Скопировать(, "Период,ВидЦены");
	Группы.Свернуть("Период,ВидЦены");

	СозданоДокументов = 0;
	СозданоСтрок = 0;

	Для Каждого Группа Из Группы Цикл
		Отбор = Новый Структура("Период,ВидЦены", Группа.Период, Группа.ВидЦены);
		СтрокиГруппы = ТаблицаЦен.НайтиСтроки(Отбор);
		Если СтрокиГруппы.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;

		НачатьТранзакцию();
		Попытка
			Док = Документы.УстановкаЦенНоменклатуры.СоздатьДокумент();
			Док.Дата = Группа.Период;
			Док.Статус = Перечисления.СтатусыУстановокЦенНоменклатуры.Согласован;
			Док.Комментарий = НСтр("ru='Schueco: автоматическое распространение цен с эталонной характеристики на ';uk='Schueco: автоматичне розповсюдження цін з еталонної характеристики на '")
				+ Строка(Характеристика);

			СтрВЦ = Док.ВидыЦен.Добавить();
			СтрВЦ.ВидЦены = Группа.ВидЦены;

			Для Каждого СтрокаЦены Из СтрокиГруппы Цикл
				СтрТовары = Док.Товары.Добавить();
				СтрТовары.Номенклатура   = СтрокаЦены.Номенклатура;
				СтрТовары.Характеристика = Характеристика;
				СтрТовары.Упаковка       = СтрокаЦены.Упаковка;
				СтрТовары.ВидЦены        = Группа.ВидЦены;
				СтрТовары.Цена           = СтрокаЦены.Цена;
			КонецЦикла;

			Док.ОбменДанными.Загрузка = Истина;
			Док.Записать(РежимЗаписиДокумента.Запись);
			Док.ОбменДанными.Загрузка = Ложь;
			Док.Записать(РежимЗаписиДокумента.Проведение);

			СозданоДокументов = СозданоДокументов + 1;
			СозданоСтрок      = СозданоСтрок + СтрокиГруппы.Количество();

			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ЗаписьЖурналаРегистрации(
				"Schueco.РаспространениеЦен",
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Документы.УстановкаЦенНоменклатуры,
				Характеристика,
				НСтр("ru='Ошибка создания документа УстановкаЦенНоменклатуры (Период ';uk='Помилка створення документа УстановкаЦенНоменклатуры (Період '")
					+ Строка(Группа.Период) + ", ВидЦен " + Строка(Группа.ВидЦены) + "): " + ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;

	ЗаписьЖурналаРегистрации(
		"Schueco.РаспространениеЦен",
		УровеньЖурналаРегистрации.Информация,
		Метаданные.Справочники.ХарактеристикиНоменклатуры,
		Характеристика,
		НСтр("ru='Распространение цен завершено. Документов: ';uk='Розповсюдження цін завершено. Документів: '")
			+ СозданоДокументов + ", "
			+ НСтр("ru='строк: ';uk='рядків: '") + СозданоСтрок);

КонецПроцедуры

#КонецОбласти

#КонецЕсли
