// Адрес выбранного файла во временном хранилище. Заполняется callback'ом
// ФайловаяСистемаКлиент.ЗагрузитьФайл при выборе файла через стандартный диалог.
// Если адрес заполнен — ЗагрузитьДанные передаёт его сразу на сервер; иначе
// fallback на ПоместитьФайлы (когда user вбил путь руками).
&НаКлиенте
Перем АдресФайлаКлиент;

&НаКлиенте
Процедура ПутьКФайлуНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	// Канонический паттерн БСП: работает в тонком/толстом/веб-клиенте, сам подключает
	// расширение работы с файлами и кладёт файл во временное хранилище.
	СтандартнаяОбработка = Ложь;

	ПараметрыЗагрузки = ФайловаяСистемаКлиент.ПараметрыЗагрузкиФайла();
	ПараметрыЗагрузки.Диалог.Фильтр = НСтр("ru='Excel (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*';"
		+ "uk='Excel (*.xlsx)|*.xlsx|Усі файли (*.*)|*.*'");
	ПараметрыЗагрузки.Диалог.Заголовок = НСтр("ru='Выберите файл GPL (flat)';"
		+ "uk='Оберіть файл GPL (flat)'");
	ПараметрыЗагрузки.ИдентификаторФормы = УникальныйИдентификатор;

	Оповещение = Новый ОписаниеОповещения("ПослеВыбораФайла", ЭтотОбъект);
	ФайловаяСистемаКлиент.ЗагрузитьФайл(Оповещение, ПараметрыЗагрузки);
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораФайла(ОписаниеФайла, ДополнительныеПараметры) Экспорт
	Если ОписаниеФайла = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ПутьКФайлу       = ОписаниеФайла.Имя;
	АдресФайлаКлиент = ОписаниеФайла.Хранение;
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанные(Команда)

	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
		Сообщить(НСтр("ru='Не выбран файл';uk='Не обрано файл'"));
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ВидЦены) Тогда
		Сообщить(НСтр("ru='Не выбран вид цены';uk='Не обрано вид ціни'"));
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ДатаЦены) Тогда
		Сообщить(НСтр("ru='Не указана дата цен';uk='Не вказано дату цін'"));
		Возврат;
	КонецЕсли;

	// Если файл уже во временном хранилище (стандартный диалог) — используем адрес.
	// Иначе (user вбил путь руками) — fallback на ПоместитьФайлы.
	АдресВХранилище = АдресФайлаКлиент;
	Если НЕ ЗначениеЗаполнено(АдресВХранилище) Тогда
		ПомещаемыеФайлы = Новый Массив;
		ПомещаемыеФайлы.Добавить(Новый ОписаниеПередаваемогоФайла(ПутьКФайлу, ""));
		ПомещенныеФайлы = Новый Массив;
		Если НЕ ПоместитьФайлы(ПомещаемыеФайлы, ПомещенныеФайлы, , Ложь, УникальныйИдентификатор) Тогда
			СообщениеСтатуса = НСтр("ru='Не удалось загрузить файл';uk='Не вдалося завантажити файл'");
			Возврат;
		КонецЕсли;
		АдресВХранилище = ПомещенныеФайлы[0].Хранение;
	КонецЕсли;

	СообщениеСтатуса = НСтр("ru='Загрузка...';uk='Завантаження...'");

	Результат = ЗагрузитьЦеныНаСервере(АдресВХранилище, ВидЦены, ДатаЦены, РазмерПакета,
		НомерПервойСтроки, НомерПоследнейСтроки, ДопРекв_ЕстьПокраска,
		ЕИ_M, ЕИ_ST, ЕИ_ШТАНГА, ЕИ_PAK, ЕИ_PAA);

	СообщениеСтатуса = Результат;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗагрузитьЦеныНаСервере(АдресВХранилище, ВидЦены, ДатаЦены, РазмерПакета,
	НомерПервойСтроки, НомерПоследнейСтроки, ДопРекв_ЕстьПокраска,
	ЕИ_M, ЕИ_ST, ЕИ_ШТАНГА, ЕИ_PAK, ЕИ_PAA)

	// 1. Достать файл из временного хранилища во временный файл и прочитать его
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресВХранилище);
	Если ДвоичныеДанные = Неопределено Тогда
		Возврат НСтр("ru='Файл не найден во временном хранилище';uk='Файл не знайдено у тимчасовому сховищі'");
	КонецЕсли;
	ИмяВремФайла = ПолучитьИмяВременногоФайла("xlsx");
	ДвоичныеДанные.Записать(ИмяВремФайла);

	Попытка
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ИмяВремФайла);
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		УдалитьФайлы(ИмяВремФайла);
		Возврат НСтр("ru='Ошибка чтения файла: ';uk='Помилка читання файлу: '") + ТекстОшибки;
	КонецПопытки;
	УдалитьФайлы(ИмяВремФайла);

	ПерваяСтрока = ?(НомерПервойСтроки > 0, НомерПервойСтроки, 2);
	ПоследняяСтрока = ?(НомерПоследнейСтроки > 0, НомерПоследнейСтроки, ТабДок.ВысотаТаблицы);
	Если ПоследняяСтрока < ПерваяСтрока Тогда
		Возврат НСтр("ru='Файл пуст';uk='Файл порожній'");
	КонецЕсли;

	// 2. Маппінг GPL кодів → базові ОВ (з форми)
	СоответствиеБазовыхЕИ = Новый Соответствие;
	СоответствиеБазовыхЕИ.Вставить("M", ЕИ_M);
	СоответствиеБазовыхЕИ.Вставить("ST", ЕИ_ST);
	СоответствиеБазовыхЕИ.Вставить("PAK", ЕИ_PAK);
	СоответствиеБазовыхЕИ.Вставить("PAA", ЕИ_PAA);

	// 3. Прочитать строки и подготовить данные
	ТаблицаДанных = Новый ТаблицаЗначений;
	ТаблицаДанных.Колонки.Добавить("Номенклатура");
	ТаблицаДанных.Колонки.Добавить("Характеристика");
	ТаблицаДанных.Колонки.Добавить("Упаковка");
	ТаблицаДанных.Колонки.Добавить("Цена");

	КоличествоОбработано = 0;
	КоличествоНеНайдено = 0;
	КоличествоБезХарактеристики = 0;
	КоличествоБезУпаковки = 0;
	КоличествоДублікатов = 0;
	// Дедуплікація: ключ "Номенклатура|Характеристика|Упаковка" → індекс рядка
	КлючіДодані = Новый Соответствие;
	// Кеш характеристик за Видом номенклатури (Владелец = ВидНоменклатуры).
	// Ключ — ссылка ВидНоменклатуры, значення — Массив характеристик.
	КешХарактеристик = Новый Соответствие;

	Для НомерСтроки = ПерваяСтрока По ПоследняяСтрока Цикл

		Артикул   = СокрЛП(ТабДок.Область(НомерСтроки, 1).Текст);
		ЦенаТекст = СокрЛП(ТабДок.Область(НомерСтроки, 2).Текст);
		КодЕИ     = ВРег(СокрЛП(ТабДок.Область(НомерСтроки, 3).Текст));

		Если НЕ ЗначениеЗаполнено(Артикул) Тогда
			Продолжить;
		КонецЕсли;

		// Найти номенклатуру по артикулу + ВидНоменклатуры/ИспХар + базова ОВ + НаборУпаковок
		ЗапросНом = Новый Запрос(
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Ссылка,
			|	ВидНоменклатуры,
			|	ВидНоменклатуры.ИспользованиеХарактеристик КАК ИспХар,
			|	ЕдиницаИзмерения КАК БазоваяЕИ,
			|	НаборУпаковок
			|ИЗ Справочник.Номенклатура ГДЕ Артикул = &Артикул");
		ЗапросНом.УстановитьПараметр("Артикул", Артикул);
		ВыборкаНом = ЗапросНом.Выполнить().Выбрать();

		Если НЕ ВыборкаНом.Следующий() Тогда
			КоличествоНеНайдено = КоличествоНеНайдено + 1;
			Сообщить("Артикул не знайдено: " + Артикул);
			Продолжить;
		КонецЕсли;

		ВидИспользуетХарактеристики = ВыборкаНом.ИспХар <> Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать
			И ЗначениеЗаполнено(ВыборкаНом.ИспХар);

		// Цена
		Попытка
			ЦенаТекст = СтрЗаменить(ЦенаТекст, ",", ".");
			Цена = Число(ЦенаТекст);
		Исключение
			Продолжить;
		КонецПопытки;

		Если Цена <= 0 Тогда
			Продолжить;
		КонецЕсли;

		// 1. Визначити цільову базову ОВ за GPL-кодом.
		// ST для профілів (база = м) інтерпретуємо як штангу, інакше — як шт.
		ЦільоваБазоваЕИ = СоответствиеБазовыхЕИ.Получить(КодЕИ);
		Если КодЕИ = "ST" И ВыборкаНом.БазоваяЕИ = ЕИ_M И ЗначениеЗаполнено(ЕИ_ШТАНГА) Тогда
			ЦільоваБазоваЕИ = ЕИ_ШТАНГА;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ЦільоваБазоваЕИ) Тогда
			КоличествоБезУпаковки = КоличествоБезУпаковки + 1;
			Сообщить("Невідомий код ОВ '" + КодЕИ + "' для арт. " + Артикул + " (заповніть поле на формі)");
			Продолжить;
		КонецЕсли;

		// 2. Підбір Упаковки: спочатку базова ОВ номенклатури, далі — індивідуальна або з НабораУпаковок
		Упаковка = Неопределено;
		Если ВыборкаНом.БазоваяЕИ = ЦільоваБазоваЕИ Тогда
			Упаковка = ВыборкаНом.БазоваяЕИ;
		Иначе
			ЗапросУп = Новый Запрос(
				"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка
				|ИЗ Справочник.УпаковкиЕдиницыИзмерения
				|ГДЕ ЕдиницаИзмерения = &ЦільоваБазоваЕИ
				|	И НЕ ПометкаУдаления
				|	И (ВЫБОР
				|		КОГДА &НаборУпаковок = ЗНАЧЕНИЕ(Справочник.НаборыУпаковок.ИндивидуальныйДляНоменклатуры)
				|			ТОГДА Владелец = &Номенклатура
				|		КОГДА &НаборУпаковок <> ЗНАЧЕНИЕ(Справочник.НаборыУпаковок.ПустаяСсылка)
				|			ТОГДА Владелец = &НаборУпаковок
				|		ИНАЧЕ ЛОЖЬ
				|		КОНЕЦ)");
			ЗапросУп.УстановитьПараметр("ЦільоваБазоваЕИ", ЦільоваБазоваЕИ);
			ЗапросУп.УстановитьПараметр("Номенклатура", ВыборкаНом.Ссылка);
			ЗапросУп.УстановитьПараметр("НаборУпаковок", ВыборкаНом.НаборУпаковок);
			ВыборкаУп = ЗапросУп.Выполнить().Выбрать();
			Если ВыборкаУп.Следующий() Тогда
				Упаковка = ВыборкаУп.Ссылка;
			КонецЕсли;
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(Упаковка) Тогда
			КоличествоБезУпаковки = КоличествоБезУпаковки + 1;
			Сообщить("Упаковка з ОВ '" + КодЕИ + "' не знайдена для арт. " + Артикул + " (немає в індивідуальних/наборі упаковок)");
			Продолжить;
		КонецЕсли;

		// Характеристики: для Видів з характеристиками — ВСІ характеристики цього Виду;
		// для Видів без характеристик — порожня характеристика (одна).
		МассивХарактеристик = Новый Массив;
		Если ВидИспользуетХарактеристики Тогда
			МассивКеш = КешХарактеристик.Получить(ВыборкаНом.ВидНоменклатуры);
			Если МассивКеш = Неопределено Тогда
				МассивКеш = Новый Массив;
				ЗапросХар = Новый Запрос(
					"ВЫБРАТЬ Ссылка ИЗ Справочник.ХарактеристикиНоменклатуры
					|ГДЕ Владелец = &Владелец И НЕ ПометкаУдаления");
				ЗапросХар.УстановитьПараметр("Владелец", ВыборкаНом.ВидНоменклатуры);
				ВыборкаХар = ЗапросХар.Выполнить().Выбрать();
				Пока ВыборкаХар.Следующий() Цикл
					МассивКеш.Добавить(ВыборкаХар.Ссылка);
				КонецЦикла;
				КешХарактеристик.Вставить(ВыборкаНом.ВидНоменклатуры, МассивКеш);
			КонецЕсли;
			Если МассивКеш.Количество() = 0 Тогда
				КоличествоБезХарактеристики = КоличествоБезХарактеристики + 1;
				Сообщить("У Виду номенклатури '" + ВыборкаНом.ВидНоменклатуры
					+ "' немає жодної характеристики (арт. " + Артикул + " — пропущено)");
				Продолжить;
			КонецЕсли;
			Для Каждого Хар Из МассивКеш Цикл
				МассивХарактеристик.Добавить(Хар);
			КонецЦикла;
		Иначе
			МассивХарактеристик.Добавить(Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
		КонецЕсли;

		// По одному рядку на кожну характеристику (для Видів без характеристик масив містить
		// порожнє посилання — отримуємо одну рядок).
		Для Каждого Характеристика Из МассивХарактеристик Цикл
			// Дедуплікація: якщо вже є рядок з тим же ключем — оновити ціну (last wins)
			Ключ = Строка(ВыборкаНом.Ссылка.УникальныйИдентификатор()) + "|"
				+ Строка(Характеристика.УникальныйИдентификатор()) + "|"
				+ Строка(Упаковка.УникальныйИдентификатор());
			ІндексІснуючого = КлючіДодані.Получить(Ключ);
			Если ІндексІснуючого <> Неопределено Тогда
				ТаблицаДанных[ІндексІснуючого].Цена = Цена;
				КоличествоДублікатов = КоличествоДублікатов + 1;
			Иначе
				Строка = ТаблицаДанных.Добавить();
				Строка.Номенклатура = ВыборкаНом.Ссылка;
				Строка.Характеристика = Характеристика;
				Строка.Упаковка = Упаковка;
				Строка.Цена = Цена;
				КлючіДодані.Вставить(Ключ, ТаблицаДанных.Количество() - 1);
				КоличествоОбработано = КоличествоОбработано + 1;
			КонецЕсли;
		КонецЦикла;

	КонецЦикла;

	Если ТаблицаДанных.Количество() = 0 Тогда
		Возврат "Жодного артикула не знайдено. Не знайдено: " + КоличествоНеНайдено;
	КонецЕсли;

	// 4. Создать документы пакетами
	ФактическийРазмерПакета = ?(РазмерПакета > 0, РазмерПакета, 2000);
	ВсегоСтрок = ТаблицаДанных.Количество();
	ВсегоДокументов = 0;

	ИндексНачала = 0;
	Пока ИндексНачала < ВсегоСтрок Цикл

		ИндексКонца = Мин(ИндексНачала + ФактическийРазмерПакета, ВсегоСтрок);

		НачатьТранзакцию();
		Попытка
			Док = Документы.УстановкаЦенНоменклатуры.СоздатьДокумент();
			Док.Дата = ДатаЦены;
			Док.Статус = Перечисления.СтатусыУстановокЦенНоменклатуры.Согласован;
			Док.Комментарий = "GPL — автоматичне завантаження (пакет " + (ВсегоДокументов + 1) + ")";

			// ВидыЦен табличная часть
			СтрокаВЦ = Док.ВидыЦен.Добавить();
			СтрокаВЦ.ВидЦены = ВидЦены;

			// Товары — одна строка на артикул:
			//   з характеристикою "Без фарбування" для Видів з характеристиками,
			//   без характеристики для Видів без характеристик (арт. 2xx)
			Для Инд = ИндексНачала По ИндексКонца - 1 Цикл
				СтрокаДанных = ТаблицаДанных[Инд];

				СтрокаТовары = Док.Товары.Добавить();
				СтрокаТовары.Номенклатура = СтрокаДанных.Номенклатура;
				СтрокаТовары.Характеристика = СтрокаДанных.Характеристика;
				СтрокаТовары.ВидЦены = ВидЦены;
				СтрокаТовары.Цена = СтрокаДанных.Цена;
				СтрокаТовары.Упаковка = СтрокаДанных.Упаковка;
			КонецЦикла;

			// Сначала записать (bypass ПередЗаписью), потом провести
			Док.ОбменДанными.Загрузка = Истина;
			Док.Записать(РежимЗаписиДокумента.Запись);
			// Провести уже без флага загрузки
			Док.ОбменДанными.Загрузка = Ложь;
			Док.Записать(РежимЗаписиДокумента.Проведение);
			ВсегоДокументов = ВсегоДокументов + 1;

			ЗафиксироватьТранзакцию();

		Исключение
			ОтменитьТранзакцию();
			Сообщить("Помилка пакету " + (ВсегоДокументов + 1) + ": " + ОписаниеОшибки());
		КонецПопытки;

		ИндексНачала = ИндексКонца;

	КонецЦикла;

	Возврат "Завершено. Оброблено: " + КоличествоОбработано
		+ ", Не знайдено: " + КоличествоНеНайдено
		+ ", Без характеристики: " + КоличествоБезХарактеристики
		+ ", Без упаковки: " + КоличествоБезУпаковки
		+ ", Дублікатів об'єднано: " + КоличествоДублікатов
		+ ", Документів: " + ВсегоДокументов;

КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ДатаЦены = ТекущаяДатаСеанса();
	РазмерПакета = 2000;
	НомерПервойСтроки = 2;
	НомерПоследнейСтроки = 0;

	// Автозаполнення ДопРеквізита ЕстьПокраска
	ДопРекв_ЕстьПокраска = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоРеквизиту("Имя", "ЕстьПокраска");

	// Автозаповнення базових ОВ за найменуванням
	ЗапросЕИ = Новый Запрос(
		"ВЫБРАТЬ Ссылка, Наименование
		|ИЗ Справочник.УпаковкиЕдиницыИзмерения
		|ГДЕ Владелец = &Владелец");
	ЗапросЕИ.УстановитьПараметр("Владелец", Справочники.НаборыУпаковок.БазовыеЕдиницыИзмерения);
	ВыборкаЕИ = ЗапросЕИ.Выполнить().Выбрать();
	Пока ВыборкаЕИ.Следующий() Цикл
		Имя = ВРег(СокрЛП(ВыборкаЕИ.Наименование));
		Если Имя = "М" И НЕ ЗначениеЗаполнено(ЕИ_M) Тогда
			ЕИ_M = ВыборкаЕИ.Ссылка;
		ИначеЕсли Имя = "ШТ" И НЕ ЗначениеЗаполнено(ЕИ_ST) Тогда
			ЕИ_ST = ВыборкаЕИ.Ссылка;
		ИначеЕсли (Имя = "ПАКОВ" Или Имя = "УПАК" Или Имя = "ПАК") И НЕ ЗначениеЗаполнено(ЕИ_PAK) Тогда
			ЕИ_PAK = ВыборкаЕИ.Ссылка;
		ИначеЕсли Имя = "ПАР" И НЕ ЗначениеЗаполнено(ЕИ_PAA) Тогда
			ЕИ_PAA = ВыборкаЕИ.Ссылка;
		ИначеЕсли Имя = "ШТАНГА" И НЕ ЗначениеЗаполнено(ЕИ_ШТАНГА) Тогда
			ЕИ_ШТАНГА = ВыборкаЕИ.Ссылка;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
