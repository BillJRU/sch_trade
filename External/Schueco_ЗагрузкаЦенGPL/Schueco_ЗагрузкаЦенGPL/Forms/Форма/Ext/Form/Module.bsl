
&НаКлиенте
Процедура ПутьКФайлуНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ДиалогВыбора = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбора.Фильтр = "Excel (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*";
	ДиалогВыбора.Заголовок = НСтр("ru='Выберите файл GPL (flat)';uk='Оберіть файл GPL (flat)'");
	Если ДиалогВыбора.Выбрать() Тогда
		ПутьКФайлу = ДиалогВыбора.ПолноеИмяФайла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанные(Команда)

	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
		Сообщить(НСтр("ru='Не выбран файл';uk='Не обрано файл'"));
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ВидЦены) Тогда
		Сообщить(НСтр("ru='Не выбран вид цены';uk='Не обрано вид ціни'"));
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ДатаЦены) Тогда
		Сообщить(НСтр("ru='Не указана дата цен';uk='Не вказано дату цін'"));
		Возврат;
	КонецЕсли;

	СообщениеСтатуса = НСтр("ru='Загрузка...';uk='Завантаження...'");

	Результат = ЗагрузитьЦеныНаСервере(ПутьКФайлу, ВидЦены, ДатаЦены, РазмерПакета,
		НомерПервойСтроки, НомерПоследнейСтроки);

	СообщениеСтатуса = Результат;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗагрузитьЦеныНаСервере(ПутьКФайлу, ВидЦены, ДатаЦены, РазмерПакета,
	НомерПервойСтроки, НомерПоследнейСтроки)

	// 1. Прочитать flat Excel
	Попытка
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ПутьКФайлу);
	Исключение
		Возврат НСтр("ru='Ошибка чтения файла: ';uk='Помилка читання файлу: '") + ОписаниеОшибки();
	КонецПопытки;

	ПерваяСтрока = ?(НомерПервойСтроки > 0, НомерПервойСтроки, 2);
	ПоследняяСтрока = ?(НомерПоследнейСтроки > 0, НомерПоследнейСтроки, ТабДок.ВысотаТаблицы);
	Если ПоследняяСтрока < ПерваяСтрока Тогда
		Возврат НСтр("ru='Файл пуст';uk='Файл порожній'");
	КонецЕсли;

	// 2. Подготовить кэш ЕИ
	КэшЕИ = Новый Соответствие;
	Запрос = Новый Запрос("ВЫБРАТЬ Ссылка, Наименование ИЗ Справочник.УпаковкиЕдиницыИзмерения");
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		КэшЕИ.Вставить(ВРег(СокрЛП(Выборка.Наименование)), Выборка.Ссылка);
	КонецЦикла;
	// Маппинг GPL кодов
	СоответствиеЕИ = Новый Соответствие;
	СоответствиеЕИ.Вставить("M", КэшЕИ.Получить("М"));
	СоответствиеЕИ.Вставить("ST", КэшЕИ.Получить("ШТ"));
	СоответствиеЕИ.Вставить("PAK", КэшЕИ.Получить("УПАК"));
	СоответствиеЕИ.Вставить("PAA", КэшЕИ.Получить("ПАР"));

	// Fallback
	Если СоответствиеЕИ.Получить("M") = Неопределено Тогда
		СоответствиеЕИ.Вставить("M", КэшЕИ.Получить("М."));
	КонецЕсли;
	Если СоответствиеЕИ.Получить("ST") = Неопределено Тогда
		СоответствиеЕИ.Вставить("ST", КэшЕИ.Получить("ШТ."));
	КонецЕсли;

	// 3. Прочитать строки и подготовить данные
	ТаблицаДанных = Новый ТаблицаЗначений;
	ТаблицаДанных.Колонки.Добавить("Номенклатура");
	ТаблицаДанных.Колонки.Добавить("Упаковка");
	ТаблицаДанных.Колонки.Добавить("Цена");

	КоличествоОбработано = 0;
	КоличествоНеНайдено = 0;

	Для НомерСтроки = ПерваяСтрока По ПоследняяСтрока Цикл

		Артикул   = СокрЛП(ТабДок.Область(НомерСтроки, 1).Текст);
		ЦенаТекст = СокрЛП(ТабДок.Область(НомерСтроки, 2).Текст);
		КодЕИ     = ВРег(СокрЛП(ТабДок.Область(НомерСтроки, 3).Текст));

		Если НЕ ЗначениеЗаполнено(Артикул) Тогда
			Продолжить;
		КонецЕсли;

		// Найти номенклатуру по артикулу
		ЗапросНом = Новый Запрос(
			"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Номенклатура ГДЕ Артикул = &Артикул");
		ЗапросНом.УстановитьПараметр("Артикул", Артикул);
		ВыборкаНом = ЗапросНом.Выполнить().Выбрать();

		Если НЕ ВыборкаНом.Следующий() Тогда
			КоличествоНеНайдено = КоличествоНеНайдено + 1;
			Продолжить;
		КонецЕсли;

		// Цена
		Попытка
			ЦенаТекст = СтрЗаменить(ЦенаТекст, ",", ".");
			Цена = Число(ЦенаТекст);
		Исключение
			Продолжить;
		КонецПопытки;

		Если Цена <= 0 Тогда
			Продолжить;
		КонецЕсли;

		// Упаковка (ЕИ цены)
		Упаковка = СоответствиеЕИ.Получить(КодЕИ);
		Если Упаковка = Неопределено Тогда
			Упаковка = СоответствиеЕИ.Получить("ST"); // fallback шт
		КонецЕсли;

		Строка = ТаблицаДанных.Добавить();
		Строка.Номенклатура = ВыборкаНом.Ссылка;
		Строка.Упаковка = Упаковка;
		Строка.Цена = Цена;

		КоличествоОбработано = КоличествоОбработано + 1;

	КонецЦикла;

	Если ТаблицаДанных.Количество() = 0 Тогда
		Возврат "Жодного артикула не знайдено. Не знайдено: " + КоличествоНеНайдено;
	КонецЕсли;

	// 4. Создать документы пакетами
	ФактическийРазмерПакета = ?(РазмерПакета > 0, РазмерПакета, 2000);
	ВсегоСтрок = ТаблицаДанных.Количество();
	ВсегоДокументов = 0;

	ИндексНачала = 0;
	Пока ИндексНачала < ВсегоСтрок Цикл

		ИндексКонца = Мин(ИндексНачала + ФактическийРазмерПакета, ВсегоСтрок);

		НачатьТранзакцию();
		Попытка
			Док = Документы.УстановкаЦенНоменклатуры.СоздатьДокумент();
			Док.Дата = ДатаЦены;
			Док.Статус = Перечисления.СтатусыУстановокЦенНоменклатуры.Согласован;
			Док.Комментарий = "GPL — автоматичне завантаження (пакет " + (ВсегоДокументов + 1) + ")";

			// ВидыЦен табличная часть
			СтрокаВЦ = Док.ВидыЦен.Добавить();
			СтрокаВЦ.ВидЦены = ВидЦены;

			// Товары
			Для Инд = ИндексНачала По ИндексКонца - 1 Цикл
				СтрокаДанных = ТаблицаДанных[Инд];
				СтрокаТовары = Док.Товары.Добавить();
				СтрокаТовары.Номенклатура = СтрокаДанных.Номенклатура;
				СтрокаТовары.ВидЦены = ВидЦены;
				СтрокаТовары.Цена = СтрокаДанных.Цена;
				СтрокаТовары.Упаковка = СтрокаДанных.Упаковка;
			КонецЦикла;

			// Сначала записать (bypass ПередЗаписью), потом провести
			Док.ОбменДанными.Загрузка = Истина;
			Док.Записать(РежимЗаписиДокумента.Запись);
			// Провести уже без флага загрузки
			Док.ОбменДанными.Загрузка = Ложь;
			Док.Записать(РежимЗаписиДокумента.Проведение);
			ВсегоДокументов = ВсегоДокументов + 1;

			ЗафиксироватьТранзакцию();

		Исключение
			ОтменитьТранзакцию();
			Сообщить("Помилка пакету " + (ВсегоДокументов + 1) + ": " + ОписаниеОшибки());
		КонецПопытки;

		ИндексНачала = ИндексКонца;

	КонецЦикла;

	Возврат "Завершено. Оброблено: " + КоличествоОбработано
		+ ", Не знайдено: " + КоличествоНеНайдено
		+ ", Документів: " + ВсегоДокументов;

КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ДатаЦены = ТекущаяДатаСеанса();
	РазмерПакета = 2000;
	НомерПервойСтроки = 2;
	НомерПоследнейСтроки = 0;
КонецПроцедуры
