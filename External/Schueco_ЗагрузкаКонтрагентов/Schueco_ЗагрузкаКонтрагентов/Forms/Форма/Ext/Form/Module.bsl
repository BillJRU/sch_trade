
&НаКлиенте
Процедура ПутьКФайлуНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ДиалогВыбора = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбора.Фильтр = "Excel (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*";
	ДиалогВыбора.Заголовок = НСтр("ru='Выберите файл контрагентов';uk='Оберіть файл контрагентів'");
	Если ДиалогВыбора.Выбрать() Тогда
		ПутьКФайлу = ДиалогВыбора.ПолноеИмяФайла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанные(Команда)

	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Укажите путь к файлу';uk='Вкажіть шлях до файлу'"));
		Возврат;
	КонецЕсли;

	КоличествоОбработано = 0;
	КоличествоСоздано    = 0;
	КоличествоОбновлено  = 0;
	КоличествоКонтактов  = 0;
	КоличествоОшибок     = 0;
	СообщениеСтатуса     = НСтр("ru='Загрузка...';uk='Завантаження...'");

	Результат = ЗагрузитьДанныеНаСервере(ПутьКФайлу,
		РежимОбновления, НомерПервойСтроки, НомерПоследнейСтроки);

	КоличествоОбработано = Результат.Обработано;
	КоличествоСоздано    = Результат.Создано;
	КоличествоОбновлено  = Результат.Обновлено;
	КоличествоКонтактов  = Результат.Контактов;
	КоличествоОшибок     = Результат.Ошибок;
	СообщениеСтатуса     = Результат.Сообщение;

КонецПроцедуры

// ===================================================================
// Видалення завантажених контрагентів
// ===================================================================

&НаКлиенте
Процедура УдалитьЗагруженные(Команда)

	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Укажите файл — контрагенты будут удалены по именам из файла';uk='Вкажіть файл — контрагенти будуть видалені за іменами з файлу'"));
		Возврат;
	КонецЕсли;

	ОписаниеОповещения = Новый ОписаниеОповещения("УдалитьЗагруженныеЗавершение", ЭтотОбъект);
	ПоказатьВопрос(ОписаниеОповещения,
		НСтр("ru='Удалить контрагентов, партнёров, контактных лиц и банковские счета, загруженные из этого файла? Это действие необратимо!';uk='Видалити контрагентів, партнерів, контактних осіб та банківські рахунки, завантажені з цього файлу? Цю дію неможливо скасувати!'"),
		РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

&НаКлиенте
Процедура УдалитьЗагруженныеЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	РезультатУдаления = УдалитьЗагруженныеНаСервере(ПутьКФайлу,
		НомерПервойСтроки, НомерПоследнейСтроки);

	КоличествоОбработано = РезультатУдаления.Удалено;
	КоличествоСоздано    = 0;
	КоличествоОбновлено  = 0;
	КоличествоКонтактов  = 0;
	КоличествоОшибок     = РезультатУдаления.Ошибок;
	СообщениеСтатуса     = РезультатУдаления.Сообщение;

КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	НомерПервойСтроки = 2;
	НомерПоследнейСтроки = 0;
КонецПроцедуры

// ===================================================================
// Формат Clients_Flat.xlsx (22 колонки A–V):
//   A  Manager         — ПІБ менеджера → Справочник.Пользователи
//   B  Company Name    — Повне юридичне найменування (НаименованиеПолное)
//   C  Short Name      — Коротке найменування (Наименование, до 100 символів)
//   D  Company Address — Адреса
//   E  ЄДРПОУ          — КодПоЕДРПОУ
//   F  ИПН             — НалоговыйНомер / ИННПлательщикаНДС
//   G  Bank Details    — Банківські реквізити (вільний текст)
//   H–J   Contact 1 (Name / Phone / Email)
//   K–M   Contact 2
//   N–P   Contact 3
//   Q–S   Contact 4
//   T–V   Contact 5
// ===================================================================

&НаСервереБезКонтекста
Функция ЗагрузитьДанныеНаСервере(ПутьКФайлу,
	РежимОбновления, НомерПервойСтроки, НомерПоследнейСтроки)

	Результат = Новый Структура("Обработано, Создано, Обновлено, Контактов, Ошибок, Сообщение",
		0, 0, 0, 0, 0, "");

	Попытка
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ПутьКФайлу);
	Исключение
		Результат.Сообщение = НСтр("ru='Ошибка чтения файла: ';uk='Помилка читання файлу: '") + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;

	ПерваяСтрока = ?(НомерПервойСтроки > 0, НомерПервойСтроки, 2);
	ПоследняяСтрока = ?(НомерПоследнейСтроки > 0, НомерПоследнейСтроки, ТабДок.ВысотаТаблицы);

	КэшМенеджеров = Новый Соответствие;

	Для НомерСтроки = ПерваяСтрока По ПоследняяСтрока Цикл

		ИмяМенеджера    = СокрЛП(ТабДок.Область(НомерСтроки, 1).Текст);  // A  Manager
		ПолноеИмя       = СокрЛП(ТабДок.Область(НомерСтроки, 2).Текст);  // B  Company Name
		КороткоеИмя     = СокрЛП(ТабДок.Область(НомерСтроки, 3).Текст);  // C  Short Name
		АдресКомпании   = СокрЛП(ТабДок.Область(НомерСтроки, 4).Текст);  // D  Company Address (presentation)
		// Структуровані компоненти адреси E–Q (35 колонок, A–AI)
		АдрИндекс       = СокрЛП(ТабДок.Область(НомерСтроки, 5).Текст);  // E  Індекс
		АдрОбласть      = СокрЛП(ТабДок.Область(НомерСтроки, 6).Текст);  // F  Область
		АдрРайон        = СокрЛП(ТабДок.Область(НомерСтроки, 7).Текст);  // G  Район
		АдрТипГорода    = СокрЛП(ТабДок.Область(НомерСтроки, 8).Текст);  // H  Тип міста (м., смт.)
		АдрГород        = СокрЛП(ТабДок.Область(НомерСтроки, 9).Текст);  // I  Місто (назва)
		АдрТипНасПункта = СокрЛП(ТабДок.Область(НомерСтроки, 10).Текст); // J  Тип нас. пункту
		АдрНаселПункт   = СокрЛП(ТабДок.Область(НомерСтроки, 11).Текст); // K  Населений пункт (назва)
		АдрТипУлицы     = СокрЛП(ТабДок.Область(НомерСтроки, 12).Текст); // L  Тип вулиці (вул., пров.)
		АдрУлица        = СокрЛП(ТабДок.Область(НомерСтроки, 13).Текст); // M  Вулиця (назва)
		АдрДом          = СокрЛП(ТабДок.Область(НомерСтроки, 14).Текст); // N  Будинок
		АдрКорпус       = СокрЛП(ТабДок.Область(НомерСтроки, 15).Текст); // O  Корпус
		АдрКвартира     = СокрЛП(ТабДок.Область(НомерСтроки, 16).Текст); // P  Квартира
		АдрОфис         = СокрЛП(ТабДок.Область(НомерСтроки, 17).Текст); // Q  Офіс
		EDRPOU          = ОчиститьПробелы(СокрЛП(ТабДок.Область(НомерСтроки, 18).Текст)); // R  ЄДРПОУ
		IPN             = ОчиститьПробелы(СокрЛП(ТабДок.Область(НомерСтроки, 19).Текст)); // S  ИПН
		БанковскиеРеквизиты = СокрЛП(ТабДок.Область(НомерСтроки, 20).Текст); // T  Bank Details

		КомпонентыАдреса = Новый Структура;
		КомпонентыАдреса.Вставить("Представление",  АдресКомпании);
		КомпонентыАдреса.Вставить("Индекс",         АдрИндекс);
		КомпонентыАдреса.Вставить("Область",        АдрОбласть);
		КомпонентыАдреса.Вставить("Район",          АдрРайон);
		КомпонентыАдреса.Вставить("ТипГорода",      АдрТипГорода);
		КомпонентыАдреса.Вставить("Город",          АдрГород);
		КомпонентыАдреса.Вставить("ТипНаселПункта", АдрТипНасПункта);
		КомпонентыАдреса.Вставить("НаселПункт",     АдрНаселПункт);
		КомпонентыАдреса.Вставить("ТипУлицы",       АдрТипУлицы);
		КомпонентыАдреса.Вставить("Улица",          АдрУлица);
		КомпонентыАдреса.Вставить("Дом",            АдрДом);
		КомпонентыАдреса.Вставить("Корпус",         АдрКорпус);
		КомпонентыАдреса.Вставить("Квартира",       АдрКвартира);
		КомпонентыАдреса.Вставить("Офис",           АдрОфис);

		ЕстьАдрес = ЗначениеЗаполнено(АдресКомпании)
			ИЛИ ЗначениеЗаполнено(АдрГород)
			ИЛИ ЗначениеЗаполнено(АдрУлица);

		Если НЕ ЗначениеЗаполнено(ПолноеИмя) И НЕ ЗначениеЗаполнено(КороткоеИмя) Тогда
			Продолжить;
		КонецЕсли;

		// Якщо Short Name порожній — використати Company Name
		Если НЕ ЗначениеЗаполнено(КороткоеИмя) Тогда
			КороткоеИмя = ПолноеИмя;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ПолноеИмя) Тогда
			ПолноеИмя = КороткоеИмя;
		КонецЕсли;

		Результат.Обработано = Результат.Обработано + 1;

		НачатьТранзакцию();
		Попытка

			МенеджерСсылка = РезолвнутьМенеджера(ИмяМенеджера, КэшМенеджеров);

			// ЮрФизЛицо визначаємо за повним іменем (B) — там є ТОВ/ПАТ/ФОП
			ЮрФизТип = ОпределитьЮрФизЛицо(ПолноеИмя);
			ЭтоЧастноеЛицо = (ЮрФизТип = Перечисления.ЮрФизЛицо.ФизЛицо);

			СсылкаКонтрагента = ЗнайтиКонтрагента(EDRPOU, КороткоеИмя);

			ЭтоОбновление = Ложь;
			ОбъектКонтрагент = Неопределено;
			ПартнерСсылка = Неопределено;

			Если ЗначениеЗаполнено(СсылкаКонтрагента) Тогда
				Если НЕ РежимОбновления Тогда
					ОтменитьТранзакцию();
					Продолжить;
				КонецЕсли;
				ОбъектКонтрагент = СсылкаКонтрагента.ПолучитьОбъект();
				ПартнерСсылка = ОбъектКонтрагент.Партнер;
				ЭтоОбновление = Истина;

				// Обновить КИ партнера — очистить и перезаписать
				Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
					ОбъектПартнер = ПартнерСсылка.ПолучитьОбъект();
					ОбъектПартнер.КонтактнаяИнформация.Очистить();
					Если ЕстьАдрес Тогда
						ЗаписатьАдресВТЧ(ОбъектПартнер, КомпонентыАдреса,
							Справочники.ВидыКонтактнойИнформации.АдресПартнера);
					КонецЕсли;
					ОбъектПартнер.ОбменДанными.Загрузка = Истина;
					ОбъектПартнер.Записать();
				КонецЕсли;
			Иначе
				// === Створити Партнера ===
				ОбъектПартнер = Справочники.Партнеры.СоздатьЭлемент();
				ОбъектПартнер.Наименование       = Лев(КороткоеИмя, 100);
				ОбъектПартнер.НаименованиеПолное = ПолноеИмя;
				ОбъектПартнер.Клиент             = Истина;
				ОбъектПартнер.ДатаРегистрации    = ТекущаяДатаСеанса();
				ОбъектПартнер.ЮрФизЛицо          = ?(ЭтоЧастноеЛицо,
					Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо,
					Перечисления.КомпанияЧастноеЛицо.Компания);
				Если ЗначениеЗаполнено(МенеджерСсылка) Тогда
					ОбъектПартнер.ОсновнойМенеджер = МенеджерСсылка;
				КонецЕсли;

				// КИ партнера — адрес (напрямую в ТЧ, щоб BSP не перезаписав JSON)
				ОбъектПартнер.КонтактнаяИнформация.Очистить();
				Если ЕстьАдрес Тогда
					ЗаписатьАдресВТЧ(ОбъектПартнер, КомпонентыАдреса,
						Справочники.ВидыКонтактнойИнформации.АдресПартнера);
				КонецЕсли;

				ОбъектПартнер.Записать();
				ПартнерСсылка = ОбъектПартнер.Ссылка;

				ОбъектКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
			КонецЕсли;

			// === Заповнити Контрагента ===
			ОбъектКонтрагент.Наименование       = Лев(КороткоеИмя, 100);
			ОбъектКонтрагент.НаименованиеПолное = ПолноеИмя;
			ОбъектКонтрагент.Партнер            = ПартнерСсылка;
			ОбъектКонтрагент.ЮрФизЛицо          = ЮрФизТип;

			Если ЗначениеЗаполнено(EDRPOU) И НЕ ЭтоЧастноеЛицо Тогда
				ОбъектКонтрагент.КодПоЕДРПОУ = Лев(EDRPOU, 10);
			КонецЕсли;
			Если ЗначениеЗаполнено(IPN) Тогда
				ОбъектКонтрагент.НалоговыйНомер = Лев(IPN, 50);
				Если СтрДлина(IPN) <= 12 Тогда
					ОбъектКонтрагент.ИННПлательщикаНДС = IPN;
				КонецЕсли;
			КонецЕсли;

			// КИ контрагента — очистить и записать адреса напрямую в ТЧ
			ОбъектКонтрагент.КонтактнаяИнформация.Очистить();
			Если ЕстьАдрес Тогда
				ЗаписатьАдресВТЧ(ОбъектКонтрагент, КомпонентыАдреса,
					Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента);
				Если НЕ ЭтоЧастноеЛицо Тогда
					ЗаписатьАдресВТЧ(ОбъектКонтрагент, КомпонентыАдреса,
						Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента);
				КонецЕсли;
			КонецЕсли;

			ОбъектКонтрагент.ОбменДанными.Загрузка = Истина;
			ОбъектКонтрагент.Записать();
			КонтрагентСсылка = ОбъектКонтрагент.Ссылка;

			// === Банківський рахунок ===
			Если ЗначениеЗаполнено(БанковскиеРеквизиты) Тогда
				Если НЕ РазобратьИСоздатьБанковскийСчет(КонтрагентСсылка, БанковскиеРеквизиты) Тогда
					ОбъектКонтрагентДоп = КонтрагентСсылка.ПолучитьОбъект();
					Если ПустаяСтрока(ОбъектКонтрагентДоп.ДополнительнаяИнформация) Тогда
						ОбъектКонтрагентДоп.ДополнительнаяИнформация = БанковскиеРеквизиты;
					Иначе
						ОбъектКонтрагентДоп.ДополнительнаяИнформация =
							ОбъектКонтрагентДоп.ДополнительнаяИнформация + Символы.ПС + БанковскиеРеквизиты;
					КонецЕсли;
					ОбъектКонтрагентДоп.ОбменДанными.Загрузка = Истина;
					ОбъектКонтрагентДоп.Записать();
				КонецЕсли;
			КонецЕсли;

			// === Контактні особи 1–5 (колонки U–AI, крок 3) ===
			Для Слот = 1 По 5 Цикл
				КолОснова = 21 + (Слот - 1) * 3; // U=21, X=24, AA=27, AD=30, AG=33
				КонтактИмя    = СокрЛП(ТабДок.Область(НомерСтроки, КолОснова).Текст);
				КонтактТелефон = СокрЛП(ТабДок.Область(НомерСтроки, КолОснова + 1).Текст);
				КонтактEmail  = СокрЛП(ТабДок.Область(НомерСтроки, КолОснова + 2).Текст);

				Если ЗначениеЗаполнено(КонтактИмя) ИЛИ ЗначениеЗаполнено(КонтактТелефон) ИЛИ ЗначениеЗаполнено(КонтактEmail) Тогда
					Если СоздатьКонтактноеЛицо(ПартнерСсылка, КонтактИмя, КонтактТелефон, КонтактEmail) Тогда
						Результат.Контактов = Результат.Контактов + 1;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;

			ЗафиксироватьТранзакцию();

			Если ЭтоОбновление Тогда
				Результат.Обновлено = Результат.Обновлено + 1;
			Иначе
				Результат.Создано = Результат.Создано + 1;
			КонецЕсли;

		Исключение
			ОтменитьТранзакцию();
			Результат.Ошибок = Результат.Ошибок + 1;
			Сообщить(НСтр("ru='Строка ';uk='Рядок '") + НомерСтроки + " ("
				+ КороткоеИмя + "): " + ОписаниеОшибки());
		КонецПопытки;

	КонецЦикла;

	Результат.Сообщение = НСтр("ru='Готово';uk='Готово'") + ". "
		+ НСтр("ru='Обработано: ';uk='Оброблено: '") + Результат.Обработано + ", "
		+ НСтр("ru='создано: ';uk='створено: '") + Результат.Создано + ", "
		+ НСтр("ru='обновлено: ';uk='оновлено: '") + Результат.Обновлено + ", "
		+ НСтр("ru='контактов: ';uk='контактів: '") + Результат.Контактов + ", "
		+ НСтр("ru='ошибок: ';uk='помилок: '") + Результат.Ошибок;

	Возврат Результат;

КонецФункции

// ===================================================================
// Видалення контрагентів за іменами з файлу
// ===================================================================

&НаСервереБезКонтекста
Функция УдалитьЗагруженныеНаСервере(ПутьКФайлу, НомерПервойСтроки, НомерПоследнейСтроки)

	Результат = Новый Структура("Удалено, Ошибок, Сообщение", 0, 0, "");

	Попытка
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ПутьКФайлу);
	Исключение
		Результат.Сообщение = НСтр("ru='Ошибка чтения файла: ';uk='Помилка читання файлу: '") + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;

	ПерваяСтрока = ?(НомерПервойСтроки > 0, НомерПервойСтроки, 2);
	ПоследняяСтрока = ?(НомерПоследнейСтроки > 0, НомерПоследнейСтроки, ТабДок.ВысотаТаблицы);

	Для НомерСтроки = ПерваяСтрока По ПоследняяСтрока Цикл

		ПолноеИмя   = СокрЛП(ТабДок.Область(НомерСтроки, 2).Текст); // B — Company Name
		КороткоеИмя = СокрЛП(ТабДок.Область(НомерСтроки, 3).Текст); // C — Short Name
		EDRPOU      = ОчиститьПробелы(СокрЛП(ТабДок.Область(НомерСтроки, 18).Текст)); // R — ЄДРПОУ

		Если НЕ ЗначениеЗаполнено(КороткоеИмя) И НЕ ЗначениеЗаполнено(ПолноеИмя) Тогда
			Продолжить;
		КонецЕсли;

		// Пошук: EDRPOU → Short Name → Company Name (повне юр. ім'я)
		СсылкаКонтрагента = ЗнайтиКонтрагента(EDRPOU, КороткоеИмя);
		Если НЕ ЗначениеЗаполнено(СсылкаКонтрагента) И ЗначениеЗаполнено(ПолноеИмя) Тогда
			СсылкаКонтрагента = ЗнайтиКонтрагента("", ПолноеИмя);
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(СсылкаКонтрагента) Тогда
			Сообщить(НСтр("ru='Не найден: ';uk='Не знайдено: '") + ?(ЗначениеЗаполнено(КороткоеИмя), КороткоеИмя, ПолноеИмя));
			Продолжить;
		КонецЕсли;

		НачатьТранзакцию();
		Попытка

			ОбъектКонтрагент = СсылкаКонтрагента.ПолучитьОбъект();
			ПартнерСсылка = ОбъектКонтрагент.Партнер;

			// 1. Видалити банківські рахунки контрагента
			ЗапросБС = Новый Запрос(
				"ВЫБРАТЬ Ссылка ИЗ Справочник.БанковскиеСчетаКонтрагентов ГДЕ Владелец = &Владелец");
			ЗапросБС.УстановитьПараметр("Владелец", СсылкаКонтрагента);
			ВыборкаБС = ЗапросБС.Выполнить().Выбрать();
			Пока ВыборкаБС.Следующий() Цикл
				ВыборкаБС.Ссылка.ПолучитьОбъект().Удалить();
			КонецЦикла;

			// 2. Видалити контрагента
			ОбъектКонтрагент.Удалить();

			// 3. Видалити контактних осіб партнера
			Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
				ЗапросКЛ = Новый Запрос(
					"ВЫБРАТЬ Ссылка ИЗ Справочник.КонтактныеЛицаПартнеров ГДЕ Владелец = &Владелец");
				ЗапросКЛ.УстановитьПараметр("Владелец", ПартнерСсылка);
				ВыборкаКЛ = ЗапросКЛ.Выполнить().Выбрать();
				Пока ВыборкаКЛ.Следующий() Цикл
					ВыборкаКЛ.Ссылка.ПолучитьОбъект().Удалить();
				КонецЦикла;

				// 4. Видалити партнера (якщо немає інших контрагентів)
				ЗапросДругие = Новый Запрос(
					"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Контрагенты
					|ГДЕ Партнер = &Партнер И НЕ ПометкаУдаления");
				ЗапросДругие.УстановитьПараметр("Партнер", ПартнерСсылка);
				Если ЗапросДругие.Выполнить().Пустой() Тогда
					ПартнерСсылка.ПолучитьОбъект().Удалить();
				КонецЕсли;
			КонецЕсли;

			Результат.Удалено = Результат.Удалено + 1;
			ЗафиксироватьТранзакцию();

		Исключение
			ОтменитьТранзакцию();
			Результат.Ошибок = Результат.Ошибок + 1;
			Сообщить(НСтр("ru='Ошибка удаления: ';uk='Помилка видалення: '") + КороткоеИмя + ": " + ОписаниеОшибки());
		КонецПопытки;

	КонецЦикла;

	Результат.Сообщение = НСтр("ru='Удаление завершено';uk='Видалення завершено'") + ". "
		+ НСтр("ru='Удалено: ';uk='Видалено: '") + Результат.Удалено + ", "
		+ НСтр("ru='Ошибок: ';uk='Помилок: '") + Результат.Ошибок;

	Возврат Результат;

КонецФункции

// === Хелпери ===

&НаСервереБезКонтекста
Функция РезолвнутьМенеджера(ИмяМенеджера, КэшМенеджеров)

	Если НЕ ЗначениеЗаполнено(ИмяМенеджера) Тогда
		Возврат Справочники.Пользователи.ПустаяСсылка();
	КонецЕсли;

	Закэшированный = КэшМенеджеров.Получить(ИмяМенеджера);
	Если Закэшированный <> Неопределено Тогда
		Возврат Закэшированный;
	КонецЕсли;

	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Пользователи
		|ГДЕ Наименование = &Имя И НЕ ПометкаУдаления");
	Запрос.УстановитьПараметр("Имя", Лев(ИмяМенеджера, 100));
	Выборка = Запрос.Выполнить().Выбрать();

	Если Выборка.Следующий() Тогда
		КэшМенеджеров.Вставить(ИмяМенеджера, Выборка.Ссылка);
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Сообщить(НСтр("ru='Менеджер не найден: ';uk='Менеджер не знайдений: '") + ИмяМенеджера);
	КэшМенеджеров.Вставить(ИмяМенеджера, Справочники.Пользователи.ПустаяСсылка());
	Возврат Справочники.Пользователи.ПустаяСсылка();

КонецФункции

&НаСервереБезКонтекста
Функция ОпределитьЮрФизЛицо(Наименование)
	Нормализованное = ВРег(СокрЛП(Наименование));
	Если СтрНачинаетсяС(Нормализованное, "ФОП ") ИЛИ СтрНачинаетсяС(Нормализованное, "ФОП.")
		ИЛИ СтрНачинаетсяС(Нормализованное, "СПД ") ИЛИ СтрНачинаетсяС(Нормализованное, "СПД.") Тогда
		Возврат Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель;
	КонецЕсли;
	Если СтрНачинаетсяС(Нормализованное, "ФІЗ. ОСОБА")
		ИЛИ СтрНачинаетсяС(Нормализованное, "ФИЗ. ЛИЦО")
		ИЛИ СтрНачинаетсяС(Нормализованное, "ФІЗИЧНА ОСОБА")
		ИЛИ СтрНачинаетсяС(Нормализованное, "ФИЗИЧЕСКОЕ ЛИЦО")
		ИЛИ СтрНачинаетсяС(Нормализованное, "ЧАСТНОЕ ЛИЦО")
		ИЛИ СтрНачинаетсяС(Нормализованное, "ПРИВАТНА ОСОБА") Тогда
		Возврат Перечисления.ЮрФизЛицо.ФизЛицо;
	КонецЕсли;
	Возврат Перечисления.ЮрФизЛицо.ЮрЛицо;
КонецФункции

&НаСервереБезКонтекста
Функция ОчиститьПробелы(Знач Строка)
	Стр = СтрЗаменить(Строка, Символ(160), " ");
	Стр = СтрЗаменить(Стр, " ", "");
	Возврат Стр;
КонецФункции

&НаСервереБезКонтекста
Функция ЗнайтиКонтрагента(EDRPOU, Наименование)

	Если ЗначениеЗаполнено(EDRPOU) Тогда
		Запрос = Новый Запрос(
			"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Контрагенты
			|ГДЕ КодПоЕДРПОУ = &Код И НЕ ПометкаУдаления");
		Запрос.УстановитьПараметр("Код", EDRPOU);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	КонецЕсли;

	Если ЗначениеЗаполнено(Наименование) Тогда
		Запрос = Новый Запрос(
			"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Контрагенты
			|ГДЕ Наименование = &Имя И НЕ ПометкаУдаления");
		Запрос.УстановитьПараметр("Имя", Лев(Наименование, 100));
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьАдресВТЧ(Объект, Комп, ВидКИ)

	// Записуємо адресу напряму в ТЧ КонтактнаяИнформация з повним JSON в Значение.
	// Це обходить BSP нормалізацію (ДобавитьКонтактнуюИнформацию перезаписує наші поля).
	// JSON формат з OData запису АВД Групп (виправлений вручну).
	// city = скорочення типу ("м."), cityType = назва ("Київ").
	// street = скорочення типу ("вул."), streetType = назва ("М.Тимошенка").

	АдресJSON = Новый Структура;
	АдресJSON.Вставить("value",          Комп.Представление);
	АдресJSON.Вставить("comment",        "");
	АдресJSON.Вставить("type",           "Адрес");
	АдресJSON.Вставить("country",        "Україна");
	АдресJSON.Вставить("countryCode",    "804");
	АдресJSON.Вставить("addressType",    "Административно-территориальный");
	АдресJSON.Вставить("ZIPcode",        Комп.Индекс);
	АдресJSON.Вставить("area",           Комп.Область);
	АдресJSON.Вставить("areaType",       "");
	АдресJSON.Вставить("district",       Комп.Район);
	АдресJSON.Вставить("districtType",   "");
	АдресJSON.Вставить("city",           Комп.ТипГорода);
	АдресJSON.Вставить("cityType",       Комп.Город);
	АдресJSON.Вставить("locality",       Комп.ТипНаселПункта);
	АдресJSON.Вставить("localityType",   Комп.НаселПункт);
	АдресJSON.Вставить("street",         Комп.ТипУлицы);
	АдресJSON.Вставить("streetType",     Комп.Улица);
	АдресJSON.Вставить("houseType",      ?(ЗначениеЗаполнено(Комп.Дом), "Дом", ""));
	АдресJSON.Вставить("houseNumber",    Комп.Дом);
	// Id-поля (пусті, але потрібні для повної схеми)
	АдресJSON.Вставить("id",                "");
	АдресJSON.Вставить("areaCode",          "");
	АдресJSON.Вставить("areaId",            "");
	АдресJSON.Вставить("districtId",        "");
	АдресJSON.Вставить("munDistrict",       "");
	АдресJSON.Вставить("munDistrictType",   "");
	АдресJSON.Вставить("munDistrictId",     "");
	АдресJSON.Вставить("cityId",            "");
	АдресJSON.Вставить("cityDistrict",      "");
	АдресJSON.Вставить("cityDistrictType",  "");
	АдресJSON.Вставить("cityDistrictId",    "");
	АдресJSON.Вставить("territory",         "");
	АдресJSON.Вставить("territoryType",     "");
	АдресJSON.Вставить("territoryId",       "");
	АдресJSON.Вставить("localityId",        "");
	АдресJSON.Вставить("streetId",          "");
	АдресJSON.Вставить("houseId",           "");
	АдресJSON.Вставить("stead",             "");

	МассивСтроений = Новый Массив;
	Если ЗначениеЗаполнено(Комп.Корпус) Тогда
		МассивСтроений.Добавить(Новый Структура("type, number", "Корпус", Комп.Корпус));
	КонецЕсли;
	АдресJSON.Вставить("buildings", МассивСтроений);

	МассивПомещений = Новый Массив;
	Если ЗначениеЗаполнено(Комп.Квартира) Тогда
		МассивПомещений.Добавить(Новый Структура("type, number", "Квартира", Комп.Квартира));
	КонецЕсли;
	Если ЗначениеЗаполнено(Комп.Офис) Тогда
		МассивПомещений.Добавить(Новый Структура("type, number", "Офис", Комп.Офис));
	КонецЕсли;
	АдресJSON.Вставить("apartments", МассивПомещений);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, АдресJSON);
	СтрокаJSON = ЗаписьJSON.Закрыть();

	// Записуємо напряму в ТЧ об'єкта — BSP не перезапише
	Стр = Объект.КонтактнаяИнформация.Добавить();
	Стр.Тип           = Перечисления.ТипыКонтактнойИнформации.Адрес;
	Стр.Вид           = ВидКИ;
	Стр.ВидДляСписка  = ВидКИ;
	Стр.Представление = Комп.Представление;
	Стр.Значение      = СтрокаJSON;
	Стр.ЗначенияПолей = СтрокаJSON;
	Стр.Страна        = "Україна";
	Стр.Регион        = Комп.Область;
	Стр.Город         = ?(ЗначениеЗаполнено(Комп.Город),
		Комп.ТипГорода + " " + Комп.Город, "");

КонецПроцедуры


&НаСервереБезКонтекста
Процедура ДобавитьКИ(Объект, ВидКИ, ТипКИ, Представление)

	Если НЕ ЗначениеЗаполнено(Представление) Тогда
		Возврат;
	КонецЕсли;

	Стр = Объект.КонтактнаяИнформация.Добавить();
	Стр.Тип           = ТипКИ;
	Стр.Вид           = ВидКИ;
	Стр.Представление = Представление;

	Попытка
		Стр.Значение = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(
			Представление, ВидКИ);
		Стр.ЗначенияПолей = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияВXML(
			Стр.Значение, Представление, ВидКИ);
	Исключение
	КонецПопытки;

	Если ТипКИ = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
		Стр.АдресЭП = Представление;
		Поз = СтрНайти(Представление, "@");
		Если Поз > 0 Тогда
			Стр.ДоменноеИмяСервера = Сред(Представление, Поз + 1);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция СоздатьКонтактноеЛицо(ПартнерСсылка, ИмяКонтакта, ТелефонКонтакта, EmailКонтакта)

	ИмяДляНаименования = ?(ЗначениеЗаполнено(ИмяКонтакта), ИмяКонтакта,
		?(ЗначениеЗаполнено(EmailКонтакта), EmailКонтакта, ТелефонКонтакта));

	Если НЕ ЗначениеЗаполнено(ИмяДляНаименования) Тогда
		Возврат Ложь;
	КонецЕсли;

	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.КонтактныеЛицаПартнеров
		|ГДЕ Владелец = &Владелец И Наименование = &Имя И НЕ ПометкаУдаления");
	Запрос.УстановитьПараметр("Владелец", ПартнерСсылка);
	Запрос.УстановитьПараметр("Имя", Лев(ИмяДляНаименования, 100));
	Выборка = Запрос.Выполнить().Выбрать();

	Если Выборка.Следующий() Тогда
		ОбъектКЛ = Выборка.Ссылка.ПолучитьОбъект();
		НовыйЗапис = Ложь;
	Иначе
		ОбъектКЛ = Справочники.КонтактныеЛицаПартнеров.СоздатьЭлемент();
		ОбъектКЛ.Владелец             = ПартнерСсылка;
		ОбъектКЛ.Наименование         = Лев(ИмяДляНаименования, 100);
		ОбъектКЛ.ДатаРегистрацииСвязи = ТекущаяДатаСеанса();
		ОбъектКЛ.Автор                = Пользователи.ТекущийПользователь();
		НовыйЗапис = Истина;
	КонецЕсли;

	ДобавитьКИКонтактногоЛица(ОбъектКЛ,
		Справочники.ВидыКонтактнойИнформации.ТелефонКонтактногоЛица,
		Перечисления.ТипыКонтактнойИнформации.Телефон, ТелефонКонтакта);
	ДобавитьКИКонтактногоЛица(ОбъектКЛ,
		Справочники.ВидыКонтактнойИнформации.EmailКонтактногоЛица,
		Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты, EmailКонтакта);

	ОбъектКЛ.Записать();
	Возврат НовыйЗапис;

КонецФункции

&НаСервереБезКонтекста
Процедура ДобавитьКИКонтактногоЛица(ОбъектКЛ, ВидКИ, ТипКИ, Представление)

	Если НЕ ЗначениеЗаполнено(Представление) Тогда
		Возврат;
	КонецЕсли;

	Для Каждого Стр Из ОбъектКЛ.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид", ВидКИ)) Цикл
		ОбъектКЛ.КонтактнаяИнформация.Удалить(Стр);
	КонецЦикла;

	ДобавитьКИ(ОбъектКЛ, ВидКИ, ТипКИ, Представление);

КонецПроцедуры

// === Розбір банківських реквізитів ===

&НаСервереБезКонтекста
Функция РазобратьИСоздатьБанковскийСчет(КонтрагентСсылка, БанковскиеРеквизиты)

	Парсинг = РазобратьБанковскиеРеквизиты(БанковскиеРеквизиты);

	Если НЕ ЗначениеЗаполнено(Парсинг.НомерСчета)
		И НЕ ЗначениеЗаполнено(Парсинг.КодБанка) Тогда
		Возврат Ложь;
	КонецЕсли;

	БС = Справочники.БанковскиеСчетаКонтрагентов.СоздатьЭлемент();
	БС.Владелец = КонтрагентСсылка;
	БС.ВалютаДенежныхСредств = Константы.ВалютаРегламентированногоУчета.Получить();

	Если ЗначениеЗаполнено(Парсинг.НомерСчета) Тогда
		БС.НомерСчета = Парсинг.НомерСчета;
	КонецЕсли;

	Если ЗначениеЗаполнено(Парсинг.КодБанка) Тогда
		Банк = НайтиБанкПоКоду(Парсинг.КодБанка);
		Если ЗначениеЗаполнено(Банк) Тогда
			БС.Банк = Банк;
		Иначе
			БС.РучноеИзменениеРеквизитовБанка = Истина;
			БС.КодБанка = Парсинг.КодБанка;
		КонецЕсли;
	КонецЕсли;

	Если ЗначениеЗаполнено(Парсинг.НаименованиеБанка) И НЕ ЗначениеЗаполнено(БС.Банк) Тогда
		БС.РучноеИзменениеРеквизитовБанка = Истина;
		БС.НаименованиеБанка = Лев(Парсинг.НаименованиеБанка, 150);
	КонецЕсли;

	Если ЗначениеЗаполнено(Парсинг.НомерСчета) Тогда
		БС.Наименование = Лев(Парсинг.НомерСчета, 150);
	Иначе
		БС.Наименование = Лев(БанковскиеРеквизиты, 150);
	КонецЕсли;

	БС.Комментарий = БанковскиеРеквизиты;

	Попытка
		БС.Записать();
		Возврат Истина;
	Исключение
		Сообщить(НСтр("ru='Не удалось сохранить банковский счёт: ';uk='Не вдалося зберегти банківський рахунок: '")
			+ ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;

КонецФункции

&НаСервереБезКонтекста
Функция РазобратьБанковскиеРеквизиты(Текст)

	Результат = Новый Структура("НомерСчета, КодБанка, НаименованиеБанка", "", "", "");

	ИндексUA = СтрНайти(ВРег(Текст), "UA");
	Пока ИндексUA > 0 Цикл
		Кандидат = Сред(Текст, ИндексUA, 29);
		Если СтрДлина(Кандидат) = 29 И ВРег(Лев(Кандидат, 2)) = "UA" И ЭтоТолькоЦифры(Сред(Кандидат, 3)) Тогда
			Результат.НомерСчета = ВРег(Кандидат);
			Прервать;
		КонецЕсли;
		ИндексUA = СтрНайти(ВРег(Текст), "UA", НаправлениеПоиска.СНачала, ИндексUA + 1);
	КонецЦикла;

	Если НЕ ЗначениеЗаполнено(Результат.НомерСчета) Тогда
		БлокЦифр = НайтиСамуюДлиннуюПоследовательностьЦифр(Текст);
		Если СтрДлина(БлокЦифр) >= 10 И СтрДлина(БлокЦифр) <= 34 Тогда
			Результат.НомерСчета = БлокЦифр;
		КонецЕсли;
	КонецЕсли;

	Поз = 1;
	Пока Поз <= СтрДлина(Текст) - 5 Цикл
		Кандидат = Сред(Текст, Поз, 6);
		Если ЭтоТолькоЦифры(Кандидат) Тогда
			ПередСимв = ?(Поз > 1, Сред(Текст, Поз - 1, 1), "");
			ПослеСимв = ?(Поз + 6 <= СтрДлина(Текст), Сред(Текст, Поз + 6, 1), "");
			Если НЕ ЭтоТолькоЦифры(ПередСимв) И НЕ ЭтоТолькоЦифры(ПослеСимв) Тогда
				Если СтрНайти(Результат.НомерСчета, Кандидат) = 0 Тогда
					Результат.КодБанка = Кандидат;
					Прервать;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		Поз = Поз + 1;
	КонецЦикла;

	ИндексЛап = СтрНайти(Текст, """");
	Если ИндексЛап > 0 Тогда
		Кінець = СтрНайти(Текст, """", НаправлениеПоиска.СНачала, ИндексЛап + 1);
		Если Кінець > ИндексЛап Тогда
			Результат.НаименованиеБанка = Сред(Текст, ИндексЛап + 1, Кінець - ИндексЛап - 1);
		КонецЕсли;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Результат.НаименованиеБанка) Тогда
		Для Каждого Ключ Из СтрРазделить("ПРИВАТБАНК,ОЩАДБАНК,УКРГАЗБАНК,РАЙФФАЙЗЕН,УКРСИББАНК,ПУМБ,КРЕДОБАНК,АЛЬФА-БАНК,ОТП", ",") Цикл
			Если СтрНайти(ВРег(Текст), Ключ) > 0 Тогда
				Результат.НаименованиеБанка = Ключ;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Возврат Результат;

КонецФункции

&НаСервереБезКонтекста
Функция ЭтоТолькоЦифры(Знач Строка)
	Если ПустаяСтрока(Строка) Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Поз = 1 По СтрДлина(Строка) Цикл
		Если СтрНайти("0123456789", Сред(Строка, Поз, 1)) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

&НаСервереБезКонтекста
Функция НайтиСамуюДлиннуюПоследовательностьЦифр(Текст)
	Лучшая = "";
	Текущая = "";
	Для Поз = 1 По СтрДлина(Текст) Цикл
		Если СтрНайти("0123456789", Сред(Текст, Поз, 1)) > 0 Тогда
			Текущая = Текущая + Сред(Текст, Поз, 1);
		Иначе
			Если СтрДлина(Текущая) > СтрДлина(Лучшая) Тогда
				Лучшая = Текущая;
			КонецЕсли;
			Текущая = "";
		КонецЕсли;
	КонецЦикла;
	Если СтрДлина(Текущая) > СтрДлина(Лучшая) Тогда
		Лучшая = Текущая;
	КонецЕсли;
	Возврат Лучшая;
КонецФункции

&НаСервереБезКонтекста
Функция НайтиБанкПоКоду(КодМФО)
	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.КлассификаторБанков
		|ГДЕ Код = &Код И НЕ ПометкаУдаления");
	Запрос.УстановитьПараметр("Код", КодМФО);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	Возврат Справочники.КлассификаторБанков.ПустаяСсылка();
КонецФункции
