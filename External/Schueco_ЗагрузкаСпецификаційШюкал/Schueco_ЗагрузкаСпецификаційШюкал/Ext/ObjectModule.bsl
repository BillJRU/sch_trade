
#Область ПрограммныйИнтерфейс

// Возвращает сведения о внешней обработке для подсистемы БСП
// "Дополнительные отчеты и обработки".
//
Функция СведенияОВнешнейОбработке() Экспорт

	ПараметрыРегистрации = ДополнительныеОтчетыИОбработки.СведенияОВнешнейОбработке("2.3.1.73");
	ПараметрыРегистрации.Вид     = ДополнительныеОтчетыИОбработкиКлиентСервер.ВидОбработкиЗаполнениеОбъекта();
	ПараметрыРегистрации.Версия  = "1.8.3";
	ПараметрыРегистрации.Назначение.Добавить("Документ.КоммерческоеПредложениеКлиенту");
	ПараметрыРегистрации.Информация = НСтр("ru='Импорт строк спецификации Schücal в форму Коммерческого предложения клиенту';uk='Імпорт рядків специфікації Schücal у форму Комерційної пропозиції клієнту'");

	ПараметрыРегистрации.Разрешения.Добавить(
		РаботаВБезопасномРежиме.РазрешениеНаИспользованиеКаталогаВременныхФайлов(
			Истина, Истина,
			НСтр("uk='Запис тимчасового XLSX для читання табличним документом'")));

	// Регистрируем единственную команду — пункт "Завантажити специфікацію Schücal"
	// в "Заповнити" формы КП. Форма настроек открывается из самой формы загрузки
	// кнопкой "Налаштування" — отдельной командой её не публикуем, чтобы не
	// засорять меню КП.
	НоваяКоманда = ПараметрыРегистрации.Команды.Добавить();
	НоваяКоманда.Представление        = НСтр("ru='Загрузить спецификацию Schücal';uk='Завантажити специфікацію Schücal'");
	НоваяКоманда.Идентификатор        = "Schueco_ЗагрузитьСпецификациюSchucal";
	НоваяКоманда.Использование        = ДополнительныеОтчетыИОбработкиКлиентСервер.ТипКомандыОткрытиеФормы();
	НоваяКоманда.ПоказыватьОповещение = Ложь;

	Возврат ПараметрыРегистрации;

КонецФункции

#КонецОбласти
