
// Форма настроек загрузки спецификации Schücal.
// Открывается отдельной командой "НастройкиЗагрузки" типа ОткрытиеФормы — её
// диспетчеризует основная форма обработки в обработчике ПриОткрытии (см. Модуль формы Форма).
//
// Настройки хранятся в реквизите Catalog.ДополнительныеОтчетыИОбработки.ХранилищеНастроек
// в виде Структуры. Это документировано БСП 3.1.10:
// "Пример: сохраняемые параметры дополнительной обработки".
//
// Контракт:
//  - Параметр формы "ДополнительнаяОбработкаСсылка" — ссылка на элемент справочника
//    Дополнительные отчёты и обработки. Передаётся диспетчером БСП в команды этой обработки.
//  - При создании формы загружаем настройки из ХранилищеНастроек (если уже сохранены).
//  - По кнопке "OK" пакуем текущие значения в Структуру и записываем
//    в ХранилищеНастроек, затем закрываем форму.

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Свойство("ДополнительнаяОбработкаСсылка") Тогда
		ОбработкаСсылка = Параметры.ДополнительнаяОбработкаСсылка;
	КонецЕсли;

	// Значения по умолчанию для диапазона строк — соответствуют формату Schücal-экспорта.
	НомерСтрокиЗаголовка    = 10;
	НомерПервойСтрокиДанных = 11;
	НомерПоследнейСтроки    = 0;
	РежимДодавання          = Ложь;

	ЗагрузитьСохранённыеНастройки();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Сохранить(Команда)

	Если НЕ ЗначениеЗаполнено(ОбработкаСсылка) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Форма настроек открыта вне контекста дополнительной обработки. "
				+ "Откройте её через ""НДІ та адміністрування → Дод. обробки → Виконати команду"".';"
			+ "uk='Форма налаштувань відкрита поза контекстом додаткової обробки. "
				+ "Відкрийте її через ""НДІ та адміністрування → Дод. обробки → Виконати команду"".'"));
		Возврат;
	КонецЕсли;

	Записано = СохранитьНастройкиВХранилище();
	Если НЕ Записано Тогда
		Возврат;
	КонецЕсли;

	Закрыть();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗагрузитьСохранённыеНастройки()

	Если НЕ ЗначениеЗаполнено(ОбработкаСсылка) Тогда
		Возврат;
	КонецЕсли;

	Хранилище = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбработкаСсылка, "ХранилищеНастроек");
	Если Хранилище = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Настройки = Хранилище.Получить();
	Если ТипЗнч(Настройки) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;

	// Имена полей идентичны атрибутам формы — ЗаполнитьЗначенияСвойств их разнесёт.
	// Без списка имён: копируются только пересекающиеся ключи. Это защищает от
	// старых снапшотов настроек, в которых ещё нет новых ключей (например
	// ДопРекв_БазоваяНоменклатура, добавленный в v1.1.0).
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Настройки);

КонецПроцедуры

&НаСервере
Функция СохранитьНастройкиВХранилище()

	Настройки = Новый Структура;
	Настройки.Вставить("ЕИ_Sta",                       ЕИ_Sta);
	Настройки.Вставить("ЕИ_шт",                        ЕИ_шт);
	Настройки.Вставить("ДопРекв_Покраска",             ДопРекв_Покраска);
	Настройки.Вставить("ХарактеристикаБезПокраски",    ХарактеристикаБезПокраски);
	Настройки.Вставить("ДопРекв_БазоваяНоменклатура",  ДопРекв_БазоваяНоменклатура);
	Настройки.Вставить("РежимДодавання",               РежимДодавання);
	Настройки.Вставить("НомерСтрокиЗаголовка",         НомерСтрокиЗаголовка);
	Настройки.Вставить("НомерПервойСтрокиДанных",      НомерПервойСтрокиДанных);
	Настройки.Вставить("НомерПоследнейСтроки",         НомерПоследнейСтроки);

	Попытка
		ОбъектОбработки = ОбработкаСсылка.ПолучитьОбъект();
		ОбъектОбработки.ХранилищеНастроек = Новый ХранилищеЗначения(Настройки);
		ОбъектОбработки.Записать();
	Исключение
		Сообщить(СтрШаблон(
			НСтр("ru='Не удалось сохранить настройки в справочник ""Дополнительные обработки"": %1';"
				+ "uk='Не вдалося зберегти налаштування у довідник ""Додаткові обробки"": %1'"),
			ОписаниеОшибки()));
		Возврат Ложь;
	КонецПопытки;

	Возврат Истина;

КонецФункции

#КонецОбласти
