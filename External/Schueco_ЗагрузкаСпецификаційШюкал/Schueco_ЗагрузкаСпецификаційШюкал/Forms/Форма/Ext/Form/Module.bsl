
&НаКлиенте
Перем КПФорма;

// Async-state для интерактивного создания рецептов наборов (v1.2.0).
// ОжидающиеСекцииКлиент — массив структур секций, по которым нужно открыть форму
// варианта комплектации (kit-секции из Isomat, у которых kit-Номенклатура есть в каталоге,
// но рецепт ВариантКомплектации отсутствует). Заполняется в ЗаполнитьТЧТоварыКП и
// перебирается асинхронной цепочкой ОбработатьСледующуюСекцию → ПослеОтветаОСоздании →
// ПослеЗакрытияВарианта. ИндексТекущейСекции — позиция в этом массиве.
// ЗакрытьПослеЦепочки — флаг, выставляемый ЗагрузитьИЗакрыть, чтобы форма закрылась
// только когда вся async-цепочка отработает (а не сразу после ВыполнитьИмпорт).
&НаКлиенте
Перем ОжидающиеСекцииКлиент;
&НаКлиенте
Перем ИндексТекущейСекции;
&НаКлиенте
Перем ЗакрытьПослеЦепочки;
// Накопитель сообщений, которые надо вывести в окно КП (а не spec-loader формы).
// Ключ-данных сам по себе не переносит сообщения между уже открытыми окнами:
// Сообщить() кладёт текст в активное окно. Поэтому копим всё здесь по ходу
// импорта и одним залпом выводим в конце ВывестиФинальнуюСтатистику, после
// КПФорма.Активизировать() — тогда они попадают именно в окно КП и сохраняются
// после закрытия spec-loader-формы.
&НаКлиенте
Перем НакопленныеСообщенияКлиент;

// Адрес выбранного файла во временном хранилище. Заполняется callback'ом
// ФайловаяСистемаКлиент.ЗагрузитьФайл при выборе файла через стандартный диалог.
// Если адрес заполнен — ВыполнитьИмпорт берёт файл напрямую из хранилища без
// повторного ПоместитьФайлы. Если пусто (user вбил путь руками в поле) —
// fallback на ПоместитьФайлы.
&НаКлиенте
Перем АдресФайлаКлиент;

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	НомерСтрокиЗаголовка = 10;
	НомерПервойСтрокиДанных = 11;
	НомерПоследнейСтроки = 0;
	РежимДодавання = Ложь;
	РасширенноеЛогирование = Ложь;
	СтатусВыполнения = НСтр("uk='Готово до завантаження'");

	// Захватываем ссылку на элемент справочника "Дополнительные обработки" — она нужна,
	// чтобы прочитать сохранённые в ХранилищеНастроек параметры обработки и чтобы
	// потом передать её в ФормаНастроек (по кнопке "Налаштування").
	Если Параметры.Свойство("ДополнительнаяОбработкаСсылка") Тогда
		ОбработкаСсылка = Параметры.ДополнительнаяОбработкаСсылка;
	КонецЕсли;

	// Сначала автонастройки (на случай первого запуска без сохранённого хранилища),
	// затем поверх — сохранённые значения. Хранилище имеет приоритет.
	ЗаполнитьЕдиницыПоУмолчанию();
	ДопРекв_Покраска = НайтиСвойствоПокраска();
	ЗагрузитьСохранённыеНастройки();
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСохранённыеНастройки()
	// Читает Структуру из Catalog.ДополнительныеОтчетыИОбработки.ХранилищеНастроек
	// и переносит её ключи в одноимённые реквизиты формы. Документировано в БСП 3.1.10
	// "Пример: сохраняемые параметры дополнительной обработки".
	Если НЕ ЗначениеЗаполнено(ОбработкаСсылка) Тогда
		Возврат; // Standalone-открытие из Конфигуратора либо БСП ещё не передал ссылку.
	КонецЕсли;
	Хранилище = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбработкаСсылка, "ХранилищеНастроек");
	Если Хранилище = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Настройки = Хранилище.Получить();
	Если ТипЗнч(Настройки) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	// Без списка имён: копируются только те ключи, которые есть и в Источнике, и в Приёмнике.
	// Это защищает от старых снапшотов настроек, в которых ещё нет новых ключей
	// (например ДопРекв_БазоваяНоменклатура, добавленный в v1.1.0).
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Настройки);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЕдиницыПоУмолчанию()
	// Базовая упаковка ШТ для типичного маппинга "шт." → шт.
	// Sta (штанги) намеренно не предзаполняем: связь штанги↔метр зависит от номенклатуры,
	// пользователь подберёт корректную упаковку.
	Если ЗначениеЗаполнено(ЕИ_шт) Тогда
		Возврат;
	КонецЕсли;
	Запрос = Новый Запрос(
		"ВЫБРАТЬ Ссылка, Наименование
		|ИЗ Справочник.УпаковкиЕдиницыИзмерения
		|ГДЕ Владелец = &Владелец");
	Запрос.УстановитьПараметр("Владелец", Справочники.НаборыУпаковок.БазовыеЕдиницыИзмерения);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Имя = ВРег(СокрЛП(Выборка.Наименование));
		Если Имя = "ШТ" Или Имя = "ШТ." Тогда
			ЕИ_шт = Выборка.Ссылка;
			Прервать;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервереБезКонтекста
Функция НайтиСвойствоПокраска()
	// Ищем дополнительный реквизит, тип которого включает Покраски_SCT.
	// Если будет несколько кандидатов — пользователь скорректирует на форме.
	Запрос = Новый Запрос(
		"ВЫБРАТЬ Ссылка, ТипЗначения
		|ИЗ ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения
		|ГДЕ НЕ ПометкаУдаления");
	Выборка = Запрос.Выполнить().Выбрать();
	ТипПокраски = Тип("СправочникСсылка.Покраски_SCT");
	Пока Выборка.Следующий() Цикл
		Описание = Выборка.ТипЗначения;
		Если Описание <> Неопределено И Описание.СодержитТип(ТипПокраски) Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	// Обычный сценарий — вызов из КП "Заповнити". Запоминаем форму-владельца (КП-форму).
	Если ВладелецФормы <> Неопределено Тогда
		КПФорма = ВладелецФормы;
		Попытка
			ИнформацияОКП = Строка(КПФорма.Объект.Номер) + " від " + Формат(КПФорма.Объект.Дата, "ДЛФ=D");
		Исключение
			ИнформацияОКП = НСтр("uk='Новий документ'");
		КонецПопытки;
	Иначе
		ИнформацияОКП = НСтр("uk='(не передано)'");
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ПутьКФайлуНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	// Стандартный путь — БСП-хелпер ФайловаяСистемаКлиент.ЗагрузитьФайл:
	// asynchronous, работает и в тонком, и в веб-клиенте, сам подключает
	// расширение работы с файлами в браузере, сам показывает диалог и кладёт
	// выбранный файл во временное хранилище. См. канонический пример в
	// CommonModules/ЗагрузкаДанныхИзФайлаКлиент/Ext/Module.bsl:79-84.
	СтандартнаяОбработка = Ложь;

	ПараметрыЗагрузки = ФайловаяСистемаКлиент.ПараметрыЗагрузкиФайла();
	ПараметрыЗагрузки.Диалог.Фильтр = НСтр("ru='Книга Excel 2007 (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*';"
		+ "uk='Книга Excel 2007 (*.xlsx)|*.xlsx|Усі файли (*.*)|*.*'");
	ПараметрыЗагрузки.Диалог.Заголовок = НСтр("ru='Выберите файл спецификации Schücal';"
		+ "uk='Оберіть файл специфікації Schücal'");
	ПараметрыЗагрузки.ИдентификаторФормы = УникальныйИдентификатор;

	Оповещение = Новый ОписаниеОповещения("ПослеВыбораФайлаЗагрузка", ЭтотОбъект);
	ФайловаяСистемаКлиент.ЗагрузитьФайл(Оповещение, ПараметрыЗагрузки);
КонецПроцедуры

// Callback от ФайловаяСистемаКлиент.ЗагрузитьФайл. Получает ОписаниеФайла со
// свойствами Имя (отображаемый путь, в веб-клиенте без полного пути) и Хранение
// (адрес во временном хранилище — оттуда ВыполнитьИмпорт/ПарситьФайлНаСервере
// заберёт двоичные данные). Если user отменил выбор — приходит Неопределено.
&НаКлиенте
Процедура ПослеВыбораФайлаЗагрузка(ОписаниеФайла, ДополнительныеПараметры) Экспорт
	Если ОписаниеФайла = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ПутьКФайлу        = ОписаниеФайла.Имя;
	АдресФайлаКлиент  = ОписаниеФайла.Хранение;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗагрузитьДанные(Команда)
	ЗакрытьПослеЦепочки = Ложь;
	ВыполнитьИмпорт();
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИЗакрыть(Команда)
	// Закрытие формы выполняет ВывестиФинальнуюСтатистику, когда отработает вся
	// цепочка (синхронно — если секций без рецепта нет; асинхронно — если есть).
	ЗакрытьПослеЦепочки = Истина;
	Если НЕ ВыполнитьИмпорт() Тогда
		// Импорт не запустился (early return: путь не указан, КП недоступна и т. п.).
		// Снимаем флаг — пользователь увидит причину и решит, что делать дальше.
		ЗакрытьПослеЦепочки = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Функция ВыполнитьИмпорт()
	// Возвращает Истина, если импорт фактически выполнился (файл выбран, форма КП доступна,
	// файл прочитан). Возвращает Ложь во всех ранне-выходных ветках — тогда вызывающий
	// "Завантажити та закрити" не закрывает форму, чтобы пользователь увидел причину.

	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
		ПоказатьПредупреждение(, НСтр("uk='Вкажіть шлях до файлу'"));
		Возврат Ложь;
	КонецЕсли;

	Если КПФорма = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("uk='Форма Комерційної пропозиції недоступна. Запустіть з документа.'"));
		Возврат Ложь;
	КонецЕсли;

	// Информируем пользователя о незаполненных параметрах. Импорт всё равно
	// выполняется — отсутствующие маппинги превращаются в fallback на базовую
	// единицу или пустую характеристику с предупреждением по строкам.
	ПредупредитьОНезаполненныхНастройках();

	КоличествоОбработано = 0;
	КоличествоЗагружено = 0;
	КоличествоНеНайдено = 0;
	КоличествоОшибок = 0;
	СтатусВыполнения = НСтр("uk='Завантаження...'");

	// Если файл выбран через стандартный диалог (ПутьКФайлуНачалоВыбора →
	// ФайловаяСистемаКлиент.ЗагрузитьФайл), он уже лежит во временном хранилище —
	// просто берём адрес. Иначе (user вбил путь руками) — fallback ПоместитьФайлы.
	АдресВХранилище = АдресФайлаКлиент;
	Если НЕ ЗначениеЗаполнено(АдресВХранилище) Тогда
		ПомещаемыеФайлы = Новый Массив;
		ОписаниеФайла = Новый ОписаниеПередаваемогоФайла(ПутьКФайлу, "");
		ПомещаемыеФайлы.Добавить(ОписаниеФайла);
		ПомещенныеФайлы = Новый Массив;

		Если НЕ ПоместитьФайлы(ПомещаемыеФайлы, ПомещенныеФайлы, , Ложь, УникальныйИдентификатор) Тогда
			СтатусВыполнения = НСтр("uk='Не вдалося завантажити файл'");
			Возврат Ложь;
		КонецЕсли;

		Если ПомещенныеФайлы.Количество() = 0 Тогда
			СтатусВыполнения = НСтр("uk='Файл не вибрано'");
			Возврат Ложь;
		КонецЕсли;

		АдресВХранилище = ПомещенныеФайлы[0].Хранение;
	КонецЕсли;

	КонтрагентКП = Неопределено;
	Попытка
		КонтрагентКП = КПФорма.Объект.Контрагент;
	Исключение
		// На клиенте чужой формы реквизит может быть недоступен — игнорируем.
	КонецПопытки;

	МаппингЕИ = Новый Соответствие;
	МаппингЕИ.Вставить("STA", ЕИ_Sta);
	МаппингЕИ.Вставить("ШТ.", ЕИ_шт);
	МаппингЕИ.Вставить("ШТ",  ЕИ_шт);

	// Дата і валюта КП — потрібні стандартному УТ-helper'у ПродажиСервер.ЗаполнитьЦены,
	// щоб правильно зробити перерахунок ціни (валюта прайсу → валюта КП) і вибрати
	// зріз останніх на дату КП (а не сьогоднішню).
	ДатаКП    = Неопределено;
	ВалютаКП  = Неопределено;
	Попытка
		ДатаКП   = КПФорма.Объект.Дата;
		ВалютаКП = КПФорма.Объект.Валюта;
	Исключение
		// На клиенте чужой формы реквизиты могут быть недоступны — server-side fallback.
	КонецПопытки;

	// Спакувати контекст для async-цепочки (вибір ВидЦен → парсинг). Всі ці дані
	// потрібні і у синхронній гілці (ВидЦен резолвлено одразу), і у callback'у після
	// модального вибору з Справочник.ВидыЦен.ФормаВыбора.
	КонтекстИмпорта = Новый Структура;
	КонтекстИмпорта.Вставить("АдресВХранилище", АдресВХранилище);
	КонтекстИмпорта.Вставить("КонтрагентКП",    КонтрагентКП);
	КонтекстИмпорта.Вставить("МаппингЕИ",       МаппингЕИ);
	КонтекстИмпорта.Вставить("ДатаКП",          ДатаКП);
	КонтекстИмпорта.Вставить("ВалютаКП",        ВалютаКП);

	// Резолвер ВидЦены прайс-листа — повторюємо логіку picker'а УТ
	// (КоммерческиеПредложенияДокументыКлиентУТ:1218-1283):
	//  • Якщо опція "Кілька видів цін" вимкнена → ЦенообразованиеВызовСервера.ВидЦеныПрайсЛист()
	//    повертає одразу готовий ВидЦен (створить, якщо немає) → парсимо синхронно.
	//  • Якщо опція ввімкнена → повертає Неопределено → відкриваємо модальний вибір.
	ВидЦенПрайс = ПолучитьВидЦенПрайс();
	Если ЗначениеЗаполнено(ВидЦенПрайс) Тогда
		ВыполнитьИмпортПарсинг(КонтекстИмпорта, ВидЦенПрайс);
		Возврат Истина;
	КонецЕсли;

	// Async: модальний вибір Виду цін. Фільтр ИспользоватьПриПродаже — той самий, що в picker'а УТ.
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Отбор", Новый Структура("ИспользоватьПриПродаже", Истина));
	ПараметрыФормы.Вставить("Заголовок", НСтр("uk='Виберіть Вид цін для імпорту специфікації'"));
	Оповещение = Новый ОписаниеОповещения("ПослеВыбораВидаЦен", ЭтотОбъект, КонтекстИмпорта);
	ОткрытьФорму("Справочник.ВидыЦен.ФормаВыбора", ПараметрыФормы, ЭтотОбъект, , , , Оповещение,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

	Возврат Истина;

КонецФункции

// Callback від Справочник.ВидыЦен.ФормаВыбора. Користувач або обрав ВидЦен →
// продовжуємо парсинг, або закрив форму без вибору → скасовуємо імпорт
// (і скидаємо ЗакрытьПослеЦепочки, щоб форма обробки не закривалась).
&НаКлиенте
Процедура ПослеВыбораВидаЦен(Результат, КонтекстИмпорта) Экспорт
	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		СтатусВыполнения = НСтр("uk='Імпорт скасовано — Вид цін не вибрано.'");
		СообщитьВКП(СтатусВыполнения);
		ЗакрытьПослеЦепочки = Ложь;
		Возврат;
	КонецЕсли;
	ВыполнитьИмпортПарсинг(КонтекстИмпорта, Результат);
КонецПроцедуры

// Власне парсинг файла + наповнення ТЧ Товари + прикріплення джерельного xlsx.
// Викликається або синхронно з ВыполнитьИмпорт (якщо ВидЦен резолвлено одразу),
// або з ПослеВыбораВидаЦен (callback модального вибору).
&НаКлиенте
Процедура ВыполнитьИмпортПарсинг(КонтекстИмпорта, ВидЦенПрайс)
	РезультатПарсинга = ПарситьФайлНаСервере(
		КонтекстИмпорта.АдресВХранилище,
		НомерПервойСтрокиДанных,
		НомерПоследнейСтроки,
		КПФорма.Объект.ЦенаВключаетНДС,
		КонтекстИмпорта.МаппингЕИ,
		ДопРекв_Покраска,
		КонтекстИмпорта.КонтрагентКП,
		ХарактеристикаБезПокраски,
		ДопРекв_БазоваяНоменклатура,
		КонтекстИмпорта.ДатаКП,
		ВидЦенПрайс,
		КонтекстИмпорта.ВалютаКП);

	// Промежуточная статистика — отображается сразу. После окончания async-цепочки
	// (если она нужна) ВывестиФинальнуюСтатистику добавит финальный статус.
	КоличествоОбработано = РезультатПарсинга.Статистика.Обработано;
	КоличествоЗагружено  = РезультатПарсинга.Статистика.Загружено;
	КоличествоНеНайдено  = РезультатПарсинга.Статистика.НеНайдено;
	КоличествоОшибок     = РезультатПарсинга.Статистика.Ошибок;
	СтатусВыполнения     = РезультатПарсинга.Статистика.Сообщение;

	// Вывести предупреждения парсера в окно сообщений КП. Кожне повідомлення —
	// Структура("Текст, Подробное"). "Подробное" логи (різні «знайдено N — взято
	// першого», «ціна differs тощо) показуємо лише коли Розширене логування ввімкнено.
	Для Каждого Сообщ Из РезультатПарсинга.Сообщения Цикл
		Если Сообщ.Подробное И НЕ РасширенноеЛогирование Тогда
			Продолжить;
		КонецЕсли;
		СообщитьВКП(Сообщ.Текст);
	КонецЦикла;

	КПФорма.Модифицированность = Истина;

	// Заполнить ТЧ Товары: добавляет прямые строки и при необходимости запускает
	// async-цепочку диалогов «создать рецепт?» по kit-секциям из Isomat без рецепта.
	ЗаполнитьТЧТоварыКП(РезультатПарсинга);

	// Сохранить исходный xlsx в присоединённых файлах КП — архивное подтверждение
	// источника данных. Если КП ещё не записан — пропускаем с предупреждением.
	ИмяФайлаДляВкладения = ИзвлечьИмяФайла(ПутьКФайлу);
	РезультатВкладения = ПрисоединитьФайлКПДокументу(КПФорма.Объект.Ссылка, КонтекстИмпорта.АдресВХранилище, ИмяФайлаДляВкладения);
	СообщитьВКП(РезультатВкладения.Сообщение);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьВидЦенПрайс()
	Возврат ЦенообразованиеВызовСервера.ВидЦеныПрайсЛист();
КонецФункции

// Извлекает имя файла с расширением из полного пути (Windows / Unix-разделители).
// Веб-клиент часто отдаёт уже только имя — этот helper нормализует оба случая.
&НаКлиенте
Функция ИзвлечьИмяФайла(Знач Путь)
	Если ПустаяСтрока(Путь) Тогда
		Возврат "";
	КонецЕсли;
	Поз1 = СтрНайти(Путь, "\", НаправлениеПоиска.СКонца);
	Поз2 = СтрНайти(Путь, "/", НаправлениеПоиска.СКонца);
	Поз  = Макс(Поз1, Поз2);
	Если Поз > 0 Тогда
		Возврат Сред(Путь, Поз + 1);
	Иначе
		Возврат Путь;
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ОткрытьНастройки(Команда)

	Если НЕ ЗначениеЗаполнено(ОбработкаСсылка) Тогда
		ПоказатьПредупреждение(,
			НСтр("ru='Форма открыта вне контекста БСП — ссылка на дополнительную обработку отсутствует, "
					+ "сохранить настройки некуда.';"
				+ "uk='Форма відкрита поза контекстом БСП — посилання на додаткову обробку відсутнє, "
					+ "зберегти налаштування немає куди.'"));
		Возврат;
	КонецЕсли;

	ПараметрыНастроек = Новый Структура;
	ПараметрыНастроек.Вставить("ДополнительнаяОбработкаСсылка", ОбработкаСсылка);

	// Имя формы выводим из ИмяФормы текущей формы — у внешней обработки префикс
	// меняется при подключении (БСП использует runtime-alias), хардкодить нельзя.
	ИмяФормыНастроек = СтрЗаменить(ЭтотОбъект.ИмяФормы, ".Форма.Форма", ".Форма.ФормаНастроек");

	// После закрытия формы настроек перечитываем их из ХранилищеНастроек —
	// чтобы текущая сессия импорта сразу подхватила новые значения.
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияФормыНастроек", ЭтотОбъект);
	ОткрытьФорму(ИмяФормыНастроек, ПараметрыНастроек, , , , , Оповещение);

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияФормыНастроек(Результат, ДополнительныеПараметры) Экспорт
	ПерезагрузитьНастройкиИзХранилищаНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПерезагрузитьНастройкиИзХранилищаНаСервере()
	ЗагрузитьСохранённыеНастройки();
КонецПроцедуры

&НаКлиенте
Процедура ПредупредитьОНезаполненныхНастройках()
	НезаполненныеПоля = Новый Массив;
	Если НЕ ЗначениеЗаполнено(ЕИ_Sta) Тогда
		НезаполненныеПоля.Добавить(НСтр("ru='единица для Sta';uk='одиниця для Sta'"));
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ЕИ_шт) Тогда
		НезаполненныеПоля.Добавить(НСтр("ru='единица для шт.';uk='одиниця для шт.'"));
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ДопРекв_Покраска) Тогда
		НезаполненныеПоля.Добавить(НСтр("ru='реквизит ""Фарбування""';uk='реквізит ""Фарбування""'"));
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ХарактеристикаБезПокраски) Тогда
		НезаполненныеПоля.Добавить(НСтр("ru='характеристика ""Без фарбування""';uk='характеристика ""Без фарбування""'"));
	КонецЕсли;
	Если НезаполненныеПоля.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	СообщитьВКП(СтрШаблон(
		НСтр("ru='Не настроено: %1. Откройте ""Налаштування"" и заполните параметры — иначе в '"
				+ "'результате могут быть пустые характеристики и предупреждения по строкам.';"
			+ "uk='Не налаштовано: %1. Відкрийте ""Налаштування"" та заповніть параметри — інакше в '"
				+ "'результаті можуть бути порожні характеристики та попередження за рядками.'"),
		СтрСоединить(НезаполненныеПоля, ", ")));
КонецПроцедуры


&НаКлиенте
Процедура ЗаполнитьТЧТоварыКП(РезультатПарсинга)

	Если НЕ РежимДодавання Тогда
		КПФорма.Объект.Товары.Очистить();
	КонецЕсли;

	// Прямые строки (обычные товары + строки kit'ов с уже существующим рецептом)
	ДобавитьСтрокиВКП(РезультатПарсинга.Строки);

	// Kit-секции, у которых kit-Номенклатура есть в каталоге, но рецепта нет —
	// проводим интерактивную цепочку «создать рецепт?» по каждой.
	ОжидающиеСекцииКлиент = РезультатПарсинга.СекцииДляСозданияРецепта;
	ИндексТекущейСекции   = -1;

	Если ОжидающиеСекцииКлиент = Неопределено
		ИЛИ ОжидающиеСекцииКлиент.Количество() = 0 Тогда
		ВывестиФинальнуюСтатистику();
		Возврат;
	КонецЕсли;

	ОбработатьСледующуюСекцию();

КонецПроцедуры

// Накапливает сообщение в массив для последующего вывода в окно КП.
// Сразу не выводим: Сообщить() пишет в активное окно, а активное при работе
// spec-loader — её собственное; такие сообщения исчезли бы при закрытии формы.
// В конце ВывестиФинальнуюСтатистику делаем КПФорма.Активизировать() и уже тогда
// разворачиваем накопленное — попадает в нижнюю панель КП и остаётся там.
&НаКлиенте
Процедура СообщитьВКП(Текст)
	Если НакопленныеСообщенияКлиент = Неопределено Тогда
		НакопленныеСообщенияКлиент = Новый Массив;
	КонецЕсли;
	НакопленныеСообщенияКлиент.Добавить(Текст);
КонецПроцедуры

// Добавляет массив структур (СтрокаДанных) в КП.Товары через ЗаполнитьЗначенияСвойств.
// Выделено в helper для повторного использования из синхронного добавления (прямые
// строки) и из callback'а после сохранения варианта (строки секции).
&НаКлиенте
Процедура ДобавитьСтрокиВКП(Строки)
	Если Строки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Для Каждого СтрокаДанных Из Строки Цикл
		НоваяСтрока = КПФорма.Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДанных);
		// Индикатор-картинка в колонке "Картинка" формы КП — это поле ПолеКартинки
		// с КартинкаЗначений = БиблиотекаКартинок.Наборы, привязанное к Товары.ИндексНабора.
		// Стандартный УТ ставит 1/0 по факту НоменклатураНабора при подборе и при загрузках
		// (КоммерческиеПредложенияДокументыУТ:1782, 2443) — повторяем тот же паттерн.
		НоваяСтрока.ИндексНабора = ?(ЗначениеЗаполнено(НоваяСтрока.НоменклатураНабора), 1, 0);
	КонецЦикла;
	КПФорма.Модифицированность = Истина;

	// Сигнал «авто-знижки потребують перерахунку» — те саме, що робить
	// ТоварыПриИзмененииНоменклатуры формы КП (Documents/.../ФормаДокумента/
	// Module.bsl:890). Без этого вызова ПередЗаписью КП не показывает стандартный
	// вопрос «Автоматичні знижки не розраховані. Розрахувати?» при проведении.
	СкидкиНаценкиКлиент.СброситьФлагСкидкиРассчитаны(КПФорма);
КонецПроцедуры

// Точка входа state machine для kit-секций без рецепта. Вызывается рекурсивно
// (через callback'и) для каждой секции по очереди. Когда ИндексТекущейСекции
// выходит за границы массива — финальная статистика и опционально закрытие.
&НаКлиенте
Процедура ОбработатьСледующуюСекцию()

	ИндексТекущейСекции = ИндексТекущейСекции + 1;
	Если ОжидающиеСекцииКлиент = Неопределено
		ИЛИ ИндексТекущейСекции >= ОжидающиеСекцииКлиент.Количество() Тогда
		ВывестиФинальнуюСтатистику();
		Возврат;
	КонецЕсли;

	Текущая = ОжидающиеСекцииКлиент[ИндексТекущейСекции];
	Текст = СтрШаблон(
		НСтр("ru='Для набора артикул %1 ""%2"" не задан рецепт (Состав набора). Создать?';"
			+ "uk='Для набору артикул %1 ""%2"" не задано рецепт (Склад набору). Створити?'"),
		Текущая.КитАртикул, Текущая.КитНаименование);

	ПоказатьВопрос(
		Новый ОписаниеОповещения("ПослеОтветаОСоздании", ЭтотОбъект, Текущая),
		Текст,
		РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

// Реакция пользователя на вопрос «создать рецепт?». Нет → сообщение в лог и
// переход к следующей секции. Да → открываем стандартную ФормаЭлемента варианта
// комплектации с пред-заполненной табчастью Товары (через ПолучитьФорму +
// ЗначениеВДанныеФормы + КопироватьДанныеФормы — без записи объекта в каталог).
&НаКлиенте
Процедура ПослеОтветаОСоздании(КодОтвета, Текущая) Экспорт

	Если КодОтвета = КодВозвратаДиалога.Нет Тогда
		СообщитьВКП(СтрШаблон(
			НСтр("ru='Пользователь отказался создавать рецепт для набора артикул %1 ""%2"" — секция пропущена';"
				+ "uk='Користувач відмовився створювати рецепт для набору артикул %1 ""%2"" — секцію пропущено'"),
			Текущая.КитАртикул, Текущая.КитНаименование));
		ОбработатьСледующуюСекцию();
		Возврат;
	КонецЕсли;

	// Получаем (но не открываем) специализированную для kit'ов форму "Состав набора".
	// Она читает Параметры.Отбор.Владелец/Характеристика в ЗаполнитьДанныеФормы (в отличие
	// от ФормаЭлемента, которая ждёт Параметры.Ключ). См. Catalogs/...СоставНабора/Module.bsl:172-180.
	Отбор = Новый Структура;
	Отбор.Вставить("Владелец",       Текущая.КитСсылка);
	Отбор.Вставить("Характеристика", ПредопределенноеЗначение("Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка"));
	ПараметрыФормы = Новый Структура("Отбор", Отбор);
	Форма = ПолучитьФорму(
		"Справочник.ВариантыКомплектацииНоменклатуры.Форма.СоставНабора",
		ПараметрыФормы,
		ЭтаФорма);

	// Сервер создаёт прикладной СправочникОбъект с заполненными Владелец и Товары
	// (без Записать!) и через ЗначениеВДанныеФормы переносит его в ДанныеФормыСтруктура.
	КопияОбъектаФормы = Форма.Объект;
	ЗаполнитьВариантНаСервере(КопияОбъектаФормы, Текущая.КитСсылка, Текущая.КомпонентыПреЗаполнения);
	КопироватьДанныеФормы(КопияОбъектаФормы, Форма.Объект);

	// Сама форма обчислює ПредставлениеОсновногоКомпонента у своїй ЗаполнитьДанныеФормы
	// (СоставНабора:209-210) ОДИН раз на ПриСозданииНаСервере — ще ДО того, як ми
	// поставили НоменклатураОсновногоКомпонента. Тому підпис «Основна комплектуюча: ___»
	// внизу форми лишається порожнім. Перерахуємо вручну — поле є реквізитом форми
	// (Form.xml:768), модуль НоменклатураКлиентСервер доступний з клієнта.
	Если ЗначениеЗаполнено(Форма.Объект.НоменклатураОсновногоКомпонента) Тогда
		Форма.ПредставлениеОсновногоКомпонента = НоменклатураКлиентСервер.ПредставлениеНоменклатуры(
			Форма.Объект.НоменклатураОсновногоКомпонента,
			Форма.Объект.ХарактеристикаОсновногоКомпонента);
	КонецЕсли;

	// Модальное открытие, чтобы блокировать spec-loader на время редактирования
	Форма.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
	// Callback на закрытие: получаем СправочникСсылка при сохранении или
	// Неопределено при отмене (✕). Ничего не записывается, если user не сохранит.
	Форма.ОписаниеОповещенияОЗакрытии = Новый ОписаниеОповещения(
		"ПослеЗакрытияВарианта", ЭтотОбъект,
		Новый Структура("Текущая", Текущая));
	Форма.Открыть();

КонецПроцедуры

// Callback: пользователь закрыл форму варианта комплектации.
// Параметр Результат у формы СоставНабора при «Записать и закрыть» приходит
// Неопределено (форма не выставляет ЗначениеЗакрытия), поэтому надёжный способ
// определить «сохранил ли user» — перепросить БД: КитИмеетРецепт. Мы уверены,
// что до открытия формы рецепта точно НЕ было (pre-pass отфильтровал такие kit'ы
// в СекцииДляСозданияРецепта именно по факту отсутствия), поэтому если сейчас
// рецепт есть — это результат сохранения user'ом в текущей сессии.
&НаКлиенте
Процедура ПослеЗакрытияВарианта(Результат, Контекст) Экспорт

	Если КитИмеетРецепт(Контекст.Текущая.КитСсылка) Тогда
		// Рецепт сохранён — добавляем строки секции в КП
		ДобавитьСтрокиВКП(Контекст.Текущая.СтрокиОжидающие);
	Иначе
		СообщитьВКП(СтрШаблон(
			НСтр("ru='Рецепт для набора артикул %1 ""%2"" не сохранён — секция пропущена';"
				+ "uk='Рецепт для набору артикул %1 ""%2"" не збережений — секцію пропущено'"),
			Контекст.Текущая.КитАртикул, Контекст.Текущая.КитНаименование));
	КонецЕсли;

	ОбработатьСледующуюСекцию();

КонецПроцедуры

// Финальный статус, вывод накопленных сообщений в окно КП и опциональное закрытие
// формы. Вызывается либо сразу из ЗаполнитьТЧТоварыКП (если ожидающих секций нет),
// либо в конце async-цепочки.
&НаКлиенте
Процедура ВывестиФинальнуюСтатистику()

	СтатусВыполнения = НСтр("ru='Завершено';uk='Завершено'");

	// Активируем окно КП и выливаем туда накопленные сообщения. Активизировать()
	// делает форму КП активной синхронно; последующие Сообщить() кладут текст
	// в её панель сообщений и не исчезают при закрытии spec-loader.
	Если НакопленныеСообщенияКлиент <> Неопределено
		И НакопленныеСообщенияКлиент.Количество() > 0
		И КПФорма <> Неопределено Тогда

		Попытка
			КПФорма.Активизировать();
		Исключение
			// Если КП-форма закрыта — fallback на стандартный Сообщить() в активное окно.
		КонецПопытки;

		Для Каждого Сообщ Из НакопленныеСообщенияКлиент Цикл
			СооблПольз = Новый СообщениеПользователю;
			СооблПольз.Текст = Сообщ;
			Если ЗначениеЗаполнено(КПФорма.Объект.Ссылка) Тогда
				СооблПольз.КлючДанных = КПФорма.Объект.Ссылка;
			КонецЕсли;
			СооблПольз.Сообщить();
		КонецЦикла;

		НакопленныеСообщенияКлиент.Очистить();
	КонецЕсли;

	Если ЗакрытьПослеЦепочки = Истина Тогда
		ЗакрытьПослеЦепочки = Ложь;
		Закрыть();
	КонецЕсли;

КонецПроцедуры

// Серверная процедура: дописывает строки Товары и «Основную комплектующую» в уже
// инициализированную форм-структуру СоставНабора. Шапка (Владелец, ВариантРасчета-
// ЦеныНабора, ВариантПредставленияНабораВПечатныхФормах) уже заполнена самой формой
// в её ЗаполнитьДанныеФормы (Catalogs/.../СоставНабора:172-194 — берёт значения из
// Номенклатура.ВидНоменклатуры) — НЕ перезаписываем. Раньше использовался
// СоздатьЭлемент() + ЗначениеВДанныеФормы, но он затирал шапку дефолтами пустого
// прикладного объекта.
//
// Объект пишется в БД только если пользователь нажмёт «Записать и закрыть» — мы
// здесь ничего не записываем; работаем строго с памятью формы.
&НаСервереБезКонтекста
Процедура ЗаполнитьВариантНаСервере(ДанныеФормыОбъект, КитСсылка, КомпонентыМассив)

	// Добавляем строки Товары прямо в форм-коллекцию — без промежуточного
	// прикладного объекта, чтобы не задеть шапку.
	Для Каждого Комп Из КомпонентыМассив Цикл
		Стр = ДанныеФормыОбъект.Товары.Добавить();
		Стр.Номенклатура       = Комп.Номенклатура;
		Стр.Характеристика     = Комп.Характеристика;
		Стр.Количество         = Комп.Количество;
		Стр.КоличествоУпаковок = Комп.Количество;
		Стр.ДоляСтоимости      = 1;
	КонецЦикла;

	// Основная комплектующая = первый компонент (разумный default; пользователь
	// сможет сменить через кнопку «Основна комплектуюча» в форме перед сохранением).
	// ЗаполнитьДанныеФормы её не ставит, поэтому без нас она останется пустой.
	Если КомпонентыМассив.Количество() > 0 Тогда
		ДанныеФормыОбъект.НоменклатураОсновногоКомпонента   = КомпонентыМассив[0].Номенклатура;
		ДанныеФормыОбъект.ХарактеристикаОсновногоКомпонента = КомпонентыМассив[0].Характеристика;
	КонецЕсли;

	// Прапорець ХарактеристикиИспользуются — реквізит формы, не прикладного объекта.
	// Хелпер БСП ставит Истина только когда Номенклатура.ИспользованиеХарактеристик ∈
	// {ОбщиеДляВидаНоменклатуры, ОбщиеСДругимВидомНоменклатуры, ИндивидуальныеДляНоменклатуры}.
	// Для НеИспользовать прапорець лишається Ложь — і форма коректно показує
	// «<характеристики не використовуються>».
	НоменклатураСервер.ЗаполнитьПризнакИспользованияХарактеристик(ДанныеФормыОбъект.Товары);

КонецПроцедуры

// Додає повідомлення в Результат.Сообщения. Кожне повідомлення — Структура з
// Текстом і прапорцем "Подробное". Подробное-повідомлення (типу «знайдено N —
// обрано першу», «ціна differs») показуються лише коли користувач увімкнув
// «Розширене логування»; решта (Не знайдено, Помилки, ессенційні попередження
// налаштувань) — завжди. Default Подробное = Ложь.
&НаСервереБезКонтекста
Процедура ДобавитьСообщение(Результат, Текст, Подробное = Ложь)
	Результат.Сообщения.Добавить(Новый Структура("Текст, Подробное", Текст, Подробное));
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПарситьФайлНаСервере(АдресВХранилище, НомерПервойСтрокиДанных, НомерПоследнейСтроки, ЦенаВключаетНДС,
	МаппингЕИ, СвойствоПокраска, КонтрагентКП, ХарактеристикаБезПокраски, СвойствоБазоваяНоменклатура, ДатаКП, ВидЦенПрайс, ВалютаКП)

	Результат = Новый Структура;
	Результат.Вставить("Строки", Новый Массив);
	Результат.Вставить("СекцииДляСозданияРецепта", Новый Массив);
	Результат.Вставить("Сообщения", Новый Массив);
	Результат.Вставить("Статистика", Новый Структура("Обработано, Загружено, НеНайдено, Ошибок, Сообщение", 0, 0, 0, 0, ""));
	НеизвестныеЕИ = Новый Соответствие;
	// Промежуточная карта секций без рецепта: ключ КлючСвязи → структура секции
	// (КомпонентыПреЗаполнения и СтрокиОжидающие накапливаются по ходу main-pass).
	// В конце парсинга конвертируется в Массив (Результат.СекцииДляСозданияРецепта).
	СекцииСоответствие = Новый Соответствие;

	// Получить файл из временного хранилища во временный файл на сервере
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресВХранилище);
	ИмяВремФайла = ПолучитьИмяВременногоФайла("xlsx");
	ДвоичныеДанные.Записать(ИмяВремФайла);

	Попытка
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ИмяВремФайла);
	Исключение
		Результат.Статистика.Сообщение = НСтр("uk='Помилка читання файлу: '") + ОписаниеОшибки();
		УдалитьФайлы(ИмяВремФайла);
		Возврат Результат;
	КонецПопытки;

	// Pre-pass по листу Isomat (если он есть в книге) — собираем карту "(артикул, цвет) → Набор"
	// и набор kit-секций без рецепта. Если листа нет — обе коллекции пустые, main-pass работает
	// как раньше: ноль регрессий для одно-листовых спек без скаток.
	ИтогIsomat = СобратьКартуIsomat(ИмяВремФайла, СвойствоБазоваяНоменклатура, Результат);
	КартаIsomat      = ИтогIsomat.Карта;
	СекцииБезРецепта = ИтогIsomat.СекцииБезРецепта;
	// Подготовить накопители для каждой kit-секции без рецепта (заполняются в main-pass)
	Для Каждого ЭлСекц Из СекцииБезРецепта Цикл
		Секция = Новый Структура;
		Секция.Вставить("КитСсылка",              ЭлСекц.Значение.КитСсылка);
		Секция.Вставить("КитАртикул",             ЭлСекц.Значение.КитАртикул);
		Секция.Вставить("КитНаименование",        ЭлСекц.Значение.КитНаименование);
		Секция.Вставить("КлючСвязи",              ЭлСекц.Значение.КлючСвязи);
		Секция.Вставить("КитSumQty",              ЭлСекц.Значение.КитSumQty);
		Секция.Вставить("КомпонентыПреЗаполнения", Новый Массив);
		Секция.Вставить("СтрокиОжидающие",        Новый Массив);
		СекцииСоответствие.Вставить(ЭлСекц.Ключ, Секция);
	КонецЦикла;

	Попытка
		УдалитьФайлы(ИмяВремФайла);
	Исключение
		// Не критично
	КонецПопытки;

	ПерваяСтрока = ?(НомерПервойСтрокиДанных > 0, НомерПервойСтрокиДанных, 11);
	ПоследняяСтрока = ?(НомерПоследнейСтроки > 0, НомерПоследнейСтроки, ТабДок.ВысотаТаблицы);

	// Собрать массив артикулов для batch-запроса. Нормализуем через ИзвлечьОсновнойАртикул,
	// чтобы поймать форматы "277049\n  (277048)" — иначе ЭтоВалидныйАртикул отсеет их и
	// артикул не попадёт в кеш, а в main-pass появится «Не знайдено артикул».
	МассивАртикулов = Новый Массив;
	Для НомерСтроки = ПерваяСтрока По ПоследняяСтрока Цикл
		МатериалНо = ИзвлечьОсновнойАртикул(СокрЛП(ТабДок.Область(НомерСтроки, 1).Текст));
		Если ЗначениеЗаполнено(МатериалНо) И ЭтоВалидныйАртикул(МатериалНо) Тогда
			МассивАртикулов.Добавить(МатериалНо);
		КонецЕсли;
	КонецЦикла;

	Если МассивАртикулов.Количество() = 0 Тогда
		Результат.Статистика.Сообщение = НСтр("uk='У файлі не знайдено валідних артикулів'");
		Возврат Результат;
	КонецЕсли;

	// Batch-запрос Номенклатура по артикулам.
	// Признак использования характеристик берём из Номенклатура.ИспользованиеХарактеристик —
	// это канонический источник, на который ссылается БСП (ОбщегоНазначения.ЗначенияРеквизитовОбъекта)
	// и к нему привязано отображение колонки Характеристика в КП.
	НеИспХар = Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать;
	КэшНоменклатуры = Новый Соответствие;
	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Ссылка, Артикул, ЕдиницаИзмерения, ВидНоменклатуры, НаборУпаковок,
		|	СтавкаНДС                                КАК СтавкаНДС,
		|	СтавкаНДС.Ставка                         КАК ПроцентНДС,
		|	ИспользованиеХарактеристик               КАК ВариантХар,
		|	ВидНоменклатуры.ВладелецХарактеристик    КАК ВладелецХар
		|ИЗ
		|	Справочник.Номенклатура
		|ГДЕ
		|	Артикул В (&МассивАртикулов)");
	Запрос.УстановитьПараметр("МассивАртикулов", МассивАртикулов);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДанныеНоменклатуры = Новый Структура("Ссылка, ВидНоменклатуры, ЕдиницаИзмерения, НаборУпаковок, СтавкаНДС, ПроцентНДС, ИспХар, ВариантХар, ВладелецХар");
		ДанныеНоменклатуры.Ссылка           = Выборка.Ссылка;
		ДанныеНоменклатуры.ВидНоменклатуры  = Выборка.ВидНоменклатуры;
		ДанныеНоменклатуры.ЕдиницаИзмерения = Выборка.ЕдиницаИзмерения;
		ДанныеНоменклатуры.НаборУпаковок    = Выборка.НаборУпаковок;
		ДанныеНоменклатуры.СтавкаНДС        = Выборка.СтавкаНДС;
		ДанныеНоменклатуры.ПроцентНДС       = ?(Выборка.ПроцентНДС = NULL, 0, Выборка.ПроцентНДС);
		ДанныеНоменклатуры.ВариантХар       = Выборка.ВариантХар;
		ДанныеНоменклатуры.ВладелецХар      = Выборка.ВладелецХар;
		ДанныеНоменклатуры.ИспХар           = (Выборка.ВариантХар <> НеИспХар);
		КэшНоменклатуры.Вставить(СокрЛП(Выборка.Артикул), ДанныеНоменклатуры);
	КонецЦикла;

	// ВидЦенПрайс приходить від клієнта (резолвиться через УТ-picker логіку — або
	// ЦенообразованиеВызовСервера.ВидЦеныПрайсЛист, або модальний вибір
	// Справочник.ВидыЦен.ФормаВыбора). Підстановка цін відбувається ПІСЛЯ головного
	// циклу через стандартний УТ-helper ПродажиСервер.ЗаполнитьЦены — той самий, що
	// використовує picker КП "Заповнити → Підібрати товари" (КоммерческиеПредложения
	// ДокументыУТ:2601). Хелпер сам опрацює перерахунок ціни через коефіцієнт упаковки,
	// конвертацію валют, ставку ПДВ — те, що ми б у custom-логіці пропускали.

	// Обработка строк
	Для НомерСтроки = ПерваяСтрока По ПоследняяСтрока Цикл

		МатериалНоСырой = СокрЛП(ТабДок.Область(НомерСтроки, 1).Текст);  // A
		Описание        = СокрЛП(ТабДок.Область(НомерСтроки, 2).Текст);  // B
		КодЦвета        = СокрЛП(ТабДок.Область(НомерСтроки, 4).Текст);  // D
		// E = сумма по строке (а не цена за единицу). Цену получаем как Сумма / Количество.
		СуммаТекст      = ТабДок.Область(НомерСтроки, 5).Текст;          // E
		// I = количество в базовой ЕИ (для штанг — длина в м одной штанги; используется для
		// выбора правильной индивидуальной упаковки, если у Номенклатуры несколько Sta-упаковок
		// разной длины), J = количество в ЕИ из колонки K (Sta/шт./У.Е.).
		// В документ записываем пару (J, K) — это «родные» для спецификации значения.
		КолБазТекст     = ТабДок.Область(НомерСтроки, 9).Текст;          // I
		КоличествоТекст = ТабДок.Область(НомерСтроки, 10).Текст;         // J
		ЕИКодСпеки      = СокрЛП(ТабДок.Область(НомерСтроки, 11).Текст); // K

		Если НЕ ЗначениеЗаполнено(МатериалНоСырой) Тогда
			Продолжить;
		КонецЕсли;

		// Витягуємо першу числову групу — обробляє формати типу "277049\n  (277048)"
		// (основний артикул + альтернативний у дужках). Для звичайних "381160" → "381160".
		МатериалНо = ИзвлечьОсновнойАртикул(МатериалНоСырой);

		Если НЕ ЭтоВалидныйАртикул(МатериалНо) Тогда
			Продолжить; // категория, заголовок и т.д. — НЕ логуємо: це нормальні нерядкові заголовки секцій.
		КонецЕсли;
		// Якщо з оригіналу витягли коротший варіант — попереджаємо про альтернативи в дужках,
		// зберігаємо «сирий» текст для коментаря (нижче).
		МатериалАльт = ?(МатериалНо <> МатериалНоСырой, МатериалНоСырой, "");
		ВРегОписание = ВРег(Описание);
		Если СтрНайти(ВРегОписание, "СУМА") > 0 Или СтрНайти(ВРегОписание, "ИТОГО") > 0
			Или СтрНайти(ВРегОписание, "TOTAL") > 0 Тогда
			Продолжить;
		КонецЕсли;

		Результат.Статистика.Обработано = Результат.Статистика.Обработано + 1;

		Количество = СтрокаВЧисло(КоличествоТекст);
		Если Количество = 0 Тогда
			Продолжить;
		КонецЕсли;

		ДанныеНоменклатуры = КэшНоменклатуры.Получить(МатериалНо);
		Если ДанныеНоменклатуры = Неопределено Тогда
			Результат.Статистика.НеНайдено = Результат.Статистика.НеНайдено + 1;
			Если Результат.Статистика.НеНайдено <= 20 Тогда
				ДобавитьСообщение(Результат, НСтр("uk='Не знайдено артикул: '") + МатериалНо);
			КонецЕсли;
			Продолжить;
		КонецЕсли;

		Сумма = СтрокаВЧисло(СуммаТекст);
		Цена  = ?(Количество <> 0, Сумма / Количество, 0);
		ИнформацияОЦвете = РазобратьКодЦвета(КодЦвета);

		// Единица измерения: ищем индивидуальную упаковку этой Номенклатуры с той же
		// одиницей классификатора, что у настроечной упаковки (МаппингЕИ["STA"].ЕдиницаИзмерения).
		// Если упаковок несколько (разная длина штанги) — выбираем ту, у которой
		// Числитель/Знаменатель совпадает с col I (метров в Sta) спеки.
		КоэфИзСпеки = ?(СтрокаВЧисло(КоличествоТекст) <> 0,
			СтрокаВЧисло(КолБазТекст) / СтрокаВЧисло(КоличествоТекст), 0);
		ЕдиницаИзмерения = РазрешитьЕдиницуИзмерения(
			ЕИКодСпеки, МаппингЕИ, ДанныеНоменклатуры.ЕдиницаИзмерения,
			ДанныеНоменклатуры.Ссылка, КоэфИзСпеки,
			МатериалНо, НеизвестныеЕИ, Результат);

		// Характеристика по покраске (только если ВидНоменклатуры использует характеристики).
		// Пустота/0/мех. в спецификации трактуем как «без фарбування» — берём настройку с формы.
		Характеристика = Неопределено;
		Если ДанныеНоменклатуры.ИспХар Тогда
			Если ЗначениеЗаполнено(ИнформацияОЦвете) И ЗначениеЗаполнено(СвойствоПокраска) Тогда
				Характеристика = НайтиХарактеристикуПоПокраске(
					ДанныеНоменклатуры, КодЦвета, СвойствоПокраска, КонтрагентКП, МатериалНо, Результат);
			ИначеЕсли НЕ ЗначениеЗаполнено(ИнформацияОЦвете) Тогда
				Характеристика = ХарактеристикаБезПокраски;
			КонецЕсли;
		КонецЕсли;

		// Ціни підставляються ПІСЛЯ головного циклу — стандартним УТ-helper'ом
		// ПродажиСервер.ЗаполнитьЦены (див. ЗаполнитьЦеныЧерезХелпер нижче). Тут лише
		// ставимо spec-ціну як стартове значення; helper або переб'є її ціною з прайсу,
		// або лишить як «довільну», якщо запису у регістрі немає.

		// Привязка к Набору (скатке): если строка совпала с компонентом из листа Isomat —
		// проставляем НоменклатураНабора и КлючСвязи, чтобы УТ-форма КП показала её
		// в составе своей скатки. Если у kit'а нет рецепта в каталоге — строка попадёт
		// не в Результат.Строки, а в СекцииДляСозданияРецепта (отложенно — добавится в КП
		// только если пользователь сохранит созданный рецепт через интерактивный диалог).
		КлючКомпонента = ВРег(СокрЛП(МатериалНо)) + "#" + НормализоватьЦветДляМатча(КодЦвета);
		ПривязкаКНабору = КартаIsomat.Получить(КлючКомпонента);

		Попытка
			СтрокаДанных = Новый Структура;
			СтрокаДанных.Вставить("Номенклатура", ДанныеНоменклатуры.Ссылка);
			// Форма КП использует свою служебную колонку для условного оформления —
			// без неё все строки показывают "<характеристики не використовуються>".
			СтрокаДанных.Вставить("ХарактеристикиИспользуются", ДанныеНоменклатуры.ИспХар);
			Если ЗначениеЗаполнено(ЕдиницаИзмерения) Тогда
				СтрокаДанных.Вставить("ЕдиницаИзмерения", ЕдиницаИзмерения);
			КонецЕсли;
			Если ЗначениеЗаполнено(Характеристика) Тогда
				СтрокаДанных.Вставить("Характеристика", Характеристика);
			КонецЕсли;
			Если ПривязкаКНабору <> Неопределено Тогда
				СтрокаДанных.Вставить("НоменклатураНабора",   ПривязкаКНабору.КитСсылка);
				СтрокаДанных.Вставить("ХарактеристикаНабора", ПривязкаКНабору.ХарактеристикаНабора);
				СтрокаДанных.Вставить("КлючСвязи",            ПривязкаКНабору.КлючСвязи);
			КонецЕсли;
			СтрокаДанных.Вставить("Количество", Количество);
			СтрокаДанных.Вставить("Цена", Цена);
			СтрокаДанных.Вставить("Сумма", Сумма);
			СтрокаДанных.Вставить("ТекстовоеОписание", Описание);
			// Службова колонка для post-loop ЗаповнитиЦіниЧерезХелпер — артикул для логів.
			// Не потрапить у КП.Товары (бо там немає такого реквізиту), але дозволяє
			// формувати повідомлення «Арт. X: ціна зі специфікації відрізняється...».
			СтрокаДанных.Вставить("АртикулСпеки", МатериалНо);

			// Внутренний комментарий: цвет + альтернативный артикул (для рядков типу "277049\n  (277048)").
			ЧастиКомм = Новый Массив;
			Если ЗначениеЗаполнено(ИнформацияОЦвете) Тогда
				ЧастиКомм.Добавить(ИнформацияОЦвете);
			КонецЕсли;
			Если ЗначениеЗаполнено(МатериалАльт) Тогда
				ЧастиКомм.Добавить("Спека: " + СтрЗаменить(МатериалАльт, Символы.ПС, " "));
			КонецЕсли;
			Если ЧастиКомм.Количество() > 0 Тогда
				СтрокаДанных.Вставить("КомментарийВнутренний", СтрСоединить(ЧастиКомм, "; "));
			КонецЕсли;

			СтавкаНДС  = ДанныеНоменклатуры.СтавкаНДС;
			ПроцентНДС = ДанныеНоменклатуры.ПроцентНДС;
			Если ЗначениеЗаполнено(СтавкаНДС) Тогда
				СтрокаДанных.Вставить("СтавкаНДС", СтавкаНДС);
			КонецЕсли;
			Если ПроцентНДС > 0 Тогда
				Если ЦенаВключаетНДС Тогда
					СуммаНДС = Сумма - Сумма / (1 + ПроцентНДС / 100);
					СтрокаДанных.Вставить("СуммаНДС", СуммаНДС);
					СтрокаДанных.Вставить("СуммаСНДС", Сумма);
				Иначе
					СуммаНДС = Сумма * ПроцентНДС / 100;
					СтрокаДанных.Вставить("СуммаНДС", СуммаНДС);
					СтрокаДанных.Вставить("СуммаСНДС", Сумма + СуммаНДС);
				КонецЕсли;
			Иначе
				СтрокаДанных.Вставить("СуммаНДС", 0);
				СтрокаДанных.Вставить("СуммаСНДС", Сумма);
			КонецЕсли;

			СтрокаДанных.Вставить("Активность", Истина);

			Если ПривязкаКНабору <> Неопределено И ПривязкаКНабору.ПотребуетРецепт = Истина Тогда
				// Kit найден, но рецепта в каталоге нет — откладываем строку в секцию
				// для интерактивного создания рецепта на клиенте.
				Секция = СекцииСоответствие.Получить(ПривязкаКНабору.КлючСвязи);
				Если Секция <> Неопределено Тогда
					Секция.СтрокиОжидающие.Добавить(СтрокаДанных);
					ДобавитьКомпонентВПреЗаполнение(
						Секция.КомпонентыПреЗаполнения,
						ДанныеНоменклатуры.Ссылка,
						?(ЗначениеЗаполнено(Характеристика), Характеристика, Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка()),
						Количество,
						Секция.КитSumQty);
				КонецЕсли;
				// В Загружено пока не считаем — посчитается, когда (и если) пользователь сохранит рецепт.
			Иначе
				Результат.Строки.Добавить(СтрокаДанных);
				Результат.Статистика.Загружено = Результат.Статистика.Загружено + 1;
			КонецЕсли;

		Исключение
			Результат.Статистика.Ошибок = Результат.Статистика.Ошибок + 1;
			Если Результат.Статистика.Ошибок <= 10 Тогда
				ДобавитьСообщение(Результат, НСтр("uk='Помилка рядок '") + НомерСтроки + " (" + МатериалНо + "): " + ОписаниеОшибки());
			КонецЕсли;
		КонецПопытки;

	КонецЦикла;

	// Заповнення цін з прайс-листа через стандартний УТ-helper. Робимо ПІСЛЯ
	// головного циклу: хелпер очікує цілу таблицю, не окремі рядки. Kit-секції
	// (СтрокиОжидающие) поки не покриваємо — для них pricing буде окремо у момент,
	// коли користувач збереже рецепт (out of scope для цього майданчика).
	Если ЗначениеЗаполнено(ВидЦенПрайс) И Результат.Строки.Количество() > 0 Тогда
		ЗаполнитьЦеныЧерезХелпер(Результат, ВидЦенПрайс, ВалютаКП, ДатаКП);
	КонецЕсли;

	// Конвертируем Соответствие СекцииСоответствие в Массив (для удобной итерации
	// клиентом). Порядок не важен — каждая секция самодостаточна.
	Для Каждого ЭлСекц Из СекцииСоответствие Цикл
		Результат.СекцииДляСозданияРецепта.Добавить(ЭлСекц.Значение);
	КонецЦикла;

	Результат.Статистика.Сообщение = НСтр("uk='Завершено'") + ". "
		+ НСтр("uk='Оброблено: '") + Результат.Статистика.Обработано + ", "
		+ НСтр("uk='Завантажено: '") + Результат.Статистика.Загружено + ", "
		+ НСтр("uk='Не знайдено: '") + Результат.Статистика.НеНайдено + ", "
		+ НСтр("uk='Помилок: '") + Результат.Статистика.Ошибок;

	Возврат Результат;

КонецФункции

// Артикул валідний, якщо це не заголовок секції / підсумок, тобто:
//   • не порожній
//   • не містить пробілів (всередині — заголовки типу "G27 PROFILES" відсікаються)
//   • не містить кириличних літер (українські заголовки "Профілі", "Фурнітура", "СУМА")
//   • має хоча б одну цифру
// Латино-цифрові SKU типу "V10-1113600-UDC03" і чисто числові "381160" — обидва валідні.
&НаСервереБезКонтекста
Функция ЭтоВалидныйАртикул(Стр)
	Очищ = СокрЛП(Стр);
	Если ПустаяСтрока(Очищ) Тогда
		Возврат Ложь;
	КонецЕсли;
	МаєЦифру = Ложь;
	Для Поз = 1 По СтрДлина(Очищ) Цикл
		Симв = Сред(Очищ, Поз, 1);
		// Пробіл / переноси / табуляція всередині — заголовки чи "битий" артикул.
		Если СтрНайти(" " + Символы.ПС + Символы.ВК + Символы.Таб, Симв) > 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		// Кириличний блок Unicode 0x0400..0x04FF — українська/російська літера.
		Код = КодСимвола(Очищ, Поз);
		Если Код >= 1024 И Код <= 1279 Тогда
			Возврат Ложь;
		КонецЕсли;
		Если СтрНайти("0123456789", Симв) > 0 Тогда
			МаєЦифру = Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат МаєЦифру;
КонецФункции

&НаСервереБезКонтекста
Функция РазобратьКодЦвета(КодЦвета)
	// "11 7005" -> "RAL 7005, порошкове покриття"
	// "0" / "" / "мех." -> ""
	КодОчищенный = СокрЛП(КодЦвета);
	Если ПустаяСтрока(КодОчищенный) Или КодОчищенный = "0" Или ВРег(КодОчищенный) = "МЕХ." Тогда
		Возврат "";
	КонецЕсли;
	Части = СтрРазделить(КодОчищенный, " ", Ложь);
	Если Части.Количество() >= 2 Тогда
		ТипПокриття = Части[0];
		КодRAL = Части[1];
		ТекстПокриття = ?(ТипПокриття = "11", "порошкове покриття", "тип " + ТипПокриття);
		Возврат "RAL " + КодRAL + ", " + ТекстПокриття;
	Иначе
		Возврат КодОчищенный;
	КонецЕсли;
КонецФункции

&НаСервереБезКонтекста
Функция СтрокаВЧисло(Стр)
	Попытка
		Стр = СокрЛП(Стр);
		Если ПустаяСтрока(Стр) Тогда
			Возврат 0;
		КонецЕсли;
		Стр = СтрЗаменить(Стр, ",", ".");
		Стр = СтрЗаменить(Стр, " ", "");
		Возврат Число(Стр);
	Исключение
		Возврат 0;
	КонецПопытки;
КонецФункции

&НаСервереБезКонтекста
Функция РазрешитьЕдиницуИзмерения(ЕИКодСпеки, МаппингЕИ, БазоваяЕИНоменклатуры,
	Номенклатура, КоэфИзСпеки, МатериалНо, НеизвестныеЕИ, Результат)

	// Алгоритм:
	// 1. Пустой ЕИКодСпеки → базовая ЕИ Номенклатуры (без изменений).
	// 2. Получаем НастроечнаяУпаковка = МаппингЕИ[Ключ] (например, "st" из НабораУпаковок).
	//    Из неё берём ЕдиницаКлассификатора = НастроечнаяУпаковка.ЕдиницаИзмерения.
	// 3. Ищем индивидуальные упаковки Номенклатуры с той же ЕдиницаИзмерения =
	//    ЕдиницаКлассификатора (Schueco_ЗагрузкаНоменклатуры:464 кладёт их с
	//    Владелец=Номенклатура).
	//    - 0 строк → fallback на саму НастроечнаяУпаковка (старая логика).
	//    - 1 строка → её и возвращаем.
	//    - >1 строки → выбираем ту, чей Числитель/Знаменатель ближе всего к КоэфИзСпеки
	//      (col I спеки = метров в одной Sta).
	// 4. "У.Е." → базовая (тихий fallback).
	// 5. Иначе → базовая + одно предупреждение на код.

	Если ПустаяСтрока(ЕИКодСпеки) Тогда
		Возврат БазоваяЕИНоменклатуры;
	КонецЕсли;

	Ключ = ВРег(ЕИКодСпеки);

	// Спец-случай: "У.Е." — базовая Номенклатуры.
	Если Ключ = "У.Е." Или Ключ = "УЕ" Тогда
		Возврат БазоваяЕИНоменклатуры;
	КонецЕсли;

	НастроечнаяУпаковка = МаппингЕИ.Получить(Ключ);

	// Если в настройках для этого кода ничего не задано — старая логика:
	// предупреждение + базовая ЕИ.
	Если НЕ ЗначениеЗаполнено(НастроечнаяУпаковка) Тогда
		Если НеизвестныеЕИ.Получить(Ключ) = Неопределено Тогда
			НеизвестныеЕИ.Вставить(Ключ, Истина);
			ДобавитьСообщение(Результат, СтрШаблон(
				НСтр("uk='Одиниця ""%1"" не зіставлена — використано базову з номенклатури (арт. %2). Заповніть відповідність на формі.'"),
				ЕИКодСпеки, МатериалНо));
		КонецЕсли;
		Возврат БазоваяЕИНоменклатуры;
	КонецЕсли;

	// Перш ніж шукати в упаковках Номенклатури — перевіряємо, чи задана у спеці
	// одиниця взагалі НЕ є базовою ЕИ цієї Номенклатури. Якщо вона базова (наприклад,
	// у спеці "шт.", базова Номенклатури теж "шт.") — нічого шукати, базова і є
	// потрібна. Це швидкий silent-вихід без зайвого попередження.
	Если НастроечнаяУпаковка = БазоваяЕИНоменклатуры Тогда
		Возврат БазоваяЕИНоменклатуры;
	КонецЕсли;

	// Шукаємо індивідуальні упаковки Номенклатури з полем ЕдиницаИзмерения, що
	// вказує на саму налаштовану упаковку. У моделі УТ Catalog.УпаковкиЕдиницыИзмерения
	// поле ЕдиницаИзмерения зберігає посилання на ІНШУ упаковку (батьківську «одиницю»),
	// а не на класифікатор. Це підтверджено OData: КП SC00-000002 рядок 381160 має
	// упаковку Owner=Номенклатура, ЕдиницаИзмерения_Key = c919a2db (= Ref налаштованої «st»).
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		Запрос = Новый Запрос(
			"ВЫБРАТЬ
			|	У.Ссылка        КАК Ссылка,
			|	У.Числитель     КАК Числитель,
			|	У.Знаменатель   КАК Знаменатель
			|ИЗ
			|	Справочник.УпаковкиЕдиницыИзмерения КАК У
			|ГДЕ
			|	У.Владелец = &Номенклатура
			|	И У.ЕдиницаИзмерения = &ЕдиницаУпаковки
			|	И НЕ У.ПометкаУдаления");
		Запрос.УстановитьПараметр("Номенклатура",    Номенклатура);
		Запрос.УстановитьПараметр("ЕдиницаУпаковки", НастроечнаяУпаковка);
		Кандидаты = Запрос.Выполнить().Выгрузить();

		Если Кандидаты.Количество() = 1 Тогда
			Возврат Кандидаты[0].Ссылка;
		ИначеЕсли Кандидаты.Количество() > 1 И КоэфИзСпеки > 0 Тогда
			// Выбираем упаковку, чей коэффициент Числитель/Знаменатель ближе всего к КоэфИзСпеки.
			ЛучшаяСсылка    = Неопределено;
			ЛучшееОтклонение = 0;
			Для Каждого Канд Из Кандидаты Цикл
				Знам = ?(Канд.Знаменатель = 0, 1, Канд.Знаменатель);
				Коэф = ?(Знам = 0, 0, Канд.Числитель / Знам);
				Откл = Макс(Коэф - КоэфИзСпеки, КоэфИзСпеки - Коэф);
				Если ЛучшаяСсылка = Неопределено ИЛИ Откл < ЛучшееОтклонение Тогда
					ЛучшаяСсылка    = Канд.Ссылка;
					ЛучшееОтклонение = Откл;
				КонецЕсли;
			КонецЦикла;
			Если ЛучшаяСсылка <> Неопределено Тогда
				Возврат ЛучшаяСсылка;
			КонецЕсли;
		ИначеЕсли Кандидаты.Количество() > 1 Тогда
			// Несколько упаковок, но коэфф из спеки не определён — берём первую с предупреждением.
			ДобавитьСообщение(Результат, СтрШаблон(
				НСтр("uk='Для арт. %1 знайдено декілька упаковок ""%2"" — взято першу. Уточніть col I в спеці для точнішого вибору.'"),
				МатериалНо, ЕИКодСпеки), Истина);
			Возврат Кандидаты[0].Ссылка;
		КонецЕсли;
		// 0 кандидатов → fallback ниже.
	КонецЕсли;

	// Для Номенклатури немає індивідуальної упаковки з потрібною одиницею. Повертаємо
	// БАЗОВУ одиницю Номенклатури (а не загальну з налаштувань) — бо «загальна Sta»
	// для штучного товару семантично невірна (1 Sta ≠ 1 шт без коефіцієнта). Базова
	// одиниця завжди коректна, навіть якщо у спеці помилково вказано Sta. Користувач
	// бачить попередження і може поправити спеку.
	Если НеизвестныеЕИ.Получить(Ключ + "#" + Строка(Номенклатура)) = Неопределено Тогда
		НеизвестныеЕИ.Вставить(Ключ + "#" + Строка(Номенклатура), Истина);
		ДобавитьСообщение(Результат, СтрШаблон(
			НСтр("uk='Для арт. %1 немає власної упаковки ""%2"" — використано базову одиницю номенклатури. Перевірте спеку.'"),
			МатериалНо, ЕИКодСпеки));
	КонецЕсли;
	Возврат БазоваяЕИНоменклатуры;
КонецФункции

&НаСервереБезКонтекста
Функция НайтиХарактеристикуПоПокраске(ДанныеНоменклатуры, КодЦвета, СвойствоПокраска,
	КонтрагентКП, МатериалНо, Результат)

	// Кандидаты — все характеристики номенклатуры (учёт варианта использования).
	//   ИндивидуальныеДляНоменклатуры       → Хар.Владелец = Номенклатура
	//   ОбщиеСДругимВидомНоменклатуры       → Хар.Владелец = ВидНом.ВладелецХарактеристик
	//   ОбщиеДляВидаНоменклатуры (и пр.)    → Хар.Владелец = ВидНоменклатуры (сам справочник)
	ВариантИндивид = ПредопределенноеЗначение("Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры");
	Если ДанныеНоменклатуры.ВариантХар = ВариантИндивид Тогда
		ВладелецОтбор = ДанныеНоменклатуры.Ссылка;
	ИначеЕсли ЗначениеЗаполнено(ДанныеНоменклатуры.ВладелецХар) Тогда
		ВладелецОтбор = ДанныеНоменклатуры.ВладелецХар;
	Иначе
		ВладелецОтбор = ДанныеНоменклатуры.ВидНоменклатуры;
	КонецЕсли;

	// Витягуємо назву Цвета напряму. Двоступеневий запит через ВТ: спершу — кандидати
	// з типизованою Покраской, потім — звертання до Покраска.Цвет.Наименование та
	// .ОбъектЗаказчика. Так уникаємо подвійного ВЫРАЗИТЬ, який інколи ламається на
	// рівні платформи і повертає порожні значення.
	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Хар.Ссылка                                          КАК Ссылка,
		|	ВЫРАЗИТЬ(ДопР.Значение КАК Справочник.Покраски_SCT) КАК Покраска
		|ПОМЕСТИТЬ ВТ_Кандидаты
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры КАК Хар
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры.ДополнительныеРеквизиты КАК ДопР
		|		ПО ДопР.Ссылка = Хар.Ссылка
		|ГДЕ
		|	Хар.Владелец = &Владелец
		|	И НЕ Хар.ПометкаУдаления
		|	И ДопР.Свойство = &Свойство
		|;
		|ВЫБРАТЬ
		|	К.Ссылка                       КАК Ссылка,
		|	К.Покраска                     КАК Покраска,
		|	К.Покраска.Цвет.Наименование   КАК ЦветНаим,
		|	К.Покраска.ОбъектЗаказчика     КАК ОбъектЗаказчика
		|ИЗ
		|	ВТ_Кандидаты КАК К");
	Запрос.УстановитьПараметр("Владелец", ВладелецОтбор);
	Запрос.УстановитьПараметр("Свойство", СвойствоПокраска);
	Кандидаты = Запрос.Выполнить().Выгрузить();

	Если Кандидаты.Количество() = 0 Тогда
		ДобавитьСообщение(Результат, СтрШаблон(
			НСтр("uk='Не знайдено характеристик з фарбуванням для арт. %1 (код %2)'"),
			МатериалНо, КодЦвета));
		Возврат Неопределено;
	КонецЕсли;

	// Извлечь RAL-код (последний токен из "11 7016" → "7016") для текстового сопоставления цвета.
	Токены = СтрРазделить(СокрЛП(КодЦвета), " ", Ложь);
	КодRAL = ?(Токены.Количество() >= 2, Токены[Токены.Количество() - 1], СокрЛП(КодЦвета));

	// Збираємо ВСІХ кандидатів з Цветом, що містить КодRAL, і ділимо на дві групи
	// за наявністю ОбъектЗаказчика. Зв'язок ОбъектЗаказчика↔КонтрагентКП наразі не
	// реалізований у конфігурації — TODO для майбутньої доробки. Зараз: пріоритезуємо
	// характеристики БЕЗ об'єкта (універсальні), якщо вибір неоднозначний — попереджаємо.
	КандидатыСОбъектом   = Новый Массив;
	КандидатыБезОбъекта  = Новый Массив;
	Для Каждого Стр Из Кандидаты Цикл
		Если НЕ ЗначениеЗаполнено(Стр.Покраска) Тогда
			Продолжить;
		КонецЕсли;
		ЦветНаим = СокрЛП(Стр.ЦветНаим);
		Если ПустаяСтрока(ЦветНаим) ИЛИ СтрНайти(ЦветНаим, КодRAL) = 0 Тогда
			Продолжить;
		КонецЕсли;
		Если ЗначениеЗаполнено(Стр.ОбъектЗаказчика) Тогда
			КандидатыСОбъектом.Добавить(Стр.Ссылка);
		Иначе
			КандидатыБезОбъекта.Добавить(Стр.Ссылка);
		КонецЕсли;
	КонецЦикла;

	// Без об'єкта — пріоритетна гілка.
	Если КандидатыБезОбъекта.Количество() = 1 Тогда
		Возврат КандидатыБезОбъекта[0];
	ИначеЕсли КандидатыБезОбъекта.Количество() > 1 Тогда
		ДобавитьСообщение(Результат, СтрШаблон(
			НСтр("uk='Для арт. %1, колір %2: знайдено %3 характеристик без прив''язки до об''єкта замовника — обрано першу.'"),
			МатериалНо, КодRAL, КандидатыБезОбъекта.Количество()), Истина);
		Возврат КандидатыБезОбъекта[0];
	КонецЕсли;

	// Без-об'єкта нічого; беремо з заповненим, бо це краще ніж нічого. Попереджаємо.
	Если КандидатыСОбъектом.Количество() > 0 Тогда
		ДобавитьСообщение(Результат, СтрШаблон(
			НСтр("uk='Для арт. %1, колір %2: знайдено лише характеристики з прив''язкою до інших об''єктів замовника — обрано першу. Перевірте відповідність.'"),
			МатериалНо, КодRAL), Истина);
		Возврат КандидатыСОбъектом[0];
	КонецЕсли;

	// Кандидати були, але жоден не пройшов фільтр «Цвет містить RAL»: у довіднику
	// Кольори фарбування немає запису з цим RAL (або Цвет не вказаний у Покрасках).
	Если Кандидаты.Количество() > 0 Тогда
		ДобавитьСообщение(Результат, СтрШаблон(
			НСтр("uk='Не знайдено характеристики з кольором %1 для арт. %2'"),
			КодRAL, МатериалНо));
		Возврат Неопределено;
	КонецЕсли;

	// Kандидаты = 0: немає характеристик з ДопРекв «Покраска» взагалі. Можливе stale-посилання
	// на ДопРекв з налаштувань (наприклад, після клонування бази GUID не співпадає).
	ДобавитьСообщение(Результат, СтрШаблон(
		НСтр("uk='Не знайдено характеристик з фарбуванням для арт. %1 (код %2). Можливо у налаштуваннях обрано не той реквізит.'"),
		МатериалНо, КодЦвета));
	Возврат Неопределено;
КонецФункции

// Заповнює ціни через стандартний УТ-helper ПродажиСервер.ЗаполнитьЦены — той самий,
// що використовує picker КП "Заповнити → Підібрати товари". Хелпер сам виконує
// канонічний пошук у регістрі ЦеныНоменклатуры, перерахунок ціни через коефіцієнт
// упаковки, конвертацію валют і підбір ставки ПДВ. Інтерфейс взято з
// КоммерческиеПредложенияДокументыУТ.КоммерческоеПредложениеКлиентуЗаполнитьЦеныПоВидуЦен:2574.
//
// Алгоритм:
//   1. Будуємо ТаблицуЗначений з Результат.Строки — колонки: Номенклатура, Характеристика,
//      ЕдиницаИзмерения (це наша назва "Упаковки" в КП.Товары), Количество, Цена.
//      Додаємо службову СпекЦена (для diff'у) та ИндексМассива (back-pointer на Результат.Строки).
//   2. Викликаємо ПродажиСервер.ЗаполнитьЦены з ПоляЗаполнения="Цена, ВидЦены".
//   3. Для кожного рядка ТЗ:
//        • ВидЦены заповнено → прайс знайшов. Порівнюємо з СпекЦена; differs → попередження.
//          Записуємо нову Цена/ВидЦены назад у Результат.Строки.
//        • ВидЦены порожнє → прайс не знайшов. Лишаємо spec-ціну як «довільну» з попередженням.
&НаСервереБезКонтекста
Процедура ЗаполнитьЦеныЧерезХелпер(Результат, ВидЦенПрайс, ВалютаКП, ДатаКП)

	// Кваліфікатори числа обов'язкові: без них ОписаниеТипов("Число") дає precision=10, scale=0
	// (ціле число), і УТ-helper, що пише 7,9 → ТЗ зберігає 8 чи NULL — ціни «з'їдаються».
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("НомерСтроки",      Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 0)));
	ТЗ.Колонки.Добавить("Номенклатура",     Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЗ.Колонки.Добавить("Характеристика",   Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТЗ.Колонки.Добавить("ЕдиницаИзмерения", Новый ОписаниеТипов("СправочникСсылка.УпаковкиЕдиницыИзмерения"));
	ТЗ.Колонки.Добавить("Количество",       Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 3)));
	ТЗ.Колонки.Добавить("Цена",             Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
	ТЗ.Колонки.Добавить("ВидЦены",          Новый ОписаниеТипов("СправочникСсылка.ВидыЦен"));
	ТЗ.Колонки.Добавить("СпекЦена",         Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
	ТЗ.Колонки.Добавить("ИндексМассива",    Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 0)));

	Для Инд = 0 По Результат.Строки.Количество() - 1 Цикл
		Орігін = Результат.Строки[Инд];
		НоваяСтр = ТЗ.Добавить();
		НоваяСтр.НомерСтроки   = Инд + 1;
		НоваяСтр.Номенклатура  = Орігін.Номенклатура;
		Если Орігін.Свойство("Характеристика") Тогда
			НоваяСтр.Характеристика = Орігін.Характеристика;
		КонецЕсли;
		Если Орігін.Свойство("ЕдиницаИзмерения") Тогда
			НоваяСтр.ЕдиницаИзмерения = Орігін.ЕдиницаИзмерения;
		КонецЕсли;
		НоваяСтр.Количество    = Орігін.Количество;
		НоваяСтр.Цена          = Орігін.Цена;
		НоваяСтр.СпекЦена      = Орігін.Цена;
		НоваяСтр.ИндексМассива = Инд;
	КонецЦикла;

	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("Дата",               ?(ЗначениеЗаполнено(ДатаКП), ДатаКП, ТекущаяДатаСеанса()));
	ПараметрыЗаполнения.Вставить("Валюта",             ВалютаКП);
	ПараметрыЗаполнения.Вставить("ВидЦены",            ВидЦенПрайс);
	ПараметрыЗаполнения.Вставить("РассчитыватьНаборы", Ложь);
	ПараметрыЗаполнения.Вставить("ПоляЗаполнения",     "Цена, ВидЦены");
	ПараметрыЗаполнения.Вставить("ИмяКолонкиУпаковка", "ЕдиницаИзмерения");

	ПродажиСервер.ЗаполнитьЦены(ТЗ, , ПараметрыЗаполнения, Неопределено);

	Для Каждого СтрТЗ Из ТЗ Цикл
		Орігін = Результат.Строки[СтрТЗ.ИндексМассива];
		Артикул = ?(Орігін.Свойство("АртикулСпеки"), Орігін.АртикулСпеки, "");
		// Гард «прайс реально знайшов»: УТ-helper для рядків без запису у регістрі
		// віддає Цена = NULL, але ВидЦены — заповнений (CASE на параметр). Тому самого
		// ВидЦены недостатньо — мусимо переконатись, що Цена > 0.
		ЦенаПрайсЕсть = ЗначениеЗаполнено(СтрТЗ.ВидЦены)
			И СтрТЗ.Цена <> NULL
			И СтрТЗ.Цена > 0;
		Если ЦенаПрайсЕсть Тогда
			// Прайс знайшов. Записуємо назад у Результат.Строки і виводимо diff-попередження.
			Если Окр(СтрТЗ.Цена, 2) <> Окр(СтрТЗ.СпекЦена, 2) Тогда
				ДобавитьСообщение(Результат, СтрШаблон(
					НСтр("uk='Арт. %1: ціна зі специфікації %2 відрізняється від прайсу %3 — використано прайс.'"),
					Артикул, Формат(СтрТЗ.СпекЦена, "ЧДЦ=2"), Формат(СтрТЗ.Цена, "ЧДЦ=2")), Истина);
			КонецЕсли;
			Орігін.Цена = СтрТЗ.Цена;
			Орігін.Сумма = СтрТЗ.Цена * СтрТЗ.Количество;
			Орігін.Вставить("ВидЦены", СтрТЗ.ВидЦены);
		Иначе
			// Прайс не знайшов — лишаємо spec-ціну як «довільну».
			ДобавитьСообщение(Результат, СтрШаблон(
				НСтр("uk='Арт. %1: у прайсі немає ціни — використано зі специфікації %2 як довільну.'"),
				Артикул, Формат(СтрТЗ.СпекЦена, "ЧДЦ=2")));
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

// Pre-pass по листу "Isomat": если он есть в книге — собирает карту "(артикул, цвет) → Набор"
// для каждого компонента каждой kit-секции. Если листа нет, возвращает пустую структуру
// (main-pass отрабатывает как раньше — никаких регрессий для спек без скаток).
//
// Возвращаемое значение — Структура:
//   Карта             — Соответствие, ключ "ВРег(артикул)#нормализованныйЦвет",
//                       значение Структура("КитСсылка, КлючСвязи, ХарактеристикаНабора, ПотребуетРецепт").
//   СекцииБезРецепта  — Соответствие, ключ КлючСвязи, значение Структура
//                       ("КитСсылка, КитНаименование, КлючСвязи, КитSumQty"). Заполняется только
//                       для секций, у которых kit-Номенклатура нашлась, но рецепта в каталоге нет.
//
&НаСервереБезКонтекста
Функция СобратьКартуIsomat(ИмяВремФайла, СвойствоБазоваяНоменклатура, Результат)

	Возвращаемое = Новый Структура;
	Возвращаемое.Вставить("Карта",            Новый Соответствие);
	Возвращаемое.Вставить("СекцииБезРецепта", Новый Соответствие);
	Карта             = Возвращаемое.Карта;
	СекцииБезРецепта  = Возвращаемое.СекцииБезРецепта;

	// Попытка прочитать второй лист "Isomat". Если в книге его нет — Прочитать выбросит
	// исключение, ловим и возвращаем пустые коллекции.
	ТабДокIsomat = Новый ТабличныйДокумент;
	Попытка
		ТабДокIsomat.Прочитать(ИмяВремФайла, , "Isomat");
	Исключение
		Возврат Возвращаемое; // листа Isomat нет — спека без скатки, поведение прежнее
	КонецПопытки;

	// Лист есть, но реквизит "Базовая номенклатура" не настроен — pre-pass пропускаем,
	// но один раз сообщаем пользователю, чтобы он мог настроить.
	Если НЕ ЗначениеЗаполнено(СвойствоБазоваяНоменклатура) Тогда
		ДобавитьСообщение(Результат, НСтр(
			"ru='Лист Isomat найден, но в настройках не задан реквизит ""Базовая номенклатура"" — "
				+ "скатки не размечены. Откройте ""Налаштування"" и заполните параметр.';"
			+ "uk='Лист Isomat знайдено, але в налаштуваннях не задано реквізит ""Базова номенклатура"" — "
				+ "скатки не розмічені. Відкрийте ""Налаштування"" та заповніть параметр.'"));
		Возврат Возвращаемое;
	КонецЕсли;

	ВысотаIsomat = ТабДокIsomat.ВысотаТаблицы;
	Если ВысотаIsomat = 0 Тогда
		Возврат Возвращаемое;
	КонецЕсли;

	// Идём по всем строкам, разбивая на kit-секции. Маркер kit-summary: numeric arrticle
	// в col A + qty в col H + "*" в col L. Component строки: numeric article без qty в H.
	// Разделитель — пустая строка либо новая kit-summary.
	КлючСвязиСчётчик   = 0;
	КитТекущий         = Неопределено;
	КлючСвязиТек       = 0;
	ТекущКитНуждается  = Ложь;
	Для НомерСтроки = 1 По ВысотаIsomat Цикл

		АртикулСырой = СокрЛП(ТабДокIsomat.Область(НомерСтроки, 1).Текст);
		КвоТекст     = СокрЛП(ТабДокIsomat.Область(НомерСтроки, 8).Текст);  // H "Кол-во"
		МаркерСод    = СокрЛП(ТабДокIsomat.Область(НомерСтроки, 12).Текст); // L "Содержание/* "
		КодЦветаСтр  = СокрЛП(ТабДокIsomat.Область(НомерСтроки, 4).Текст);  // D "Пов-ть"

		// Очистить артикул от мусора вида "395720\n  (395730)" — берём первую числовую группу
		АртикулОсновной = ИзвлечьОсновнойАртикул(АртикулСырой);

		// Пустая строка — конец секции (не сбрасывает текущую, kit-summary делает то же)
		Если НЕ ЗначениеЗаполнено(АртикулОсновной) Тогда
			КитТекущий        = Неопределено;
			ТекущКитНуждается = Ложь;
			Продолжить;
		КонецЕсли;

		Если НЕ ЭтоВалидныйАртикул(АртикулОсновной) Тогда
			Продолжить; // заголовок/секция/категория
		КонецЕсли;

		// Kit-summary: если есть Кол-во и пометка '*'
		ЭтоКитСтрока = ЗначениеЗаполнено(КвоТекст) И (СтрНайти(МаркерСод, "*") > 0);

		Если ЭтоКитСтрока Тогда
			КлючСвязиСчётчик = КлючСвязиСчётчик + 1;
			КлючСвязиТек     = КлючСвязиСчётчик;
			КитТекущий       = НайтиКитПоБазе(АртикулОсновной, СвойствоБазоваяНоменклатура, Результат);
			ТекущКитНуждается = Ложь;

			// Если kit найден — проверяем наличие рецепта (Справочник.ВариантыКомплектацииНоменклатуры).
			// Без рецепта kit формально валиден, но УТ-форма «Изменить набор» падает —
			// собираем такие секции в СекцииБезРецепта для интерактивного создания на клиенте.
			Если КитТекущий <> Неопределено И НЕ КитИмеетРецепт(КитТекущий) Тогда
				ТекущКитНуждается = Истина;
				КитSumQty = СтрокаВЧисло(КвоТекст);
				РеквизитыКита = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КитТекущий, "Артикул, Наименование");
				СекцииБезРецепта.Вставить(КлючСвязиТек, Новый Структура(
					"КитСсылка, КитАртикул, КитНаименование, КлючСвязи, КитSumQty",
					КитТекущий,
					СокрЛП(РеквизитыКита.Артикул),
					СокрЛП(РеквизитыКита.Наименование),
					КлючСвязиТек,
					КитSumQty));
			КонецЕсли;

			Продолжить;
		КонецЕсли;

		// Component-строка имеет смысл только если выше была kit-summary с найденным kit
		Если КитТекущий = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Ключ = ВРег(АртикулОсновной) + "#" + НормализоватьЦветДляМатча(КодЦветаСтр);
		Если Карта.Получить(Ключ) = Неопределено Тогда
			Карта.Вставить(Ключ, Новый Структура(
				"КитСсылка, КлючСвязи, ХарактеристикаНабора, ПотребуетРецепт",
				КитТекущий,
				КлючСвязиТек,
				Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка(),
				ТекущКитНуждается));
		КонецЕсли;

	КонецЦикла;

	Возврат Возвращаемое;
КонецФункции

// Присоединяет файл (адресу из временного хранилища) к документу КП через канонический
// БСП-API. При повторном импорте того же файла (совпадение Описание + Расширение для
// данного КП) обновляет двоичные данные существующего вложения через
// РаботаСФайлами.ОбновитьФайл вместо создания дубликата. При первом импорте создаёт
// новое вложение через РаботаСФайлами.ДобавитьФайл.
//
// Каноничный паттерн: см. CommonModules/УстановкаЦенВызовСервера/Ext/Module.bsl
// (там Excel-экспорт прайса аналогично прикрепляется к документу).
&НаСервереБезКонтекста
Функция ПрисоединитьФайлКПДокументу(КПСсылка, АдресВХранилище, ИмяФайла)

	Если НЕ ЗначениеЗаполнено(КПСсылка) Тогда
		Возврат Новый Структура("Успех, Сообщение", Ложь,
			НСтр("ru='Документ КП не записан — файл спецификации не приложен. "
					+ "Запишите документ и повторите импорт, чтобы сохранить оригинал во вложениях.';"
				+ "uk='Документ КП не записаний — файл специфікації не приєднано. "
					+ "Запишіть документ і повторіть імпорт, щоб зберегти оригінал у вкладеннях.'"));
	КонецЕсли;

	ИмяБезРасширения = ИмяФайла;
	Расширение = "";
	ТочкаПоз = СтрНайти(ИмяФайла, ".", НаправлениеПоиска.СКонца);
	Если ТочкаПоз > 0 Тогда
		ИмяБезРасширения = Лев(ИмяФайла, ТочкаПоз - 1);
		Расширение       = Сред(ИмяФайла, ТочкаПоз + 1);
	КонецЕсли;
	Если ПустаяСтрока(Расширение) Тогда
		// Захист на крайові випадки (напр., файл без точки в имени) — ставимо xlsx.
		Расширение = "xlsx";
	КонецЕсли;
	Если ПустаяСтрока(ИмяБезРасширения) Тогда
		ИмяБезРасширения = "specification";
	КонецЕсли;

	// Поиск существующего вложения у этого КП с тем же именем + расширением.
	// БСП-каталог ПрисоединенныеФайлы кладёт имя файла в поле Наименование, НЕ в Описание
	// (см. РаботаСФайламиСлужебный.Module.bsl:4472, 4650 — Реквизит «Наименование» = ИмяБезРасширения).
	// Расширение тоже неограниченной длины — обернём в ВЫРАЗИТЬ для совместимости.
	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка
		|ИЗ Справочник.КоммерческоеПредложениеКлиентуПрисоединенныеФайлы
		|ГДЕ ВладелецФайла = &Владелец
		|	И Наименование = &Наименование
		|	И ВЫРАЗИТЬ(Расширение КАК СТРОКА(20)) = &Расширение
		|	И НЕ ПометкаУдаления");
	Запрос.УстановитьПараметр("Владелец",     КПСсылка);
	Запрос.УстановитьПараметр("Наименование", ИмяБезРасширения);
	Запрос.УстановитьПараметр("Расширение",   Расширение);
	Выборка = Запрос.Выполнить().Выбрать();
	СуществующийФайл = ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);

	Если СуществующийФайл <> Неопределено Тогда
		// Обновлять существующий — РаботаСФайлами.ОбновитьФайл (Module.bsl:326).
		ИнфоОФайле = Новый Структура;
		ИнфоОФайле.Вставить("АдресФайлаВоВременномХранилище", АдресВХранилище);
		ИнфоОФайле.Вставить("АдресВременногоХранилищаТекста", "");
		ИнфоОФайле.Вставить("ДатаМодификацииУниверсальная",   ТекущаяУниверсальнаяДата());
		Попытка
			РаботаСФайлами.ОбновитьФайл(СуществующийФайл, ИнфоОФайле);
		Исключение
			Возврат Новый Структура("Успех, Сообщение", Ложь,
				СтрШаблон(НСтр("ru='Не удалось обновить вложение в КП: %1';"
						+ "uk='Не вдалося оновити вкладення в КП: %1'"),
					ОписаниеОшибки()));
		КонецПопытки;
		Возврат Новый Структура("Успех, Сообщение", Истина,
			СтрШаблон(НСтр("ru='Файл ""%1.%2"" обновлён во вложениях КП';"
					+ "uk='Файл ""%1.%2"" оновлено у вкладеннях КП'"),
				ИмяБезРасширения, Расширение));
	КонецЕсли;

	// Иначе — добавить как новое вложение.
	ПараметрыФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
	ПараметрыФайла.ВладелецФайлов              = КПСсылка;
	ПараметрыФайла.ИмяБезРасширения            = ИмяБезРасширения;
	ПараметрыФайла.РасширениеБезТочки          = Расширение;
	ПараметрыФайла.Автор                       = Пользователи.АвторизованныйПользователь();
	ПараметрыФайла.ВремяИзмененияУниверсальное = ТекущаяУниверсальнаяДата();

	Попытка
		РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, АдресВХранилище);
	Исключение
		Возврат Новый Структура("Успех, Сообщение", Ложь,
			СтрШаблон(НСтр("ru='Не удалось приложить файл к КП: %1';uk='Не вдалося приєднати файл до КП: %1'"),
				ОписаниеОшибки()));
	КонецПопытки;

	Возврат Новый Структура("Успех, Сообщение", Истина,
		СтрШаблон(НСтр("ru='Файл ""%1.%2"" приложен к КП';uk='Файл ""%1.%2"" приєднано до КП'"),
			ИмяБезРасширения, Расширение));

КонецФункции

// Существует ли в каталоге хотя бы один ВариантКомплектации (рецепт) у указанного kit'а.
// Без рецепта УТ-форма «Изменить набор» (DataProcessor.РедактированиеНабора:102)
// выбрасывает «Состав набора не определен». Используем для развилки в pre-pass.
&НаСервереБезКонтекста
Функция КитИмеетРецепт(КитСсылка)
	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1 1 КАК Существует
		|ИЗ Справочник.ВариантыКомплектацииНоменклатуры
		|ГДЕ Владелец = &Кит");
	Запрос.УстановитьПараметр("Кит", КитСсылка);
	Возврат НЕ Запрос.Выполнить().Пустой();
КонецФункции

// Добавляет компонент в массив пред-заполнения варианта комплектации, объединяя
// дубликаты по паре (Номенклатура, Характеристика) сложением Количество. Это
// нужно потому, что в Isomat одна и та же компонента может встречаться несколько
// раз (например, артикул 244459 дважды в секции 395730), и УТ ожидает один
// рядок в Товары на пару.
//
// КитSumQty — кол-во из Isomat-kit-summary (col H) для этой секции. Если main_qty
// делится на КитSumQty без остатка, recipe_qty = main_qty / КитSumQty (корректный
// per-set qty: 22/22=1, 44/22=2). Иначе recipe_qty = main_qty (пользователь
// поправит вручную в форме).
&НаСервереБезКонтекста
Процедура ДобавитьКомпонентВПреЗаполнение(КомпонентыМассив, Номенклатура, Характеристика, MainQty, КитSumQty)

	// Расчёт recipe_qty
	Если КитSumQty > 0 И MainQty % КитSumQty = 0 Тогда
		RecipeQty = MainQty / КитSumQty;
	Иначе
		RecipeQty = MainQty;
	КонецЕсли;

	// Поиск существующей пары — слить qty
	Для Каждого Сущ Из КомпонентыМассив Цикл
		Если Сущ.Номенклатура = Номенклатура И Сущ.Характеристика = Характеристика Тогда
			Сущ.Количество = Сущ.Количество + RecipeQty;
			Возврат;
		КонецЕсли;
	КонецЦикла;

	НовКомп = Новый Структура("Номенклатура, Характеристика, Количество",
		Номенклатура, Характеристика, RecipeQty);
	КомпонентыМассив.Добавить(НовКомп);

КонецПроцедуры

// Найти kit-номенклатуру по базовому артикулу через доп.реквизит "Базовая номенклатура".
// 0 → null + warn; 1 → возвращаем; >1 → берём первого с warn-листом кандидатов.
&НаСервереБезКонтекста
Функция НайтиКитПоБазе(БазовыйАртикул, СвойствоБазоваяНоменклатура, Результат)

	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 5
		|	Хм.Ссылка     КАК Ссылка,
		|	Хм.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Номенклатура КАК Хм
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК Доп
		|			ПО Доп.Ссылка = Хм.Ссылка
		|ГДЕ
		|	Хм.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Набор)
		|	И Доп.Свойство = &Свойство
		|	И ВЫРАЗИТЬ(Доп.Значение КАК Справочник.Номенклатура).Артикул = &Артикул
		|УПОРЯДОЧИТЬ ПО
		|	Хм.Наименование");
	Запрос.УстановитьПараметр("Свойство", СвойствоБазоваяНоменклатура);
	Запрос.УстановитьПараметр("Артикул", БазовыйАртикул);
	Кандидаты = Запрос.Выполнить().Выгрузить();

	Если Кандидаты.Количество() = 0 Тогда
		ДобавитьСообщение(Результат, СтрШаблон(
			НСтр("ru='Набір для базового артикула %1 не знайдений у каталозі — секцію Isomat пропущено.';"
				+ "uk='Набір для базового артикула %1 не знайдений у каталозі — секцію Isomat пропущено.'"),
			БазовыйАртикул));
		Возврат Неопределено;
	КонецЕсли;

	Если Кандидаты.Количество() > 1 Тогда
		Имена = Новый Массив;
		Для Каждого Канд Из Кандидаты Цикл
			Имена.Добавить(Строка(Канд.Наименование));
		КонецЦикла;
		ДобавитьСообщение(Результат, СтрШаблон(
			НСтр("ru='Для базового артикула %1 знайдено декілька наборів: %2 — взято першого.';"
				+ "uk='Для базового артикула %1 знайдено декілька наборів: %2 — взято першого.'"),
			БазовыйАртикул, СтрСоединить(Имена, ", ")), Истина);
	КонецЕсли;

	Возврат Кандидаты[0].Ссылка;
КонецФункции

// Витягує основний артикул, відрізаючи альтернативу у дужках та переноси рядків.
// Приклади:
//   "277049\n  (277048)"  → "277049"   (числовий артикул з альтернативою)
//   "V10-1113600-UDC03"   → "V10-1113600-UDC03" (alphanumeric SKU без обрізання)
//   "395720\n(395730)"    → "395720"
// Працює агностично щодо формату — не вимагає, щоб артикул був суто цифровим.
&НаСервереБезКонтекста
Функция ИзвлечьОсновнойАртикул(АртикулСырой)
	Если ПустаяСтрока(АртикулСырой) Тогда
		Возврат "";
	КонецЕсли;
	Очищ = СокрЛП(АртикулСырой);

	// Альтернатива у дужках "X (Y)" / "X\n(Y)" — беремо до '('.
	ПозДужки = СтрНайти(Очищ, "(");
	Если ПозДужки > 0 Тогда
		Очищ = СокрЛП(Лев(Очищ, ПозДужки - 1));
	КонецЕсли;

	// Перенос рядка — беремо до нього (на випадок, якщо альтернативи у дужках немає).
	ПозПС = СтрНайти(Очищ, Символы.ПС);
	Если ПозПС > 0 Тогда
		Очищ = СокрЛП(Лев(Очищ, ПозПС - 1));
	КонецЕсли;

	Возврат Очищ;
КонецФункции

// Нормализует код цвета "11  7016" → "117016" для устойчивого матча между Isomat и main-листом.
// Удаляет пробелы и переводит в верхний регистр; пустая строка / "0" / "МЕХ." считаются
// одним и тем же "пусто".
&НаСервереБезКонтекста
Функция НормализоватьЦветДляМатча(КодЦвета)
	Очищ = ВРег(СокрЛП(КодЦвета));
	Если Очищ = "0" ИЛИ Очищ = "МЕХ." Тогда
		Очищ = "";
	КонецЕсли;
	Возврат СтрЗаменить(Очищ, " ", "");
КонецФункции

#КонецОбласти
