
&НаКлиенте
Процедура ПутьКФайлуНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ДиалогВыбора = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбора.Фильтр = "Excel (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*";
	ДиалогВыбора.Заголовок = НСтр("uk='Оберіть файл специфікації Schücal'");
	Если ДиалогВыбора.Выбрать() Тогда
		ПутьКФайлу = ДиалогВыбора.ПолноеИмяФайла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанные(Команда)

	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
		ПоказатьПредупреждение(, НСтр("uk='Вкажіть шлях до файлу'"));
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(СсылкаНаДокумент) Тогда
		ПоказатьПредупреждение(, НСтр("uk='Оберіть документ Комерційна пропозиція'"));
		Возврат;
	КонецЕсли;

	КоличествоОбработано = 0;
	КоличествоЗагружено = 0;
	КоличествоНеНайдено = 0;
	КоличествоОшибок = 0;
	СтатусВыполнения = НСтр("uk='Завантаження...'");

	Результат = ЗагрузитьДанныеНаСервере(ПутьКФайлу, СсылкаНаДокумент, РежимДодавання,
		НомерСтрокиЗаголовка, НомерПервойСтрокиДанных, НомерПоследнейСтроки);

	КоличествоОбработано = Результат.Обработано;
	КоличествоЗагружено = Результат.Загружено;
	КоличествоНеНайдено = Результат.НеНайдено;
	КоличествоОшибок = Результат.Ошибок;
	СтатусВыполнения = Результат.Сообщение;

	ОповеститьОбИзменении(СсылкаНаДокумент);

КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗагрузитьДанныеНаСервере(ПутьКФайлу, СсылкаНаДокумент, РежимДодавання,
	НомерСтрокиЗаголовка, НомерПервойСтрокиДанных, НомерПоследнейСтроки)

	Результат = Новый Структура("Обработано, Загружено, НеНайдено, Ошибок, Сообщение", 0, 0, 0, 0, "");

	// 1. Прочитать Excel (первый лист)
	Попытка
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ПутьКФайлу);
	Исключение
		Результат.Сообщение = НСтр("uk='Помилка читання файлу: '") + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;

	ПерваяСтрока = ?(НомерПервойСтрокиДанных > 0, НомерПервойСтрокиДанных, 11);
	ПоследняяСтрока = ?(НомерПоследнейСтроки > 0, НомерПоследнейСтроки, ТабДок.ВысотаТаблицы);

	// 2. Собрать массив артикулов из файла для batch-запроса
	МассивАртикулов = Новый Массив;
	Для НомерСтроки = ПерваяСтрока По ПоследняяСтрока Цикл
		МатериалНо = СокрЛП(ТабДок.Область(НомерСтроки, 1).Текст);
		Если ЗначениеЗаполнено(МатериалНо) И ЭтоЧисловойАртикул(МатериалНо) Тогда
			МассивАртикулов.Добавить(МатериалНо);
		КонецЕсли;
	КонецЦикла;

	Если МассивАртикулов.Количество() = 0 Тогда
		Результат.Сообщение = НСтр("uk='У файлі не знайдено валідних артикулів'");
		Возврат Результат;
	КонецЕсли;

	// 3. Batch-запрос Номенклатура по артикулам
	КэшНоменклатуры = Новый Соответствие;
	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Ссылка, Артикул, ЕдиницаИзмерения, СтавкаНДС
		|ИЗ
		|	Справочник.Номенклатура
		|ГДЕ
		|	Артикул В (&МасивАртикулов)");
	Запрос.УстановитьПараметр("МасивАртикулов", МассивАртикулов);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДанныеНоменклатуры = Новый Структура("Ссылка, ЕдиницаИзмерения, СтавкаНДС");
		ДанныеНоменклатуры.Ссылка = Выборка.Ссылка;
		ДанныеНоменклатуры.ЕдиницаИзмерения = Выборка.ЕдиницаИзмерения;
		ДанныеНоменклатуры.СтавкаНДС = Выборка.СтавкаНДС;
		КэшНоменклатуры.Вставить(СокрЛП(Выборка.Артикул), ДанныеНоменклатуры);
	КонецЦикла;

	// 4. Получить объект КП и (опционально) очистить Товары
	ДокОбъект = СсылкаНаДокумент.ПолучитьОбъект();
	Если НЕ РежимДодавання Тогда
		ДокОбъект.Товары.Очистить();
	КонецЕсли;

	ЦенаВключаетНДС = Ложь;
	Попытка
		ЦенаВключаетНДС = ДокОбъект.ЦенаВключаетНДС;
	Исключение
	КонецПопытки;

	// 5. Обработка строк
	Для НомерСтроки = ПерваяСтрока По ПоследняяСтрока Цикл

		МатериалНо    = СокрЛП(ТабДок.Область(НомерСтроки, 1).Текст);  // A
		Описание      = СокрЛП(ТабДок.Область(НомерСтроки, 2).Текст);  // B
		КодЦвета      = СокрЛП(ТабДок.Область(НомерСтроки, 4).Текст);  // D
		ЦенаТекст     = ТабДок.Область(НомерСтроки, 5).Текст;          // E
		КоличествоТекст = ТабДок.Область(НомерСтроки, 9).Текст;        // I

		// Фильтрация: пустой / нечисловой / служебный
		Если НЕ ЗначениеЗаполнено(МатериалНо) Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ ЭтоЧисловойАртикул(МатериалНо) Тогда
			Продолжить; // категория, заголовок и т.д.
		КонецЕсли;
		ВРегОписание = ВРег(Описание);
		Если СтрНайти(ВРегОписание, "СУМА") > 0 Или СтрНайти(ВРегОписание, "ИТОГО") > 0
			Или СтрНайти(ВРегОписание, "TOTAL") > 0 Тогда
			Продолжить;
		КонецЕсли;

		Результат.Обработано = Результат.Обработано + 1;

		Количество = СтрокаВЧисло(КоличествоТекст);
		Если Количество = 0 Тогда
			Продолжить; // нет количества — не загружаем
		КонецЕсли;

		ДанныеНоменклатуры = КэшНоменклатуры.Получить(МатериалНо);
		Если ДанныеНоменклатуры = Неопределено Тогда
			Результат.НеНайдено = Результат.НеНайдено + 1;
			Если Результат.НеНайдено <= 20 Тогда
				Сообщить(НСтр("uk='Не знайдено артикул: '") + МатериалНо);
			КонецЕсли;
			Продолжить;
		КонецЕсли;

		Цена = СтрокаВЧисло(ЦенаТекст);
		Сумма = Количество * Цена;

		ИнформацияОЦвете = РазобратьКодЦвета(КодЦвета);

		Попытка
			СтрокаТЧ = ДокОбъект.Товары.Добавить();
			СтрокаТЧ.Номенклатура = ДанныеНоменклатуры.Ссылка;
			СтрокаТЧ.ЕдиницаИзмерения = ДанныеНоменклатуры.ЕдиницаИзмерения;
			СтрокаТЧ.Количество = Количество;
			СтрокаТЧ.Цена = Цена;
			СтрокаТЧ.Сумма = Сумма;

			// НДС
			СтавкаНДС = ДанныеНоменклатуры.СтавкаНДС;
			Если ЗначениеЗаполнено(СтавкаНДС) Тогда
				СтрокаТЧ.СтавкаНДС = СтавкаНДС;
				ПроцентНДС = ПолучитьПроцентНДС(СтавкаНДС);
				Если ЦенаВключаетНДС Тогда
					СтрокаТЧ.СуммаНДС = Сумма - Сумма / (1 + ПроцентНДС / 100);
					СтрокаТЧ.СуммаСНДС = Сумма;
				Иначе
					СтрокаТЧ.СуммаНДС = Сумма * ПроцентНДС / 100;
					СтрокаТЧ.СуммаСНДС = Сумма + СтрокаТЧ.СуммаНДС;
				КонецЕсли;
			Иначе
				СтрокаТЧ.СуммаНДС = 0;
				СтрокаТЧ.СуммаСНДС = Сумма;
			КонецЕсли;

			СтрокаТЧ.ТекстовоеОписание = Описание;
			Если ЗначениеЗаполнено(ИнформацияОЦвете) Тогда
				СтрокаТЧ.КомментарийВнутренний = ИнформацияОЦвете;
			КонецЕсли;
			СтрокаТЧ.Активность = Истина;

			Результат.Загружено = Результат.Загружено + 1;
		Исключение
			Результат.Ошибок = Результат.Ошибок + 1;
			Если Результат.Ошибок <= 10 Тогда
				Сообщить(НСтр("uk='Помилка рядок '") + НомерСтроки + " (" + МатериалНо + "): " + ОписаниеОшибки());
			КонецЕсли;
		КонецПопытки;

	КонецЦикла;

	// 6. Записать документ
	Попытка
		ДокОбъект.ОбменДанными.Загрузка = Истина;
		ДокОбъект.Записать();
	Исключение
		Результат.Сообщение = НСтр("uk='Помилка запису документа: '") + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;

	Результат.Сообщение = НСтр("uk='Завершено'") + ". "
		+ НСтр("uk='Оброблено: '") + Результат.Обработано + ", "
		+ НСтр("uk='Завантажено: '") + Результат.Загружено + ", "
		+ НСтр("uk='Не знайдено: '") + Результат.НеНайдено + ", "
		+ НСтр("uk='Помилок: '") + Результат.Ошибок;

	Возврат Результат;

КонецФункции

&НаСервереБезКонтекста
Функция ЭтоЧисловойАртикул(Стр)
	// Артикул считается валидным если состоит только из цифр и пробелов и содержит хотя бы одну цифру
	Очищенная = СтрЗаменить(СокрЛП(Стр), " ", "");
	Если ПустаяСтрока(Очищенная) Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Поз = 1 По СтрДлина(Очищенная) Цикл
		Симв = Сред(Очищенная, Поз, 1);
		Если СтрНайти("0123456789", Симв) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

&НаСервереБезКонтекста
Функция РазобратьКодЦвета(КодЦвета)
	// "11 7005" -> "RAL 7005, порошкове покриття"
	// "0" / "" / "мех." -> ""
	КодОчищенный = СокрЛП(КодЦвета);
	Если ПустаяСтрока(КодОчищенный) Или КодОчищенный = "0" Или ВРег(КодОчищенный) = "МЕХ." Тогда
		Возврат "";
	КонецЕсли;
	Части = СтрРазделить(КодОчищенный, " ", Ложь);
	Если Части.Количество() >= 2 Тогда
		ТипПокриття = Части[0];
		КодRAL = Части[1];
		ТекстПокриття = ?(ТипПокриття = "11", "порошкове покриття", "тип " + ТипПокриття);
		Возврат "RAL " + КодRAL + ", " + ТекстПокриття;
	Иначе
		Возврат КодОчищенный;
	КонецЕсли;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьПроцентНДС(СтавкаНДС)
	Если СтавкаНДС = Перечисления.СтавкиНДС.НДС20 Тогда
		Возврат 20;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС7 Тогда
		Возврат 7;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС14 Тогда
		Возврат 14;
	КонецЕсли;
	Возврат 0;
КонецФункции

&НаСервереБезКонтекста
Функция СтрокаВЧисло(Стр)
	Попытка
		Стр = СокрЛП(Стр);
		Если ПустаяСтрока(Стр) Тогда
			Возврат 0;
		КонецЕсли;
		Стр = СтрЗаменить(Стр, ",", ".");
		Стр = СтрЗаменить(Стр, " ", "");
		Возврат Число(Стр);
	Исключение
		Возврат 0;
	КонецПопытки;
КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	НомерСтрокиЗаголовка = 10;
	НомерПервойСтрокиДанных = 11;
	НомерПоследнейСтроки = 0;
	РежимДодавання = Ложь;
КонецПроцедуры
