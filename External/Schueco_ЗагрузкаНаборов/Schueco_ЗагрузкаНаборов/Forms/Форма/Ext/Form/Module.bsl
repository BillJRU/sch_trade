
&НаКлиенте
Процедура ПутьКФайлуНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ДиалогВыбора = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбора.Фильтр = "Excel (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*";
	ДиалогВыбора.Заголовок = НСтр("ru='Выберите Excel с наборами';uk='Оберіть Excel з наборами'");
	Если ДиалогВыбора.Выбрать() Тогда
		ПутьКФайлу = ДиалогВыбора.ПолноеИмяФайла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанные(Команда)

	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Укажите путь к файлу';uk='Вкажіть шлях до файлу'"));
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Укажите вид номенклатуры';uk='Вкажіть вид номенклатури'"));
		Возврат;
	КонецЕсли;

	Если НЕ ВидНоменклатурыИмеетТипНабор(ВидНоменклатуры) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Выбранный ВидНоменклатуры не имеет ТипНоменклатуры=Набор. Тип будет принудительно установлен в Набор.';uk='Обраний ВидНоменклатури не має ТипНоменклатури=Набір. Тип буде примусово встановлено в Набір.'"));
	КонецЕсли;

	КоличествоОбработано = 0;
	КоличествоСоздано = 0;
	КоличествоОбновлено = 0;
	КоличествоОшибок = 0;
	СообщениеСтатуса = НСтр("ru='Загрузка...';uk='Завантаження...'");

	Результат = ЗагрузитьДанныеНаСервере(ПутьКФайлу, ВидНоменклатуры,
		РодительНоменклатуры, Производитель, РежимОбновления, НомерПервойСтроки, НомерПоследнейСтроки,
		ДопРекв_НаименованиеEN, ДопРекв_MS, ДопРекв_VS, ДопРекв_WS,
		ДопРекв_ПлощадьПолир, ДопРекв_ИндикаторПрограммы, ДопРекв_БазоваяНоменклатура,
		ЕИ_M, ЕИ_ST, ЕИ_PAK, ЕИ_PAA, ЕИ_KG, ЕИ_M2, ЕИ_ШТАНГА);

	КоличествоОбработано = Результат.Обработано;
	КоличествоСоздано = Результат.Создано;
	КоличествоОбновлено = Результат.Обновлено;
	КоличествоОшибок = Результат.Ошибок;
	СообщениеСтатуса = Результат.Сообщение;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ВидНоменклатурыИмеетТипНабор(ВидНоменклатуры)

	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1 ТипНоменклатуры
		|ИЗ Справочник.ВидыНоменклатуры
		|ГДЕ Ссылка = &Ссылка");
	Запрос.УстановитьПараметр("Ссылка", ВидНоменклатуры);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Набор;
	КонецЕсли;
	Возврат Ложь;

КонецФункции

&НаСервереБезКонтекста
Функция ЗагрузитьДанныеНаСервере(ПутьКФайлу, ВидНоменклатуры,
	РодительНоменклатуры, Производитель, РежимОбновления, НомерПервойСтроки, НомерПоследнейСтроки,
	ДопРекв_НаименованиеEN, ДопРекв_MS, ДопРекв_VS, ДопРекв_WS,
	ДопРекв_ПлощадьПолир, ДопРекв_ИндикаторПрограммы, ДопРекв_БазоваяНоменклатура,
	ЕИ_M, ЕИ_ST, ЕИ_PAK, ЕИ_PAA, ЕИ_KG, ЕИ_M2, ЕИ_ШТАНГА)

	Результат = Новый Структура("Обработано, Создано, Обновлено, Ошибок, Сообщение", 0, 0, 0, 0, "");

	// 1. Прочитать Excel
	Попытка
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ПутьКФайлу);
	Исключение
		Результат.Сообщение = НСтр("ru='Ошибка чтения файла: ';uk='Помилка читання файлу: '") + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;

	ПерваяСтрока = ?(НомерПервойСтроки > 0, НомерПервойСтроки, 2);
	ПоследняяСтрока = ?(НомерПоследнейСтроки > 0, НомерПоследнейСтроки, ТабДок.ВысотаТаблицы);

	// 2. Подготовить кэши справочников
	// ЕИ — из выбранных на форме ссылок
	КэшЕИ = Новый Соответствие;
	КэшЕИ.Вставить("M", ЕИ_M);
	КэшЕИ.Вставить("ST", ЕИ_ST);
	КэшЕИ.Вставить("PAK", ЕИ_PAK);
	КэшЕИ.Вставить("PAA", ЕИ_PAA);
	КэшЕИ.Вставить("KG", ЕИ_KG);
	КэшЕИ.Вставить("M2", ЕИ_M2);
	// Набор известных кодов для проверки неизвестных ОВ
	ИзвестныеКодыЕИ = Новый Соответствие;
	ИзвестныеКодыЕИ.Вставить("M", Истина);
	ИзвестныеКодыЕИ.Вставить("ST", Истина);
	ИзвестныеКодыЕИ.Вставить("PAK", Истина);
	ИзвестныеКодыЕИ.Вставить("PAA", Истина);
	ИзвестныеКодыЕИ.Вставить("KG", Истина);
	НеизвестныеЕИ = Новый Соответствие; // для предупреждений (не повторять)

	КэшЦеновыхГрупп = Новый Соответствие;

	Запрос = Новый Запрос("ВЫБРАТЬ Ссылка, Наименование ИЗ Справочник.ЦеновыеГруппы");
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		КэшЦеновыхГрупп.Вставить(СокрЛП(Выборка.Наименование), Выборка.Ссылка);
	КонецЦикла;

	// Кэш базовых номенклатур по колонке D (поиск по Артикулу без префикса "М")
	КэшОснов = Новый Соответствие;
	НеизвестныеОсновы = Новый Соответствие;

	// 3. Обработка строк
	Для НомерСтроки = ПерваяСтрока По ПоследняяСтрока Цикл

		АртикулНабора   = СокрЛП(ТабДок.Область(НомерСтроки, 1).Текст);  // A - Item relation (Мxxx)
		АртикулБазового = СокрЛП(ТабДок.Область(НомерСтроки, 4).Текст);  // D - Material no (без префикса М)
		НаименованиеDE  = СокрЛП(ТабДок.Область(НомерСтроки, 5).Текст);  // E
		НаименованиеEN  = СокрЛП(ТабДок.Область(НомерСтроки, 6).Текст);  // F
		ЕдИзмКод        = СокрЛП(ТабДок.Область(НомерСтроки, 7).Текст);  // G
		MS              = СокрЛП(ТабДок.Область(НомерСтроки, 8).Текст);  // H
		VS              = СокрЛП(ТабДок.Область(НомерСтроки, 9).Текст);  // I
		WS              = СокрЛП(ТабДок.Область(НомерСтроки, 10).Текст); // J
		ВесБрутто       = ТабДок.Область(НомерСтроки, 11).Текст;         // K
		ДлинаМ          = ТабДок.Область(НомерСтроки, 13).Текст;         // M - Length in m
		КоличествоВПак  = ТабДок.Область(НомерСтроки, 14).Текст;         // N - Quantity in pcs
		КоличествоВПаре = ТабДок.Область(НомерСтроки, 15).Текст;         // O - Quantity in pair
		ПлощадьПолир    = ТабДок.Область(НомерСтроки, 16).Текст;         // P
		ПлощадьОкруж    = ТабДок.Область(НомерСтроки, 17).Текст;         // Q
		ProgInd         = СокрЛП(ТабДок.Область(НомерСтроки, 18).Текст); // R
		ГруппаСкидки    = СокрЛП(ТабДок.Область(НомерСтроки, 19).Текст); // S
		КодТарифа       = СокрЛП(ТабДок.Область(НомерСтроки, 24).Текст); // X
		ЕдИзмПродаж     = СокрЛП(ТабДок.Область(НомерСтроки, 25).Текст); // Y - sales unit
		НаименованиеУК  = СокрЛП(ТабДок.Область(НомерСтроки, 26).Текст); // Z - Ukrainian name

		Если НЕ ЗначениеЗаполнено(АртикулНабора) Тогда
			Продолжить;
		КонецЕсли;

		Результат.Обработано = Результат.Обработано + 1;

		НачатьТранзакцию();
		Попытка

			// Проверка дубликата по Артикул
			ЗапросДубль = Новый Запрос(
				"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Номенклатура ГДЕ Артикул = &Артикул");
			ЗапросДубль.УстановитьПараметр("Артикул", АртикулНабора);
			ВыборкаДубль = ЗапросДубль.Выполнить().Выбрать();

			ЭтоОбновление = Ложь;
			ПропуститьОбновлениеПолей = Ложь;
			Если ВыборкаДубль.Следующий() Тогда
				НовыйОбъект = ВыборкаДубль.Ссылка.ПолучитьОбъект();
				ЭтоОбновление = Истина;
				Если НЕ РежимОбновления Тогда
					// Поля набора не трогаем, но всё равно дойдём до side-effect блоков
					// (создание/обновление ВариантаКомплектации) — это backfill для уже загруженных наборов.
					ПропуститьОбновлениеПолей = Истина;
				КонецЕсли;
			Иначе
				НовыйОбъект = Справочники.Номенклатура.СоздатьЭлемент();
			КонецЕсли;

			// Поиск базовой номенклатуры (по Артикулу из колонки D) — нужен и для back-link, и для
			// последующего создания ВариантаКомплектации. Вычисляем всегда, чтобы и backfill работал.
			СсылкаОсновы = Справочники.Номенклатура.ПустаяСсылка();
			Если ЗначениеЗаполнено(АртикулБазового) Тогда
				ОснКлюч = ВРег(АртикулБазового);
				КэшированноеЗначение = КэшОснов.Получить(ОснКлюч);
				Если КэшированноеЗначение = Неопределено Тогда
					ЗапросОсн = Новый Запрос(
						"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Номенклатура ГДЕ Артикул = &Артикул");
					ЗапросОсн.УстановитьПараметр("Артикул", АртикулБазового);
					ВыбОсн = ЗапросОсн.Выполнить().Выбрать();
					Если ВыбОсн.Следующий() Тогда
						СсылкаОсновы = ВыбОсн.Ссылка;
					Иначе
						Если НеизвестныеОсновы.Получить(ОснКлюч) = Неопределено Тогда
							Сообщить(НСтр("ru='Базовая номенклатура не найдена по Артикулу ';uk='Базова номенклатура не знайдена за Артикулом '") + АртикулБазового);
							НеизвестныеОсновы.Вставить(ОснКлюч, Истина);
						КонецЕсли;
					КонецЕсли;
					КэшОснов.Вставить(ОснКлюч, СсылкаОсновы);
				Иначе
					СсылкаОсновы = КэшированноеЗначение;
				КонецЕсли;
			КонецЕсли;

			Если НЕ ПропуститьОбновлениеПолей Тогда

				// ВидНоменклатуры + принудительный ТипНоменклатуры = Набор
				НовыйОбъект.ВидНоменклатуры = ВидНоменклатуры;
				Справочники.Номенклатура.ЗаполнитьРеквизитыПоВидуНоменклатуры(НовыйОбъект);
				НовыйОбъект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Набор;

				// Основные реквизиты (ПОСЛЕ заполнения по виду — наши значения перезаписывают дефолтные)
				НовыйОбъект.Наименование = Лев(НаименованиеDE, 100);
				НовыйОбъект.НаименованиеПолное = ?(ЗначениеЗаполнено(НаименованиеУК), НаименованиеУК, НаименованиеDE);
				НовыйОбъект.Артикул = АртикулНабора;

				Если ЗначениеЗаполнено(РодительНоменклатуры) Тогда
					НовыйОбъект.Родитель = РодительНоменклатуры;
				КонецЕсли;

				Если ЗначениеЗаполнено(Производитель) Тогда
					НовыйОбъект.Производитель = Производитель;
				КонецЕсли;

				// Единица измерения — базовая (колонка G)
				КодЕИХран = ВРег(ЕдИзмКод);
				ЕдИзм = КэшЕИ.Получить(КодЕИХран);
				Если ЕдИзм <> Неопределено И ЗначениеЗаполнено(ЕдИзм) Тогда
					НовыйОбъект.ЕдиницаИзмерения = ЕдИзм;
				ИначеЕсли ЗначениеЗаполнено(КодЕИХран) И ИзвестныеКодыЕИ.Получить(КодЕИХран) = Неопределено Тогда
					Если НеизвестныеЕИ.Получить(КодЕИХран) = Неопределено Тогда
						Сообщить("Невідомий код ОВ """ + КодЕИХран + """ (арт. " + АртикулНабора + "). Додайте відповідне поле на формі.");
						НеизвестныеЕИ.Вставить(КодЕИХран, Истина);
					КонецЕсли;
				КонецЕсли;

				// Вес (кол K)
				ВесЧисло = СтрокаВЧисло(ВесБрутто);
				Если ВесЧисло > 0 Тогда
					НовыйОбъект.ВесИспользовать = Истина;
					НовыйОбъект.ВесЧислитель = ВесЧисло;
					НовыйОбъект.ВесЗнаменатель = 1;
					Если ЕИ_KG <> Неопределено Тогда
						НовыйОбъект.ВесЕдиницаИзмерения = ЕИ_KG;
					КонецЕсли;
				КонецЕсли;

				// Длина (кол M)
				ДлинаЧисло = СтрокаВЧисло(ДлинаМ);
				Если ДлинаЧисло > 0 Тогда
					НовыйОбъект.ДлинаИспользовать = Истина;
					НовыйОбъект.ДлинаЧислитель = ДлинаЧисло;
					НовыйОбъект.ДлинаЗнаменатель = 1;
					НовыйОбъект.ДлинаМожноУказыватьВДокументах = Истина;
					Если ЗначениеЗаполнено(ЕИ_M) Тогда
						НовыйОбъект.ДлинаЕдиницаИзмерения = ЕИ_M;
					КонецЕсли;
				КонецЕсли;

				// Площадь окружности (кол Q) → нативное поле Площадь
				// Значение в ULF/м (1000 ULF = 1 м²): 341 ULF/м = 0.341 м²/м
				ПлощадьОкружЧисло = СтрокаВЧисло(ПлощадьОкруж);
				Если ПлощадьОкружЧисло > 0 Тогда
					НовыйОбъект.ПлощадьИспользовать = Истина;
					НовыйОбъект.ПлощадьЧислитель = ПлощадьОкружЧисло / 1000;
					НовыйОбъект.ПлощадьЗнаменатель = 1;
					Если ЗначениеЗаполнено(ЕИ_M2) Тогда
						НовыйОбъект.ПлощадьЕдиницаИзмерения = ЕИ_M2;
					КонецЕсли;
				КонецЕсли;

				// Ценовая группа (кол S)
				Если ЗначениеЗаполнено(ГруппаСкидки) Тогда
					ЦеноваяГруппа = КэшЦеновыхГрупп.Получить(ГруппаСкидки);
					Если ЦеноваяГруппа = Неопределено Тогда
						НоваяГруппа = Справочники.ЦеновыеГруппы.СоздатьЭлемент();
						НоваяГруппа.Наименование = ГруппаСкидки;
						НоваяГруппа.Записать();
						ЦеноваяГруппа = НоваяГруппа.Ссылка;
						КэшЦеновыхГрупп.Вставить(ГруппаСкидки, ЦеноваяГруппа);
					КонецЕсли;
					НовыйОбъект.ЦеноваяГруппа = ЦеноваяГруппа;
				КонецЕсли;

				// Дополнительные реквизиты (из выбранных на форме ссылок на ПВХ)
				НовыйОбъект.ДополнительныеРеквизиты.Очистить();

				ДобавитьДопРеквизитПоСсылке(НовыйОбъект, ДопРекв_НаименованиеEN, НаименованиеEN);
				ДобавитьДопРеквизитПоСсылке(НовыйОбъект, ДопРекв_MS, MS);
				ДобавитьДопРеквизитПоСсылке(НовыйОбъект, ДопРекв_VS, VS);
				ДобавитьДопРеквизитПоСсылке(НовыйОбъект, ДопРекв_WS, WS);
				ДобавитьДопРеквизитПоСсылке(НовыйОбъект, ДопРекв_ИндикаторПрограммы, ProgInd);

				// Обратная ссылка на базовую номенклатуру — пишем в ДопРеквизиты, если основа найдена.
				Если ЗначениеЗаполнено(ДопРекв_БазоваяНоменклатура) И ЗначениеЗаполнено(СсылкаОсновы) Тогда
					Стр = НовыйОбъект.ДополнительныеРеквизиты.Добавить();
					Стр.Свойство = ДопРекв_БазоваяНоменклатура;
					Стр.Значение = СсылкаОсновы;
				КонецЕсли;

				// Площадь полировки (кол P) — значение в ULF, конвертируем / 1000
				ПлощадьПолирЧисло = СтрокаВЧисло(ПлощадьПолир);
				Если ПлощадьПолирЧисло > 0 И ЗначениеЗаполнено(ДопРекв_ПлощадьПолир) Тогда
					Стр = НовыйОбъект.ДополнительныеРеквизиты.Добавить();
					Стр.Свойство = ДопРекв_ПлощадьПолир;
					Стр.Значение = ПлощадьПолирЧисло / 1000;
				КонецЕсли;

				КоличествоВПакЧисло = СтрокаВЧисло(КоличествоВПак);

				// Записать (ОбменДанными.Загрузка = Истина — пропустить ПередЗаписью,
				// т.к. ЗаполнитьРеквизитыПоВидуНоменклатуры уже вызван выше)
				НовыйОбъект.ОбменДанными.Загрузка = Истина;
				Если НЕ ЭтоОбновление Тогда
					НовыйОбъект.УстановитьНовыйКод();
				КонецЕсли;
				НовыйОбъект.Записать();
				Если ЭтоОбновление Тогда
					Результат.Обновлено = Результат.Обновлено + 1;
				Иначе
					Результат.Создано = Результат.Создано + 1;
				КонецЕсли;

				// НоменклатураГТД (кол X) — подчинённый справочник
				Если ЗначениеЗаполнено(КодТарифа) Тогда
					СоздатьНоменклатуруГТД(НовыйОбъект.Ссылка, КодТарифа);
				КонецЕсли;

				// Упаковка — PAK, PAA (розупаковка) або штанга (кінцева)
				КодЕИВРег = ВРег(ЕдИзмКод);
				СтворитиУпаковку = Ложь;
				ЕИУпаковки = Неопределено;
				ЧислитьУп = 0;
				ЗнаменатьУп = 0;
				ТипУп = Неопределено;
				НазваУп = "";
				Если КоличествоВПакЧисло > 0 Тогда
					Если КодЕИВРег = "PAK" Тогда
						СтворитиУпаковку = Истина;
						ЕИУпаковки = ЕИ_ST;
						ЧислитьУп = 1;
						ЗнаменатьУп = КоличествоВПакЧисло;
						ТипУп = Перечисления.ТипыУпаковокНоменклатуры.Разупаковка;
						НазваУп = "шт (1/" + Формат(КоличествоВПакЧисло, "ЧГ=0") + " паков)";
					ИначеЕсли КодЕИВРег = "PAA" Тогда
						СтворитиУпаковку = Истина;
						ЕИУпаковки = ЕИ_ST;
						ЧислитьУп = 1;
						ЗнаменатьУп = КоличествоВПакЧисло;
						ТипУп = Перечисления.ТипыУпаковокНоменклатуры.Разупаковка;
						НазваУп = "шт (1/" + Формат(КоличествоВПакЧисло, "ЧГ=0") + " пар)";
					КонецЕсли;
				КонецЕсли;
				Если КодЕИВРег = "M" И ВРег(ЕдИзмПродаж) = "ST" И ДлинаЧисло > 0 И ЗначениеЗаполнено(ЕИ_ШТАНГА) Тогда
					СтворитиУпаковку = Истина;
					ЕИУпаковки = ЕИ_ШТАНГА;
					ЧислитьУп = ДлинаЧисло;
					ЗнаменатьУп = 1;
					ТипУп = Перечисления.ТипыУпаковокНоменклатуры.Конечная;
					НазваУп = "st (1/" + Формат(ДлинаЧисло, "ЧГ=0") + " м)";
				КонецЕсли;
				Если СтворитиУпаковку И ЗначениеЗаполнено(ЕИУпаковки) Тогда
					НомОбъектУпак = НовыйОбъект.Ссылка.ПолучитьОбъект();
					НомОбъектУпак.ИспользоватьУпаковки = Истина;
					НомОбъектУпак.НаборУпаковок = Справочники.НаборыУпаковок.ИндивидуальныйДляНоменклатуры;
					НомОбъектУпак.ОбменДанными.Загрузка = Истина;
					НомОбъектУпак.Записать();
					СоздатьУпаковкуШтВПак(НовыйОбъект.Ссылка, ЕИУпаковки, ЧислитьУп, ЗнаменатьУп, ТипУп, НазваУп);
				КонецЕсли;

			КонецЕсли;

			ЗафиксироватьТранзакцию();

		Исключение
			ОтменитьТранзакцию();
			Результат.Ошибок = Результат.Ошибок + 1;
			Сообщить(НСтр("ru='Ошибка';uk='Помилка'") + " " + НСтр("ru='строка';uk='рядок'") + " "
				+ НомерСтроки + " (" + НСтр("ru='арт.';uk='арт.'") + " " + АртикулНабора + "): " + ОписаниеОшибки());
		КонецПопытки;

	КонецЦикла;

	Результат.Сообщение = НСтр("ru='Завершено';uk='Завершено'") + ". "
		+ НСтр("ru='Обработано: ';uk='Оброблено: '") + Результат.Обработано + ", "
		+ НСтр("ru='Создано: ';uk='Створено: '") + Результат.Создано + ", "
		+ НСтр("ru='Обновлено: ';uk='Оновлено: '") + Результат.Обновлено + ", "
		+ НСтр("ru='Ошибок: ';uk='Помилок: '") + Результат.Ошибок;

	Возврат Результат;

КонецФункции


&НаСервереБезКонтекста
Процедура ДобавитьДопРеквизитПоСсылке(Объект, СвойствоСсылка, Значение)

	Если НЕ ЗначениеЗаполнено(СвойствоСсылка) Или НЕ ЗначениеЗаполнено(Значение) Тогда
		Возврат;
	КонецЕсли;

	НоваяСтрока = Объект.ДополнительныеРеквизиты.Добавить();
	НоваяСтрока.Свойство = СвойствоСсылка;
	НоваяСтрока.Значение = Значение;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура СоздатьНоменклатуруГТД(НоменклатураСсылка, КодТарифа)

	// Найти код в КлассификаторУКТВЭД (коды хранятся с пробелами, напр. "7604 29 90 00")
	// PL51 даёт 8-значный код без пробелов: "76042990"
	// Конвертируем в паттерн с пробелами: "76042990" → "7604 29 90%"
	КодСПробелами = Лев(КодТарифа, 4);
	Если СтрДлина(КодТарифа) > 4 Тогда
		КодСПробелами = КодСПробелами + " " + Сред(КодТарифа, 5, 2);
	КонецЕсли;
	Если СтрДлина(КодТарифа) > 6 Тогда
		КодСПробелами = КодСПробелами + " " + Сред(КодТарифа, 7, 2);
	КонецЕсли;

	ЗапросУКТ = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.КлассификаторУКТВЭД
		|ГДЕ Код ПОДОБНО &КодПаттерн");
	ЗапросУКТ.УстановитьПараметр("КодПаттерн", КодСПробелами + "%");
	ВыборкаУКТ = ЗапросУКТ.Выполнить().Выбрать();
	Если НЕ ВыборкаУКТ.Следующий() Тогда
		Сообщить("УКТЗЕД код """ + КодТарифа + """ не знайдено в класифікаторі для " + НоменклатураСсылка);
		Возврат;
	КонецЕсли;
	КодУКТВЭД = ВыборкаУКТ.Ссылка;

	// Знайти єдиний існуючий запис ГТД для цієї номенклатури або створити новий
	ЗапросГТД = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.НоменклатураГТД
		|ГДЕ Владелец = &Владелец");
	ЗапросГТД.УстановитьПараметр("Владелец", НоменклатураСсылка);
	ВыборкаГТД = ЗапросГТД.Выполнить().Выбрать();
	Если ВыборкаГТД.Следующий() Тогда
		ОбъектГТД = ВыборкаГТД.Ссылка.ПолучитьОбъект();
	Иначе
		ОбъектГТД = Справочники.НоменклатураГТД.СоздатьЭлемент();
		ОбъектГТД.Владелец = НоменклатураСсылка;
	КонецЕсли;
	ОбъектГТД.КодУКТВЭД = КодУКТВЭД;
	ОбъектГТД.Записать();

	// Привязать к номенклатуре как код по умолчанию
	НомОбъект = НоменклатураСсылка.ПолучитьОбъект();
	НомОбъект.НоменклатураГТД = ОбъектГТД.Ссылка;
	НомОбъект.ОбменДанными.Загрузка = Истина;
	НомОбъект.Записать();

КонецПроцедуры

&НаСервереБезКонтекста
Процедура СоздатьУпаковкуШтВПак(НоменклатураСсылка, ЕИ_Упаковки, Числитель, Знаменатель, ТипУпаковки, НазваУпаковки)

	// Видалити всі існуючі упаковки цієї номенклатури
	Запрос = Новый Запрос(
		"ВЫБРАТЬ Ссылка ИЗ Справочник.УпаковкиЕдиницыИзмерения
		|ГДЕ Владелец = &Владелец");
	Запрос.УстановитьПараметр("Владелец", НоменклатураСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Объект = Выборка.Ссылка.ПолучитьОбъект();
		Объект.Удалить();
	КонецЦикла;

	// Створити нову
	НоваяУпаковка = Справочники.УпаковкиЕдиницыИзмерения.СоздатьЭлемент();
	НоваяУпаковка.Владелец = НоменклатураСсылка;
	НоваяУпаковка.ЕдиницаИзмерения = ЕИ_Упаковки;
	НоваяУпаковка.Наименование = НазваУпаковки;
	НоваяУпаковка.Числитель = Числитель;
	НоваяУпаковка.Знаменатель = Знаменатель;
	НоваяУпаковка.ТипИзмеряемойВеличины = Перечисления.ТипыИзмеряемыхВеличин.Упаковка;
	НоваяУпаковка.ТипУпаковки = ТипУпаковки;
	НоваяУпаковка.Безразмерная = Истина;
	НоваяУпаковка.Записать();

КонецПроцедуры

&НаСервереБезКонтекста
Функция СтрокаВЧисло(Стр)

	Попытка
		Стр = СокрЛП(Стр);
		Если НЕ ЗначениеЗаполнено(Стр) Тогда
			Возврат 0;
		КонецЕсли;
		Стр = СтрЗаменить(Стр, ",", ".");
		Возврат Число(Стр);
	Исключение
		Возврат 0;
	КонецПопытки;

КонецФункции

&НаКлиенте
Процедура УдалитьЗагруженные(Команда)

	Если НЕ ЗначениеЗаполнено(Производитель) И НЕ ЗначениеЗаполнено(РодительНоменклатуры) И НЕ ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Укажите производителя, папку или вид номенклатуры для удаления';uk='Вкажіть виробника, папку або вид номенклатури для видалення'"));
		Возврат;
	КонецЕсли;

	ОписаниеОповещения = Новый ОписаниеОповещения("УдалитьЗагруженныеЗавершение", ЭтотОбъект);
	ПоказатьВопрос(ОписаниеОповещения,
		НСтр("ru='Удалить все элементы номенклатуры по указанному производителю/папке? Это действие необратимо!';uk='Видалити всі елементи номенклатури за вказаним виробником/папкою? Цю дію неможливо скасувати!'"),
		РежимДиалогаВопрос.ДаНет);

