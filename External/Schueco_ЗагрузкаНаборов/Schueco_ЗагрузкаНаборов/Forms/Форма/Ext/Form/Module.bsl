&НаКлиенте
Процедура УдалитьЗагруженныеЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	РезультатУдаления = УдалитьЗагруженныеНаСервере(Производитель, РодительНоменклатуры, ВидНоменклатуры);

	КоличествоОбработано = РезультатУдаления.Удалено;
	КоличествоОшибок = РезультатУдаления.Ошибок;
	КоличествоСоздано = 0;
	СообщениеСтатуса = РезультатУдаления.Сообщение;

КонецПроцедуры

&НаСервереБезКонтекста
Функция УдалитьЗагруженныеНаСервере(Производитель, РодительНоменклатуры, ВидНоменклатуры)

	Результат = Новый Структура("Удалено, Ошибок, Сообщение", 0, 0, "");

	// Построить запрос с условиями
	ТекстЗапроса =
		"ВЫБРАТЬ Ссылка
		|ИЗ Справочник.Номенклатура
		|ГДЕ НЕ ЭтоГруппа";

	Запрос = Новый Запрос;

	Если ЗначениеЗаполнено(Производитель) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		| И Производитель = &Производитель";
		Запрос.УстановитьПараметр("Производитель", Производитель);
	КонецЕсли;

	Если ЗначениеЗаполнено(РодительНоменклатуры) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		| И Родитель = &Родитель";
		Запрос.УстановитьПараметр("Родитель", РодительНоменклатуры);
	КонецЕсли;

	Если ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		| И ВидНоменклатуры = &ВидНоменклатуры";
		Запрос.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры);
	КонецЕсли;

	Запрос.Текст = ТекстЗапроса;
	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл

		НачатьТранзакцию();
		Попытка
			// Сначала удалить подчинённые НоменклатураГТД
			ЗапросГТД = Новый Запрос(
				"ВЫБРАТЬ Ссылка ИЗ Справочник.НоменклатураГТД ГДЕ Владелец = &Владелец");
			ЗапросГТД.УстановитьПараметр("Владелец", Выборка.Ссылка);
			ВыборкаГТД = ЗапросГТД.Выполнить().Выбрать();
			Пока ВыборкаГТД.Следующий() Цикл
				ОбъектГТД = ВыборкаГТД.Ссылка.ПолучитьОбъект();
				ОбъектГТД.Удалить();
			КонецЦикла;

			// Удалить номенклатуру
			Объект = Выборка.Ссылка.ПолучитьОбъект();
			Объект.Удалить();
			Результат.Удалено = Результат.Удалено + 1;

			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			Результат.Ошибок = Результат.Ошибок + 1;
			Сообщить(НСтр("ru='Ошибка удаления: ';uk='Помилка видалення: '") + ОписаниеОшибки());
		КонецПопытки;

	КонецЦикла;

	Результат.Сообщение = НСтр("ru='Удаление завершено';uk='Видалення завершено'") + ". "
		+ НСтр("ru='Удалено: ';uk='Видалено: '") + Результат.Удалено + ", "
		+ НСтр("ru='Ошибок: ';uk='Помилок: '") + Результат.Ошибок;

	Возврат Результат;

КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	НомерПервойСтроки = 2;
	НомерПоследнейСтроки = 0;

	// Автозаполнение ДопРеквизитов по Имя (для разработчиков)
	ПВХ = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения;
	ДопРекв_НаименованиеEN     = ПВХ.НайтиПоРеквизиту("Имя", "НаименованиеАнглийское");
	ДопРекв_MS                 = ПВХ.НайтиПоРеквизиту("Имя", "Marktsegment");
	ДопРекв_VS                 = ПВХ.НайтиПоРеквизиту("Имя", "Vertriebsschiene");
	ДопРекв_WS                 = ПВХ.НайтиПоРеквизиту("Имя", "Warengruppe");
	ДопРекв_ПлощадьПолир       = ПВХ.НайтиПоРеквизиту("Имя", "ПлощадьПолировки");
	ДопРекв_ИндикаторПрограммы = ПВХ.НайтиПоРеквизиту("Имя", "ИндикаторПрограммы");
	// ДопРекв_БазоваяНоменклатура — выбирается пользователем вручную на форме

	// Автозаполнение ОВ по наименованию из базовых единиц
	ЗапросЕИ = Новый Запрос(
		"ВЫБРАТЬ Ссылка, Наименование
		|ИЗ Справочник.УпаковкиЕдиницыИзмерения
		|ГДЕ Владелец = &Владелец");
	ЗапросЕИ.УстановитьПараметр("Владелец", Справочники.НаборыУпаковок.БазовыеЕдиницыИзмерения);
	ВыборкаЕИ = ЗапросЕИ.Выполнить().Выбрать();
	Пока ВыборкаЕИ.Следующий() Цикл
		Имя = ВРег(СокрЛП(ВыборкаЕИ.Наименование));
		Если Имя = "М" И НЕ ЗначениеЗаполнено(ЕИ_M) Тогда
			ЕИ_M = ВыборкаЕИ.Ссылка;
		ИначеЕсли Имя = "ШТ" И НЕ ЗначениеЗаполнено(ЕИ_ST) Тогда
			ЕИ_ST = ВыборкаЕИ.Ссылка;
		ИначеЕсли (Имя = "УПАК" Или Имя = "ПАКОВ" Или Имя = "ПАК") И НЕ ЗначениеЗаполнено(ЕИ_PAK) Тогда
			ЕИ_PAK = ВыборкаЕИ.Ссылка;
		ИначеЕсли Имя = "ПАР" И НЕ ЗначениеЗаполнено(ЕИ_PAA) Тогда
			ЕИ_PAA = ВыборкаЕИ.Ссылка;
		ИначеЕсли Имя = "КГ" И НЕ ЗначениеЗаполнено(ЕИ_KG) Тогда
			ЕИ_KG = ВыборкаЕИ.Ссылка;
		ИначеЕсли (Имя = "М2" Или Имя = "М²" Или Имя = "КВ.М") И НЕ ЗначениеЗаполнено(ЕИ_M2) Тогда
			ЕИ_M2 = ВыборкаЕИ.Ссылка;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
