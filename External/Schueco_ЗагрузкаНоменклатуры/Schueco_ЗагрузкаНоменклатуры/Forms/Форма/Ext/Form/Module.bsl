
&НаКлиенте
Процедура ПутьКФайлуНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ДиалогВыбора = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбора.Фильтр = "Excel (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*";
	ДиалогВыбора.Заголовок = НСтр("ru='Выберите файл прайс-листа PL51';uk='Оберіть файл прайс-листа PL51'");
	Если ДиалогВыбора.Выбрать() Тогда
		ПутьКФайлу = ДиалогВыбора.ПолноеИмяФайла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанные(Команда)

	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Укажите путь к файлу';uk='Вкажіть шлях до файлу'"));
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Укажите вид номенклатуры';uk='Вкажіть вид номенклатури'"));
		Возврат;
	КонецЕсли;

	КоличествоОбработано = 0;
	КоличествоСоздано = 0;
	КоличествоОшибок = 0;
	СообщениеСтатуса = НСтр("ru='Загрузка...';uk='Завантаження...'");

	Результат = ЗагрузитьДанныеНаСервере(ПутьКФайлу, ВидНоменклатуры, РодительНоменклатуры,
		Производитель, РежимОбновления, НомерПервойСтроки, НомерПоследнейСтроки);

	КоличествоОбработано = Результат.Обработано;
	КоличествоСоздано = Результат.Создано;
	КоличествоОшибок = Результат.Ошибок;
	СообщениеСтатуса = Результат.Сообщение;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗагрузитьДанныеНаСервере(ПутьКФайлу, ВидНоменклатуры, РодительНоменклатуры,
	Производитель, РежимОбновления, НомерПервойСтроки, НомерПоследнейСтроки)

	Результат = Новый Структура("Обработано, Создано, Ошибок, Сообщение", 0, 0, 0, "");

	// 1. Прочитать Excel
	Попытка
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ПутьКФайлу);
	Исключение
		Результат.Сообщение = НСтр("ru='Ошибка чтения файла: ';uk='Помилка читання файлу: '") + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;

	ПерваяСтрока = ?(НомерПервойСтроки > 0, НомерПервойСтроки, 2);
	ПоследняяСтрока = ?(НомерПоследнейСтроки > 0, НомерПоследнейСтроки, ТабДок.ВысотаТаблицы);

	// 2. Подготовить кэши справочников
	КэшЕИ = Новый Соответствие;
	КэшЦеновыхГрупп = Новый Соответствие;
	КэшДопРеквизитов = Новый Соответствие;

	ПодготовитьКэшЕдиницИзмерения(КэшЕИ);

	Запрос = Новый Запрос("ВЫБРАТЬ Ссылка, Наименование ИЗ Справочник.ЦеновыеГруппы");
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		КэшЦеновыхГрупп.Вставить(СокрЛП(Выборка.Наименование), Выборка.Ссылка);
	КонецЦикла;

	ПодготовитьКэшДопРеквизитов(КэшДопРеквизитов);

	ЕдиницаИзмеренияКг = КэшЕИ.Получить("KG");
	Если ЕдиницаИзмеренияКг = Неопределено Тогда
		ЕдиницаИзмеренияКг = КэшЕИ.Получить("КГ");
	КонецЕсли;

	ЕдиницаИзмеренияМ = КэшЕИ.Получить("M");
	Если ЕдиницаИзмеренияМ = Неопределено Тогда
		ЕдиницаИзмеренияМ = КэшЕИ.Получить("М");
	КонецЕсли;

	// 3. Обработка строк
	Для НомерСтроки = ПерваяСтрока По ПоследняяСтрока Цикл

		МатериалНо     = СокрЛП(ТабДок.Область(НомерСтроки, 1).Текст);  // A
		НаименованиеDE = СокрЛП(ТабДок.Область(НомерСтроки, 2).Текст);  // B
		НаименованиеEN = СокрЛП(ТабДок.Область(НомерСтроки, 3).Текст);  // C
		ЕдИзмКод       = СокрЛП(ТабДок.Область(НомерСтроки, 4).Текст);  // D
		MS              = СокрЛП(ТабДок.Область(НомерСтроки, 5).Текст);  // E
		VS              = СокрЛП(ТабДок.Область(НомерСтроки, 6).Текст);  // F
		WS              = СокрЛП(ТабДок.Область(НомерСтроки, 7).Текст);  // G
		ВесБрутто       = ТабДок.Область(НомерСтроки, 8).Текст;          // H
		ДлинаМ          = ТабДок.Область(НомерСтроки, 10).Текст;         // J
		ПлощадьПолир    = ТабДок.Область(НомерСтроки, 13).Текст;         // M
		ПлощадьОкруж    = ТабДок.Область(НомерСтроки, 14).Текст;         // N
		ProgInd         = СокрЛП(ТабДок.Область(НомерСтроки, 15).Текст); // O
		ГруппаСкидки    = СокрЛП(ТабДок.Область(НомерСтроки, 16).Текст); // P
		КодТарифа       = СокрЛП(ТабДок.Область(НомерСтроки, 21).Текст); // U
		ЕдИзмПродаж     = СокрЛП(ТабДок.Область(НомерСтроки, 22).Текст); // V - sales unit
		НаименованиеУК  = СокрЛП(ТабДок.Область(НомерСтроки, 23).Текст); // W - Ukrainian name

		// Единица хранения: продажная (V) если заполнена, иначе базовая (D)
		ЕдИзмХранения = ?(ЗначениеЗаполнено(ЕдИзмПродаж), ЕдИзмПродаж, ЕдИзмКод);

		Если НЕ ЗначениеЗаполнено(МатериалНо) Тогда
			Продолжить;
		КонецЕсли;

		Результат.Обработано = Результат.Обработано + 1;

		НачатьТранзакцию();
		Попытка

			// Проверка дубликата по Артикул
			ЗапросДубль = Новый Запрос(
				"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.Номенклатура ГДЕ Артикул = &Артикул");
			ЗапросДубль.УстановитьПараметр("Артикул", МатериалНо);
			ВыборкаДубль = ЗапросДубль.Выполнить().Выбрать();

			Если ВыборкаДубль.Следующий() Тогда
				Если НЕ РежимОбновления Тогда
					ОтменитьТранзакцию();
					Продолжить;
				КонецЕсли;
				НовыйОбъект = ВыборкаДубль.Ссылка.ПолучитьОбъект();
			Иначе
				НовыйОбъект = Справочники.Номенклатура.СоздатьЭлемент();
			КонецЕсли;

			// ВидНоменклатуры + заполнение реквизитов по виду (ТипНоменклатуры, СтавкаНДС, мерки и т.д.)
			НовыйОбъект.ВидНоменклатуры = ВидНоменклатуры;
			Справочники.Номенклатура.ЗаполнитьРеквизитыПоВидуНоменклатуры(НовыйОбъект);

			// Основные реквизиты (ПОСЛЕ заполнения по виду — наши значения перезаписывают дефолтные)
			НовыйОбъект.Наименование = Лев(НаименованиеDE, 100);
			НовыйОбъект.НаименованиеПолное = ?(ЗначениеЗаполнено(НаименованиеУК), НаименованиеУК, НаименованиеDE);
			НовыйОбъект.Артикул = МатериалНо;

			Если ЗначениеЗаполнено(РодительНоменклатуры) Тогда
				НовыйОбъект.Родитель = РодительНоменклатуры;
			КонецЕсли;

			Если ЗначениеЗаполнено(Производитель) Тогда
				НовыйОбъект.Производитель = Производитель;
			КонецЕсли;

			// Единица измерения (хранения) — из продажной единицы (V) или базовой (D)
			ЕдИзм = КэшЕИ.Получить(ВРег(ЕдИзмХранения));
			Если ЕдИзм <> Неопределено Тогда
				НовыйОбъект.ЕдиницаИзмерения = ЕдИзм;
			КонецЕсли;

			// Вес (кол H)
			ВесЧисло = СтрокаВЧисло(ВесБрутто);
			Если ВесЧисло > 0 Тогда
				НовыйОбъект.ВесИспользовать = Истина;
				НовыйОбъект.ВесЧислитель = ВесЧисло;
				НовыйОбъект.ВесЗнаменатель = 1;
				Если ЕдиницаИзмеренияКг <> Неопределено Тогда
					НовыйОбъект.ВесЕдиницаИзмерения = ЕдиницаИзмеренияКг;
				КонецЕсли;
			КонецЕсли;

			// Длина (кол J) — только для профилей (базовая ЕИ=M)
			// Числитель = значение длины, Знаменатель = кол-во шт
			// Отображение: "{Знаменатель} шт має довжину {Числитель} м"
			ДлинаЧисло = СтрокаВЧисло(ДлинаМ);
			Если ВРег(ЕдИзмКод) = "M" И ДлинаЧисло > 0 Тогда
				НовыйОбъект.ДлинаИспользовать = Истина;
				НовыйОбъект.ДлинаЧислитель = ДлинаЧисло;
				НовыйОбъект.ДлинаЗнаменатель = 1;
				НовыйОбъект.ДлинаМожноУказыватьВДокументах = Истина;
				Если ЕдиницаИзмеренияМ <> Неопределено Тогда
					НовыйОбъект.ДлинаЕдиницаИзмерения = ЕдиницаИзмеренияМ;
				КонецЕсли;
			КонецЕсли;

			// Площадь окружности (кол N) → нативное поле Площадь
			// Значение в ULF/м (1000 ULF = 1 м²): 341 ULF/м = 0.341 м²/м
			// Числитель = значение площади, Знаменатель = кол-во шт
			ПлощадьОкружЧисло = СтрокаВЧисло(ПлощадьОкруж);
			Если ПлощадьОкружЧисло > 0 Тогда
				НовыйОбъект.ПлощадьИспользовать = Истина;
				НовыйОбъект.ПлощадьЧислитель = ПлощадьОкружЧисло / 1000;
				НовыйОбъект.ПлощадьЗнаменатель = 1;
				ЕдиницаИзмеренияМ2 = КэшЕИ.Получить("M2");
				Если ЕдиницаИзмеренияМ2 <> Неопределено Тогда
					НовыйОбъект.ПлощадьЕдиницаИзмерения = ЕдиницаИзмеренияМ2;
				КонецЕсли;
			КонецЕсли;

			// Ценовая группа (кол P)
			Если ЗначениеЗаполнено(ГруппаСкидки) Тогда
				ЦеноваяГруппа = КэшЦеновыхГрупп.Получить(ГруппаСкидки);
				Если ЦеноваяГруппа = Неопределено Тогда
					НоваяГруппа = Справочники.ЦеновыеГруппы.СоздатьЭлемент();
					НоваяГруппа.Наименование = ГруппаСкидки;
					НоваяГруппа.Записать();
					ЦеноваяГруппа = НоваяГруппа.Ссылка;
					КэшЦеновыхГрупп.Вставить(ГруппаСкидки, ЦеноваяГруппа);
				КонецЕсли;
				НовыйОбъект.ЦеноваяГруппа = ЦеноваяГруппа;
			КонецЕсли;

			// Дополнительные реквизиты
			НовыйОбъект.ДополнительныеРеквизиты.Очистить();

			ДобавитьДопРеквизит(НовыйОбъект, КэшДопРеквизитов, "Найменування (EN)", НаименованиеEN);
			ДобавитьДопРеквизит(НовыйОбъект, КэшДопРеквизитов, "MS (Marktsegment)", MS);
			ДобавитьДопРеквизит(НовыйОбъект, КэшДопРеквизитов, "VS (Vertriebsschiene)", VS);
			ДобавитьДопРеквизит(НовыйОбъект, КэшДопРеквизитов, "WS (Warengruppe)", WS);
			ДобавитьДопРеквизит(НовыйОбъект, КэшДопРеквизитов, "Індикатор програми", ProgInd);

			// Площадь полировки как ДопРеквизит (кол M) — значение в ULF, конвертируем / 1000
			ПлощадьПолирЧисло = СтрокаВЧисло(ПлощадьПолир);
			Если ПлощадьПолирЧисло > 0 Тогда
				ДобавитьДопРеквизитЧисло(НовыйОбъект, КэшДопРеквизитов, "Площа полірування", ПлощадьПолирЧисло / 1000);
			КонецЕсли;

			// Записать (ОбменДанными.Загрузка = Истина — пропустить ПередЗаписью,
			// т.к. ЗаполнитьРеквизитыПоВидуНоменклатуры уже вызван выше)
			НовыйОбъект.ОбменДанными.Загрузка = Истина;
			НовыйОбъект.Записать();
			Результат.Создано = Результат.Создано + 1;

			// НоменклатураГТД (кол U) — подчинённый справочник
			Если ЗначениеЗаполнено(КодТарифа) Тогда
				СоздатьНоменклатуруГТД(НовыйОбъект.Ссылка, КодТарифа);
			КонецЕсли;

			ЗафиксироватьТранзакцию();

		Исключение
			ОтменитьТранзакцию();
			Результат.Ошибок = Результат.Ошибок + 1;
			Сообщить(НСтр("ru='Ошибка';uk='Помилка'") + " " + НСтр("ru='строка';uk='рядок'") + " "
				+ НомерСтроки + " (" + НСтр("ru='арт.';uk='арт.'") + " " + МатериалНо + "): " + ОписаниеОшибки());
		КонецПопытки;

	КонецЦикла;

	Результат.Сообщение = НСтр("ru='Завершено';uk='Завершено'") + ". "
		+ НСтр("ru='Обработано: ';uk='Оброблено: '") + Результат.Обработано + ", "
		+ НСтр("ru='Создано: ';uk='Створено: '") + Результат.Создано + ", "
		+ НСтр("ru='Ошибок: ';uk='Помилок: '") + Результат.Ошибок;

	Возврат Результат;

КонецФункции

&НаСервереБезКонтекста
Процедура ПодготовитьКэшЕдиницИзмерения(КэшЕИ)

	Запрос = Новый Запрос(
		"ВЫБРАТЬ Ссылка, Наименование
		|ИЗ Справочник.УпаковкиЕдиницыИзмерения
		|ГДЕ Владелец = &Владелец");
	Запрос.УстановитьПараметр("Владелец",
		Справочники.НаборыУпаковок.БазовыеЕдиницыИзмерения);
	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		Имя = ВРег(СокрЛП(Выборка.Наименование));
		КэшЕИ.Вставить(Имя, Выборка.Ссылка);
	КонецЦикла;

	// Маппинг кодов PL51 на имена ЕИ в 1С
	Для Каждого КлючЗначение Из КэшЕИ Цикл
		Имя = КлючЗначение.Ключ;
		Если Имя = "М" Или Имя = "М." Тогда
			КэшЕИ.Вставить("M", КлючЗначение.Значение);
		ИначеЕсли Имя = "ШТ" Или Имя = "ШТ." Тогда
			КэшЕИ.Вставить("ST", КлючЗначение.Значение);
		ИначеЕсли Имя = "УПАК" Или Имя = "УПАК." Или Имя = "ПАК" Тогда
			КэшЕИ.Вставить("PAK", КлючЗначение.Значение);
		ИначеЕсли Имя = "ПАР" Или Имя = "ПАР." Тогда
			КэшЕИ.Вставить("PAA", КлючЗначение.Значение);
		ИначеЕсли Имя = "КГ" Или Имя = "КГ." Тогда
			КэшЕИ.Вставить("KG", КлючЗначение.Значение);
		ИначеЕсли Имя = "М2" Или Имя = "М²" Или Имя = "КВ.М" Тогда
			КэшЕИ.Вставить("M2", КлючЗначение.Значение);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПодготовитьКэшДопРеквизитов(КэшДопРеквизитов)

	Запрос = Новый Запрос(
		"ВЫБРАТЬ Ссылка, Наименование
		|ИЗ ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения");
	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		КэшДопРеквизитов.Вставить(СокрЛП(Выборка.Наименование), Выборка.Ссылка);
	КонецЦикла;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьДопРеквизит(Объект, КэшДопРеквизитов, ИмяСвойства, Значение)

	Если НЕ ЗначениеЗаполнено(Значение) Тогда
		Возврат;
	КонецЕсли;

	Свойство = КэшДопРеквизитов.Получить(ИмяСвойства);
	Если Свойство = Неопределено Тогда
		Возврат;
	КонецЕсли;

	НоваяСтрока = Объект.ДополнительныеРеквизиты.Добавить();
	НоваяСтрока.Свойство = Свойство;
	НоваяСтрока.Значение = Значение;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьДопРеквизитЧисло(Объект, КэшДопРеквизитов, ИмяСвойства, Значение)

	Если Значение = 0 Тогда
		Возврат;
	КонецЕсли;

	Свойство = КэшДопРеквизитов.Получить(ИмяСвойства);
	Если Свойство = Неопределено Тогда
		Возврат;
	КонецЕсли;

	НоваяСтрока = Объект.ДополнительныеРеквизиты.Добавить();
	НоваяСтрока.Свойство = Свойство;
	НоваяСтрока.Значение = Значение;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура СоздатьНоменклатуруГТД(НоменклатураСсылка, КодТарифа)

	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.НоменклатураГТД
		|ГДЕ Владелец = &Владелец");
	Запрос.УстановитьПараметр("Владелец", НоменклатураСсылка);
	Если НЕ Запрос.Выполнить().Пустой() Тогда
		Возврат;
	КонецЕсли;

	// Найти код в КлассификаторУКТВЭД (коды хранятся с пробелами, напр. "7604 29 90 00")
	// PL51 даёт 8-значный код без пробелов: "76042990"
	// Конвертируем в паттерн с пробелами: "76042990" → "7604 29 90%"
	КодСПробелами = Лев(КодТарифа, 4);
	Если СтрДлина(КодТарифа) > 4 Тогда
		КодСПробелами = КодСПробелами + " " + Сред(КодТарифа, 5, 2);
	КонецЕсли;
	Если СтрДлина(КодТарифа) > 6 Тогда
		КодСПробелами = КодСПробелами + " " + Сред(КодТарифа, 7, 2);
	КонецЕсли;

	ЗапросУКТ = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Справочник.КлассификаторУКТВЭД
		|ГДЕ Код ПОДОБНО &КодПаттерн");
	ЗапросУКТ.УстановитьПараметр("КодПаттерн", КодСПробелами + "%");
	ВыборкаУКТ = ЗапросУКТ.Выполнить().Выбрать();
	Если НЕ ВыборкаУКТ.Следующий() Тогда
		Сообщить("УКТЗЕД код """ + КодТарифа + """ не знайдено в класифікаторі для " + НоменклатураСсылка);
		Возврат;
	КонецЕсли;
	КодУКТВЭД = ВыборкаУКТ.Ссылка;

	// Создать НоменклатураГТД с кодом УКТВЭД
	НовыйГТД = Справочники.НоменклатураГТД.СоздатьЭлемент();
	НовыйГТД.Владелец = НоменклатураСсылка;
	НовыйГТД.КодУКТВЭД = КодУКТВЭД;
	НовыйГТД.Записать();

	// Привязать к номенклатуре как код по умолчанию
	НомОбъект = НоменклатураСсылка.ПолучитьОбъект();
	НомОбъект.НоменклатураГТД = НовыйГТД.Ссылка;
	НомОбъект.ОбменДанными.Загрузка = Истина;
	НомОбъект.Записать();

КонецПроцедуры

&НаСервереБезКонтекста
Функция СтрокаВЧисло(Стр)

	Попытка
		Стр = СокрЛП(Стр);
		Если НЕ ЗначениеЗаполнено(Стр) Тогда
			Возврат 0;
		КонецЕсли;
		Стр = СтрЗаменить(Стр, ",", ".");
		Возврат Число(Стр);
	Исключение
		Возврат 0;
	КонецПопытки;

КонецФункции

&НаКлиенте
Процедура УдалитьЗагруженные(Команда)

	Если НЕ ЗначениеЗаполнено(Производитель) И НЕ ЗначениеЗаполнено(РодительНоменклатуры) И НЕ ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Укажите производителя, папку или вид номенклатуры для удаления';uk='Вкажіть виробника, папку або вид номенклатури для видалення'"));
		Возврат;
	КонецЕсли;

	ОписаниеОповещения = Новый ОписаниеОповещения("УдалитьЗагруженныеЗавершение", ЭтотОбъект);
	ПоказатьВопрос(ОписаниеОповещения,
		НСтр("ru='Удалить все элементы номенклатуры по указанному производителю/папке? Это действие необратимо!';uk='Видалити всі елементи номенклатури за вказаним виробником/папкою? Цю дію неможливо скасувати!'"),
		РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

&НаКлиенте
Процедура УдалитьЗагруженныеЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	РезультатУдаления = УдалитьЗагруженныеНаСервере(Производитель, РодительНоменклатуры, ВидНоменклатуры);

	КоличествоОбработано = РезультатУдаления.Удалено;
	КоличествоОшибок = РезультатУдаления.Ошибок;
	КоличествоСоздано = 0;
	СообщениеСтатуса = РезультатУдаления.Сообщение;

КонецПроцедуры

&НаСервереБезКонтекста
Функция УдалитьЗагруженныеНаСервере(Производитель, РодительНоменклатуры, ВидНоменклатуры)

	Результат = Новый Структура("Удалено, Ошибок, Сообщение", 0, 0, "");

	// Построить запрос с условиями
	ТекстЗапроса =
		"ВЫБРАТЬ Ссылка
		|ИЗ Справочник.Номенклатура
		|ГДЕ НЕ ЭтоГруппа";

	Запрос = Новый Запрос;

	Если ЗначениеЗаполнено(Производитель) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		| И Производитель = &Производитель";
		Запрос.УстановитьПараметр("Производитель", Производитель);
	КонецЕсли;

	Если ЗначениеЗаполнено(РодительНоменклатуры) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		| И Родитель = &Родитель";
		Запрос.УстановитьПараметр("Родитель", РодительНоменклатуры);
	КонецЕсли;

	Если ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		| И ВидНоменклатуры = &ВидНоменклатуры";
		Запрос.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры);
	КонецЕсли;

	Запрос.Текст = ТекстЗапроса;
	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл

		НачатьТранзакцию();
		Попытка
			// Сначала удалить подчинённые НоменклатураГТД
			ЗапросГТД = Новый Запрос(
				"ВЫБРАТЬ Ссылка ИЗ Справочник.НоменклатураГТД ГДЕ Владелец = &Владелец");
			ЗапросГТД.УстановитьПараметр("Владелец", Выборка.Ссылка);
			ВыборкаГТД = ЗапросГТД.Выполнить().Выбрать();
			Пока ВыборкаГТД.Следующий() Цикл
				ОбъектГТД = ВыборкаГТД.Ссылка.ПолучитьОбъект();
				ОбъектГТД.Удалить();
			КонецЦикла;

			// Удалить номенклатуру
			Объект = Выборка.Ссылка.ПолучитьОбъект();
			Объект.Удалить();
			Результат.Удалено = Результат.Удалено + 1;

			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			Результат.Ошибок = Результат.Ошибок + 1;
			Сообщить(НСтр("ru='Ошибка удаления: ';uk='Помилка видалення: '") + ОписаниеОшибки());
		КонецПопытки;

	КонецЦикла;

	Результат.Сообщение = НСтр("ru='Удаление завершено';uk='Видалення завершено'") + ". "
		+ НСтр("ru='Удалено: ';uk='Видалено: '") + Результат.Удалено + ", "
		+ НСтр("ru='Ошибок: ';uk='Помилок: '") + Результат.Ошибок;

	Возврат Результат;

КонецФункции

