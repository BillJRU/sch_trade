// Внешняя печатная форма "Пропозицiя (Schueco)" для документа КоммерческоеПредложениеКлиенту.
// Подключается через справочник ДополнительныеОтчетыИОбработки.

#Область ПрограммныйИнтерфейс

// Возвращает сведения о внешней обработке для регистрации в справочнике ДополнительныеОтчетыИОбработки.
//
// Возвращаемое значение:
//  Структура - параметры регистрации.
//
Функция СведенияОВнешнейОбработке() Экспорт

	ПараметрыРегистрации = ДополнительныеОтчетыИОбработки.СведенияОВнешнейОбработке("2.3.1.73");
	ПараметрыРегистрации.Вид     = ДополнительныеОтчетыИОбработкиКлиентСервер.ВидОбработкиПечатнаяФорма();
	ПараметрыРегистрации.Версия  = "1.0";

	ПараметрыРегистрации.Назначение.Добавить("Документ.КоммерческоеПредложениеКлиенту");

	НоваяКоманда = ПараметрыРегистрации.Команды.Добавить();
	НоваяКоманда.Представление    = НСтр("ru='Предложение (Schueco)';uk='Пропозицiя (Schueco)'");
	НоваяКоманда.Идентификатор    = "Schueco_Предложение";
	НоваяКоманда.Использование    = ДополнительныеОтчетыИОбработкиКлиентСервер.ТипКомандыВызовСерверногоМетода();
	НоваяКоманда.ПоказыватьОповещение = Истина;
	НоваяКоманда.Модификатор      = "ПечатьMXL";

	Возврат ПараметрыРегистрации;

КонецФункции

// Формирует печатные формы.
//
// Параметры:
//  МассивОбъектов        - Массив           - ссылки на объекты печати.
//  КоллекцияПечатныхФорм - ТаблицаЗначений  - коллекция печатных форм.
//  ОбъектыПечати          - СписокЗначений   - соответствие объектов и имен областей.
//  ПараметрыВывода        - Структура        - дополнительные параметры.
//
Процедура Печать(МассивОбъектов, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт

	ПечатнаяФорма = УправлениеПечатью.СведенияОПечатнойФорме(КоллекцияПечатныхФорм, "Schueco_Предложение");
	Если ПечатнаяФорма <> Неопределено Тогда
		ПечатнаяФорма.ТабличныйДокумент = СформироватьПредложение(МассивОбъектов, ОбъектыПечати, ПараметрыВывода);
		ПечатнаяФорма.СинонимМакета     = НСтр("ru='Предложение (Schueco)';uk='Пропозицiя (Schueco)'");
		ПечатнаяФорма.ПолныйПутьКМакету = "ВнешняяОбработка.Schueco_ПечатьКП.Макет";
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует табличный документ печатной формы "Предложение (Schueco)".
//
// Параметры:
//  МассивОбъектов  - Массив         - ссылки на документы КоммерческоеПредложениеКлиенту.
//  ОбъектыПечати   - СписокЗначений - соответствие объектов и имен областей.
//  ПараметрыВывода - Структура      - дополнительные параметры.
//
// Возвращаемое значение:
//  ТабличныйДокумент - сформированная печатная форма.
//
Функция СформироватьПредложение(МассивОбъектов, ОбъектыПечати, ПараметрыВывода)

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "Schueco_Предложение";

	Макет = ПолучитьМакет("Макет");

	ОбластьЗаголовок     = Макет.ПолучитьОбласть("Заголовок");
	ОбластьШапкаТаблицы  = Макет.ПолучитьОбласть("ШапкаТаблицы");
	ОбластьСтрокаТовары  = Макет.ПолучитьОбласть("СтрокаТовары");
	ОбластьПодвалТаблицы = Макет.ПолучитьОбласть("ПодвалТаблицы");
	ОбластьПримечание    = Макет.ПолучитьОбласть("Примечание");

	// Запрос данных
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Док.Ссылка                               КАК Ссылка,
	|	Док.Номер                                КАК Номер,
	|	Док.Дата                                 КАК Дата,
	|	Док.Организация                          КАК Организация,
	|	Док.Валюта                               КАК Валюта,
	|	Док.Клиент                               КАК Клиент,
	|	Док.Контрагент                           КАК Контрагент,
	|	Док.КонтактноеЛицо                       КАК КонтактноеЛицо,
	|	Док.СрокДействия                         КАК СрокДействия,
	|	Док.ЦенаВключаетНДС                      КАК ЦенаВключаетНДС,
	|	Док.УсловияДоставкиТекст                 КАК УсловияДоставки,
	|	Док.УсловияОплатыТекст                   КАК УсловияОплаты,
	|	Док.ПрочаяДополнительнаяИнформацияТекст  КАК ПрочиеУсловия
	|ИЗ
	|	Документ.КоммерческоеПредложениеКлиенту КАК Док
	|ГДЕ
	|	Док.Ссылка В(&МассивОбъектов)
	|УПОРЯДОЧИТЬ ПО Док.Ссылка
	|;
	|ВЫБРАТЬ
	|	Товары.Ссылка                            КАК Ссылка,
	|	Товары.НомерСтроки                       КАК НомерСтроки,
	|	Товары.Номенклатура                      КАК Номенклатура,
	|	Товары.Номенклатура.Артикул              КАК Артикул,
	|	Товары.Номенклатура.НаименованиеПолное   КАК НаименованиеПолное,
	|	Товары.Характеристика                    КАК Характеристика,
	|	Товары.Количество                        КАК Количество,
	|	Товары.ЕдиницаИзмерения                  КАК ЕдиницаИзмерения,
	|	Товары.Цена                              КАК Цена,
	|	Товары.Сумма                             КАК Сумма,
	|	Товары.СуммаНДС                          КАК СуммаНДС,
	|	Товары.СуммаСНДС                         КАК СуммаСНДС,
	|	Товары.СуммаРучнойСкидки + Товары.СуммаАвтоматическойСкидки   КАК СуммаСкидки,
	|	Товары.ПроцентРучнойСкидки + Товары.ПроцентАвтоматическойСкидки КАК ПроцентСкидки,
	|	Товары.Активность                        КАК Активность
	|ИЗ
	|	Документ.КоммерческоеПредложениеКлиенту.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка В(&МассивОбъектов)
	|	И Товары.Активность
	|УПОРЯДОЧИТЬ ПО Товары.Ссылка, Товары.НомерСтроки";

	ПакетРезультатов = Запрос.ВыполнитьПакет();
	ВыборкаШапки  = ПакетРезультатов[0].Выбрать();
	ТаблицаТовары = ПакетРезультатов[1].Выгрузить();

	ПервыйДокумент = Истина;

	Пока ВыборкаШапки.Следующий() Цикл

		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

		// --- Данные организации ---
		СведенияОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ВыборкаШапки.Организация, ВыборкаШапки.Дата);

		ПредставлениеОрганизации = СведенияОрганизации.ПолноеНаименование;
		Если ПустаяСтрока(ПредставлениеОрганизации) Тогда
			ПредставлениеОрганизации = СведенияОрганизации.Наименование;
		КонецЕсли;

		АдресОрганизации  = СведенияОрганизации.ЮридическийАдрес;
		ТелефонОрганизации = СведенияОрганизации.Телефоны;

		КонтактнаяИнформация = "";
		Если Не ПустаяСтрока(АдресОрганизации) Тогда
			КонтактнаяИнформация = АдресОрганизации;
		КонецЕсли;
		Если Не ПустаяСтрока(ТелефонОрганизации) Тогда
			КонтактнаяИнформация = КонтактнаяИнформация
				+ ?(ПустаяСтрока(КонтактнаяИнформация), "", Символы.ПС)
				+ НСтр("ru='тел: ';uk='тел: '") + ТелефонОрганизации;
		КонецЕсли;

		// --- Данные покупателя ---
		ПредставлениеКлиента = "";
		Если ЗначениеЗаполнено(ВыборкаШапки.Контрагент) Тогда
			ПредставлениеКлиента = Строка(ВыборкаШапки.Контрагент);
		ИначеЕсли ЗначениеЗаполнено(ВыборкаШапки.Клиент) Тогда
			ПредставлениеКлиента = Строка(ВыборкаШапки.Клиент);
		КонецЕсли;

		АдресПокупателя = "";
		Если ЗначениеЗаполнено(ВыборкаШапки.Контрагент) Тогда
			Попытка
				МассивКонтрагентов = Новый Массив;
				МассивКонтрагентов.Добавить(ВыборкаШапки.Контрагент);
				ТребуемыеТипыКИ = Новый Массив;
				ТребуемыеТипыКИ.Добавить(Перечисления.ТипыКонтактнойИнформации.Адрес);
				ТаблицаКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(
					МассивКонтрагентов, ТребуемыеТипыКИ,, ВыборкаШапки.Дата);
				Для Каждого СтрокаКИ Из ТаблицаКИ Цикл
					АдресПокупателя = СтрокаКИ.Представление;
					Прервать;
				КонецЦикла;
			Исключение
				АдресПокупателя = "";
			КонецПопытки;
		КонецЕсли;

		// --- Валюта ---
		ПредставлениеВалюты = ?(ЗначениеЗаполнено(ВыборкаШапки.Валюта),
			СокрЛП(Строка(ВыборкаШапки.Валюта)), "");

		// --- Номер и дата ---
		НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ВыборкаШапки.Номер, Ложь, Истина);
		НомерДата = "KP" + НомерДокумента + " / " + Формат(ВыборкаШапки.Дата, "ДЛФ=D");

		// --- Заголовок ---
		ОбластьЗаголовок.Параметры.ПредставлениеОрганизации        = ПредставлениеОрганизации;
		ОбластьЗаголовок.Параметры.КонтактнаяИнформацияОрганизации = КонтактнаяИнформация;
		ОбластьЗаголовок.Параметры.НомерДата          = НомерДата;
		ОбластьЗаголовок.Параметры.ПредставлениеКлиента = ПредставлениеКлиента;
		ОбластьЗаголовок.Параметры.АдресПокупателя      = АдресПокупателя;
		ОбластьЗаголовок.Параметры.СрокДействия         = Формат(ВыборкаШапки.СрокДействия, "ДФ=dd.MM.yyyy");
		ОбластьЗаголовок.Параметры.УсловияДоставки      = ВыборкаШапки.УсловияДоставки;
		ОбластьЗаголовок.Параметры.КонтактноеЛицо       = Строка(ВыборкаШапки.КонтактноеЛицо);
		ОбластьЗаголовок.Параметры.УсловияОплаты        = ВыборкаШапки.УсловияОплаты;
		ОбластьЗаголовок.Параметры.Валюта               = ПредставлениеВалюты;

		ФормированиеПечатныхФорм.ВывестиЛоготипВТабличныйДокумент(Макет, ОбластьЗаголовок, "Заголовок", ВыборкаШапки.Организация);

		ТабличныйДокумент.Вывести(ОбластьЗаголовок);

		// --- Шапка таблицы ---
		ТабличныйДокумент.Вывести(ОбластьШапкаТаблицы);

		// --- Строки товаров ---
		СтрокиДокумента = ТаблицаТовары.НайтиСтроки(Новый Структура("Ссылка", ВыборкаШапки.Ссылка));

		СуммаВсего    = 0;
		СуммаВсегоНДС = 0;
		НомерВыводимойСтроки = 0;

		Для Каждого СтрокаТовара Из СтрокиДокумента Цикл

			НомерВыводимойСтроки = НомерВыводимойСтроки + 1;

			СуммаВсего    = СуммаВсего + СтрокаТовара.Сумма;
			СуммаВсегоНДС = СуммаВсегоНДС + СтрокаТовара.СуммаНДС;

			// Наименование
			НаименованиеТовара = СтрокаТовара.НаименованиеПолное;
			Если ПустаяСтрока(НаименованиеТовара) Тогда
				НаименованиеТовара = Строка(СтрокаТовара.Номенклатура);
			КонецЕсли;
			Если ЗначениеЗаполнено(СтрокаТовара.Характеристика) Тогда
				НаименованиеТовара = НаименованиеТовара + " (" + Строка(СтрокаТовара.Характеристика) + ")";
			КонецЕсли;

			// Количество / ед. изм.
			ЕдИзм = Строка(СтрокаТовара.ЕдиницаИзмерения);
			КоличествоЕдИзм = Формат(СтрокаТовара.Количество, "ЧДЦ=0") + " " + ЕдИзм;
			КоличествоВторичное = Формат(СтрокаТовара.Количество, "ЧДЦ=3; ЧРД=,") + " " + ЕдИзм;

			// Скидка
			СкидкаТекст = "";
			Если СтрокаТовара.ПроцентСкидки <> 0 Тогда
				СкидкаТекст = Формат(-СтрокаТовара.ПроцентСкидки, "ЧДЦ=2; ЧРД=,") + " %";
			КонецЕсли;

			// Цена / ед. изм.
			ЦенаЕдИзм = Формат(СтрокаТовара.Цена, "ЧДЦ=2; ЧРД=,") + " / 1 " + ЕдИзм;

			// Заполнение области
			ОбластьСтрокаТовары.Параметры.НомерСтроки         = Формат(НомерВыводимойСтроки, "ЧДЦ=2; ЧРД=,");
			ОбластьСтрокаТовары.Параметры.Артикул             = СтрокаТовара.Артикул;
			ОбластьСтрокаТовары.Параметры.Наименование        = НаименованиеТовара;
			ОбластьСтрокаТовары.Параметры.КоличествоЕдИзм    = КоличествоЕдИзм;
			ОбластьСтрокаТовары.Параметры.КоличествоВторичное = КоличествоВторичное;
			ОбластьСтрокаТовары.Параметры.Скидка              = СкидкаТекст;
			ОбластьСтрокаТовары.Параметры.ЦенаЕдИзм          = ЦенаЕдИзм;
			ОбластьСтрокаТовары.Параметры.СтоимостьПозиции    = Формат(СтрокаТовара.Сумма, "ЧДЦ=2; ЧРД=,");
			ОбластьСтрокаТовары.Параметры.Сумма               = Формат(СтрокаТовара.Сумма, "ЧДЦ=2; ЧРД=,");

			ТабличныйДокумент.Вывести(ОбластьСтрокаТовары);

		КонецЦикла;

		// --- Подвал таблицы ---
		СуммаСНДС = СуммаВсего + ?(ВыборкаШапки.ЦенаВключаетНДС, 0, СуммаВсегоНДС);

		ОбластьПодвалТаблицы.Параметры.ОбщаяСебестоимость = Формат(СуммаВсего, "ЧДЦ=2; ЧРД=,");
		ОбластьПодвалТаблицы.Параметры.СуммаНДС           = Формат(СуммаВсегоНДС, "ЧДЦ=2; ЧРД=,");
		ОбластьПодвалТаблицы.Параметры.ОбщаяСтоимостьСНДС = Формат(СуммаСНДС, "ЧДЦ=2; ЧРД=,");
		ОбластьПодвалТаблицы.Параметры.Валюта             = ПредставлениеВалюты;

		ТабличныйДокумент.Вывести(ОбластьПодвалТаблицы);

		// --- Примечание ---
		ТекстПримечания = ВыборкаШапки.ПрочиеУсловия;
		Если ПустаяСтрока(ТекстПримечания) Тогда
			ТекстПримечания = "";
		КонецЕсли;
		ОбластьПримечание.Параметры.Примечание = ТекстПримечания;
		ТабличныйДокумент.Вывести(ОбластьПримечание);

		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент,
			НомерСтрокиНачало, ОбъектыПечати, ВыборкаШапки.Ссылка);

	КонецЦикла;

	Возврат ТабличныйДокумент;

КонецФункции

#КонецОбласти
