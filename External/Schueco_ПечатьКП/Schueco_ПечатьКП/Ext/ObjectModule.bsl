// Внешняя печатная форма "Пропозицiя (Schueco)" для документа КоммерческоеПредложениеКлиенту.
// Подключается через справочник ДополнительныеОтчетыИОбработки.

#Область ПрограммныйИнтерфейс

// Возвращает сведения о внешней обработке для регистрации в справочнике ДополнительныеОтчетыИОбработки.
//
// Возвращаемое значение:
//  Структура - параметры регистрации.
//
Функция СведенияОВнешнейОбработке() Экспорт

	ПараметрыРегистрации = ДополнительныеОтчетыИОбработки.СведенияОВнешнейОбработке("2.3.1.73");
	ПараметрыРегистрации.Вид     = ДополнительныеОтчетыИОбработкиКлиентСервер.ВидОбработкиПечатнаяФорма();
	ПараметрыРегистрации.Версия  = "1.2.8";

	ПараметрыРегистрации.Назначение.Добавить("Документ.КоммерческоеПредложениеКлиенту");

	НоваяКоманда = ПараметрыРегистрации.Команды.Добавить();
	НоваяКоманда.Представление    = НСтр("ru='Комерческое предложение клиенту (Schueco)';uk='Комерційна пропозиція клієнту (Schueco)'");
	НоваяКоманда.Идентификатор    = "Schueco_Предложение";
	НоваяКоманда.Использование    = ДополнительныеОтчетыИОбработкиКлиентСервер.ТипКомандыВызовСерверногоМетода();
	НоваяКоманда.ПоказыватьОповещение = Истина;
	НоваяКоманда.Модификатор      = "ПечатьMXL";

	Возврат ПараметрыРегистрации;

КонецФункции

// Формирует печатные формы.
//
// Параметры:
//  МассивОбъектов        - Массив           - ссылки на объекты печати.
//  КоллекцияПечатныхФорм - ТаблицаЗначений  - коллекция печатных форм.
//  ОбъектыПечати          - СписокЗначений   - соответствие объектов и имен областей.
//  ПараметрыВывода        - Структура        - дополнительные параметры.
//
Процедура Печать(МассивОбъектов, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт

	ПечатнаяФорма = УправлениеПечатью.СведенияОПечатнойФорме(КоллекцияПечатныхФорм, "Schueco_Предложение");
	Если ПечатнаяФорма <> Неопределено Тогда
		ПечатнаяФорма.ТабличныйДокумент = СформироватьПредложение(МассивОбъектов, ОбъектыПечати, ПараметрыВывода);
		ПечатнаяФорма.СинонимМакета     = НСтр("ru='Комерческое предложение клиенту (Schueco)';uk='Комерційна пропозиція клієнту (Schueco)'");
		ПечатнаяФорма.ПолныйПутьКМакету = "ВнешняяОбработка.Schueco_ПечатьКП.Макет";
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует табличный документ печатной формы "Предложение (Schueco)".
//
// Параметры:
//  МассивОбъектов  - Массив         - ссылки на документы КоммерческоеПредложениеКлиенту.
//  ОбъектыПечати   - СписокЗначений - соответствие объектов и имен областей.
//  ПараметрыВывода - Структура      - дополнительные параметры.
//
// Возвращаемое значение:
//  ТабличныйДокумент - сформированная печатная форма.
//
Функция СформироватьПредложение(МассивОбъектов, ОбъектыПечати, ПараметрыВывода)

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "Schueco_Предложение";

	Макет = ПолучитьМакет("Макет");

	ОбластьЗаголовокВерх    = Макет.ПолучитьОбласть("Заголовок_Верх");
	ОбластьЗаголовокОбъект  = Макет.ПолучитьОбласть("Заголовок_Объект");
	ОбластьЗаголовокАдрес   = Макет.ПолучитьОбласть("Заголовок_Адрес");
	ОбластьЗаголовокКонтакт = Макет.ПолучитьОбласть("Заголовок_Контакт");
	ОбластьЗаголовокНиз     = Макет.ПолучитьОбласть("Заголовок_Низ");
	ОбластьШапкаТаблицы  = Макет.ПолучитьОбласть("ШапкаТаблицы");
	ОбластьГлавная       = Макет.ПолучитьОбласть("СтрокаТовары_Главная");
	ОбластьСтоимость        = Макет.ПолучитьОбласть("СтрокаТовары_Стоимость");
	ОбластьСтоимостьБезПокраски  = Макет.ПолучитьОбласть("СтрокаТовары_СтоимостьБезПокраски");
	ОбластьВартістьПокриття = Макет.ПолучитьОбласть("СтрокаТовары_ВартістьПокриття");
	ОбластьЗагальнаВартість = Макет.ПолучитьОбласть("СтрокаТовары_ЗагальнаВартість");
	ОбластьОписание         = Макет.ПолучитьОбласть("СтрокаТовары_Описание");
	ОбластьПодвалТаблицы = Макет.ПолучитьОбласть("ПодвалТаблицы");
	ОбластьПримечание    = Макет.ПолучитьОбласть("Примечание");

	СвойствоПокраска             = НайтиСвойствоПокраска();
	ПроцессорНаценкаПокраска     = НайтиПроцессорНаценкаПокраска();

	// Запрос данных
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.УстановитьПараметр("СвойствоПокраска", СвойствоПокраска);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Док.Ссылка                               КАК Ссылка,
	|	Док.Номер                                КАК Номер,
	|	Док.Дата                                 КАК Дата,
	|	Док.Организация                          КАК Организация,
	|	Док.Валюта                               КАК Валюта,
	|	Док.Клиент                               КАК Клиент,
	|	Док.Контрагент                           КАК Контрагент,
	|	Док.КонтактноеЛицо                       КАК КонтактноеЛицо,
	|	Док.СрокДействия                         КАК СрокДействия,
	|	Док.ЦенаВключаетНДС                      КАК ЦенаВключаетНДС,
	|	Док.УсловияДоставкиТекст                 КАК УсловияДоставки,
	|	Док.УсловияОплатыТекст                   КАК УсловияОплаты,
	|	Док.ПрочаяДополнительнаяИнформацияТекст  КАК ПрочиеУсловия,
	|	Док.ОбъектЗаказчика                      КАК ОбъектЗаказчика,
	|	Док.ОбъектЗаказчика.Наименование         КАК ОбъектЗаказчикаНаименование
	|ИЗ
	|	Документ.КоммерческоеПредложениеКлиенту КАК Док
	|ГДЕ
	|	Док.Ссылка В(&МассивОбъектов)
	|УПОРЯДОЧИТЬ ПО Док.Ссылка
	|;
	|ВЫБРАТЬ
	|	Товары.Ссылка                            КАК Ссылка,
	|	Товары.НомерСтроки                       КАК НомерСтроки,
	|	Товары.Номенклатура                      КАК Номенклатура,
	|	Товары.Номенклатура.Артикул              КАК Артикул,
	|	Товары.Номенклатура.НаименованиеПолное   КАК НаименованиеПолное,
	|	Товары.Номенклатура.ЕдиницаИзмерения                       КАК БазоваяЕдиницаСсылка,
	|	Товары.Номенклатура.ЕдиницаИзмерения.Наименование          КАК БазоваяЕдиницаНаименование,
	|	Товары.Номенклатура.ЕдиницаИзмерения.ТипИзмеряемойВеличины КАК БазовыйТипЕдиницы,
	|	Товары.ЕдиницаИзмерения.ТипИзмеряемойВеличины              КАК СеллингТипЕдиницы,
	|	Товары.Номенклатура.НаборУпаковок                          КАК НаборУпаковок,
	|	Товары.Номенклатура.ЦеноваяГруппа.Наименование             КАК ЦеноваяГруппаНаименование,
	|	Товары.Номенклатура.ДлинаИспользовать    КАК ДлинаИспользовать,
	|	Товары.Номенклатура.ДлинаЧислитель       КАК ДлинаЧислитель,
	|	Товары.Номенклатура.ДлинаЗнаменатель     КАК ДлинаЗнаменатель,
	|	Товары.Номенклатура.ДлинаЕдиницаИзмерения.Наименование КАК ДлинаЕдиницаНаименование,
	|	Товары.Номенклатура.ВесИспользовать      КАК ВесИспользовать,
	|	Товары.Номенклатура.ВесЧислитель         КАК ВесЧислитель,
	|	Товары.Номенклатура.ВесЗнаменатель       КАК ВесЗнаменатель,
	|	Товары.Номенклатура.ВесЕдиницаИзмерения.Наименование КАК ВесЕдиницаНаименование,
	|	Товары.Номенклатура.ПлощадьИспользовать  КАК ПлощадьИспользовать,
	|	Товары.Номенклатура.ПлощадьЧислитель     КАК ПлощадьЧислитель,
	|	Товары.Номенклатура.ПлощадьЗнаменатель   КАК ПлощадьЗнаменатель,
	|	Товары.Номенклатура.ПлощадьЕдиницаИзмерения.Наименование КАК ПлощадьЕдиницаНаименование,
	|	Товары.Характеристика                    КАК Характеристика,
	|	Товары.Количество                        КАК Количество,
	|	Товары.ЕдиницаИзмерения                  КАК ЕдиницаИзмерения,
	|	Товары.ЕдиницаИзмерения.Числитель        КАК ЕдИзмЧислитель,
	|	Товары.ЕдиницаИзмерения.Знаменатель      КАК ЕдИзмЗнаменатель,
	|	Товары.ЕдиницаИзмерения.ЕдиницаИзмерения.Наименование КАК СеллингЕдиницаКласНаименование,
	|	Товары.Цена                              КАК Цена,
	|	Товары.Сумма                             КАК Сумма,
	|	Товары.СуммаНДС                          КАК СуммаНДС,
	|	Товары.СуммаСНДС                         КАК СуммаСНДС,
	|	Товары.СуммаРучнойСкидки + Товары.СуммаАвтоматическойСкидки   КАК СуммаСкидки,
	|	Товары.ПроцентРучнойСкидки + Товары.ПроцентАвтоматическойСкидки КАК ПроцентСкидки,
	|	Товары.СуммаРучнойСкидки                 КАК СуммаРучнойСкидки,
	|	Товары.ПроцентРучнойСкидки               КАК ПроцентРучнойСкидки,
	|	Товары.КлючСвязи                         КАК КлючСвязи,
	|	Товары.Активность                        КАК Активность,
	|	ВЫРАЗИТЬ(ДопРекПокраска.Значение КАК Справочник.Покраски_SCT).Наименование КАК ПокраскаНаименование
	|ИЗ
	|	Документ.КоммерческоеПредложениеКлиенту.Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры.ДополнительныеРеквизиты КАК ДопРекПокраска
	|		ПО ДопРекПокраска.Ссылка = Товары.Характеристика
	|		   И ДопРекПокраска.Свойство = &СвойствоПокраска
	|ГДЕ
	|	Товары.Ссылка В(&МассивОбъектов)
	|	И Товары.Активность
	|УПОРЯДОЧИТЬ ПО Товары.Ссылка, Товары.НомерСтроки
	|;
	|ВЫБРАТЬ
	|	СН.Ссылка                            КАК Ссылка,
	|	СН.КлючСвязи                         КАК КлючСвязи,
	|	СН.СкидкаНаценка                     КАК СкидкаНаценка,
	|	СН.СкидкаНаценка.Наименование        КАК ИмяСкидки,
	|	СН.СкидкаНаценка.СпособПредоставления КАК СпособПредоставления,
	|	СН.Сумма                             КАК Сумма
	|ИЗ
	|	Документ.КоммерческоеПредложениеКлиенту.СкидкиНаценки КАК СН
	|ГДЕ
	|	СН.Ссылка В(&МассивОбъектов)
	|УПОРЯДОЧИТЬ ПО СН.Ссылка, СН.КлючСвязи, СН.НомерСтроки";

	ПакетРезультатов = Запрос.ВыполнитьПакет();
	ВыборкаШапки   = ПакетРезультатов[0].Выбрать();
	ТаблицаТовары  = ПакетРезультатов[1].Выгрузить();
	ТаблицаСкидок  = ПакетРезультатов[2].Выгрузить();

	ПервыйДокумент = Истина;

	Пока ВыборкаШапки.Следующий() Цикл

		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

		// --- Данные организации ---
		СведенияОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ВыборкаШапки.Организация, ВыборкаШапки.Дата);

		ПредставлениеОрганизации = СведенияОрганизации.ПолноеНаименование;
		Если ПустаяСтрока(ПредставлениеОрганизации) Тогда
			ПредставлениеОрганизации = СведенияОрганизации.Наименование;
		КонецЕсли;

		АдресОрганизации  = СведенияОрганизации.ЮридическийАдрес;
		ТелефонОрганизации = СведенияОрганизации.Телефоны;

		КонтактнаяИнформация = "";
		Если Не ПустаяСтрока(АдресОрганизации) Тогда
			КонтактнаяИнформация = АдресОрганизации;
		КонецЕсли;
		Если Не ПустаяСтрока(ТелефонОрганизации) Тогда
			КонтактнаяИнформация = КонтактнаяИнформация
				+ ?(ПустаяСтрока(КонтактнаяИнформация), "", Символы.ПС)
				+ НСтр("ru='тел: ';uk='тел: '") + ТелефонОрганизации;
		КонецЕсли;

		// --- Данные покупателя ---
		ПредставлениеКлиента = "";
		Если ЗначениеЗаполнено(ВыборкаШапки.Контрагент) Тогда
			ПредставлениеКлиента = Строка(ВыборкаШапки.Контрагент);
		ИначеЕсли ЗначениеЗаполнено(ВыборкаШапки.Клиент) Тогда
			ПредставлениеКлиента = Строка(ВыборкаШапки.Клиент);
		КонецЕсли;

		АдресПокупателя = "";
		Если ЗначениеЗаполнено(ВыборкаШапки.Контрагент) Тогда
			Попытка
				МассивКонтрагентов = Новый Массив;
				МассивКонтрагентов.Добавить(ВыборкаШапки.Контрагент);
				ТребуемыеТипыКИ = Новый Массив;
				ТребуемыеТипыКИ.Добавить(Перечисления.ТипыКонтактнойИнформации.Адрес);
				ТаблицаКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(
					МассивКонтрагентов, ТребуемыеТипыКИ,, ВыборкаШапки.Дата);
				Для Каждого СтрокаКИ Из ТаблицаКИ Цикл
					АдресПокупателя = СтрокаКИ.Представление;
					Прервать;
				КонецЦикла;
			Исключение
				АдресПокупателя = "";
			КонецПопытки;
		КонецЕсли;

		// --- Валюта ---
		ПредставлениеВалюты = ?(ЗначениеЗаполнено(ВыборкаШапки.Валюта),
			СокрЛП(Строка(ВыборкаШапки.Валюта)), "");

		// --- Номер и дата ---
		НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ВыборкаШапки.Номер, Ложь, Истина);
		НомерДата = "KP" + НомерДокумента + " / " + Формат(ВыборкаШапки.Дата, "ДЛФ=D");

		// --- Заголовок: верхняя часть (организация + представление клиента + номер/дата) ---
		ОбластьЗаголовокВерх.Параметры.ПредставлениеОрганизации        = ПредставлениеОрганизации;
		ОбластьЗаголовокВерх.Параметры.КонтактнаяИнформацияОрганизации = КонтактнаяИнформация;
		ОбластьЗаголовокВерх.Параметры.НомерДата          = НомерДата;
		ОбластьЗаголовокВерх.Параметры.ПредставлениеКлиента = ПредставлениеКлиента;
		ФормированиеПечатныхФорм.ВывестиЛоготипВТабличныйДокумент(Макет, ОбластьЗаголовокВерх, "Заголовок_Верх", ВыборкаШапки.Организация);
		ТабличныйДокумент.Вывести(ОбластьЗаголовокВерх);

		// --- Заголовок: блок «Об'єкт» (только если выбран объект заказчика) ---
		Если ЗначениеЗаполнено(ВыборкаШапки.ОбъектЗаказчика) Тогда
			ОбластьЗаголовокОбъект.Параметры.Объект = ВыборкаШапки.ОбъектЗаказчикаНаименование;
			ТабличныйДокумент.Вывести(ОбластьЗаголовокОбъект);
		КонецЕсли;

		// --- Заголовок: адрес покупателя + срок действия + условия поставки ---
		ОбластьЗаголовокАдрес.Параметры.АдресПокупателя = АдресПокупателя;
		ОбластьЗаголовокАдрес.Параметры.СрокДействия    = Формат(ВыборкаШапки.СрокДействия, "ДФ=dd.MM.yyyy");
		ОбластьЗаголовокАдрес.Параметры.УсловияДоставки = ВыборкаШапки.УсловияДоставки;
		ТабличныйДокумент.Вывести(ОбластьЗаголовокАдрес);

		// --- Заголовок: блок «Представник отримувача / Контактное лицо» (только если задан) ---
		Если ЗначениеЗаполнено(ВыборкаШапки.КонтактноеЛицо) Тогда
			ОбластьЗаголовокКонтакт.Параметры.КонтактноеЛицо = Строка(ВыборкаШапки.КонтактноеЛицо);
			ТабличныйДокумент.Вывести(ОбластьЗаголовокКонтакт);
		КонецЕсли;

		// --- Заголовок: условия оплаты + валюта ---
		ОбластьЗаголовокНиз.Параметры.УсловияОплаты = ВыборкаШапки.УсловияОплаты;
		ОбластьЗаголовокНиз.Параметры.Валюта        = ПредставлениеВалюты;
		ТабличныйДокумент.Вывести(ОбластьЗаголовокНиз);

		// --- Шапка таблицы ---
		ТабличныйДокумент.Вывести(ОбластьШапкаТаблицы);

		// --- Строки товаров ---
		СтрокиДокумента = ТаблицаТовары.НайтиСтроки(Новый Структура("Ссылка", ВыборкаШапки.Ссылка));

		СуммаВсего    = 0;
		СуммаВсегоНДС = 0;
		НомерВыводимойСтроки = 0;
		ВесОбщий      = 0;
		ЕдВеса        = "";

		Для Каждого СтрокаТовара Из СтрокиДокумента Цикл

			НомерВыводимойСтроки = НомерВыводимойСтроки + 1;

			СуммаВсего    = СуммаВсего + СтрокаТовара.Сумма;
			СуммаВсегоНДС = СуммаВсегоНДС + СтрокаТовара.СуммаНДС;

			// Наименование (без характеристики)
			НаименованиеТовара = СтрокаТовара.НаименованиеПолное;
			Если ПустаяСтрока(НаименованиеТовара) Тогда
				НаименованиеТовара = Строка(СтрокаТовара.Номенклатура);
			КонецЕсли;

			// Точность вывода количества зависит от типа единицы измерения
			ДЦПродажа = ДЦДляТипаЕдиницы(СтрокаТовара.СеллингТипЕдиницы);
			ДЦБазы    = ДЦДляТипаЕдиницы(СтрокаТовара.БазовыйТипЕдиницы);

			// Продажная единица измерения / количество
			// Берём наименование с классификатора (например, «st»), а не Description упаковки («st (1/6 м)»).
			ЕдИзмПродажа = СокрЛП(СтрокаТовара.СеллингЕдиницаКласНаименование);
			Если ПустаяСтрока(ЕдИзмПродажа) Тогда
				ЕдИзмПродажа = СокрЛП(Строка(СтрокаТовара.ЕдиницаИзмерения));
			КонецЕсли;
			КоличествоПродажа  = Формат(СтрокаТовара.Количество, "ЧДЦ=" + Формат(ДЦПродажа, "ЧГ=0") + "; ЧРД=,") + " " + ЕдИзмПродажа;

			// Базовая единица измерения / количество
			ЕдЧислитель = ?(ЗначениеЗаполнено(СтрокаТовара.ЕдИзмЧислитель), СтрокаТовара.ЕдИзмЧислитель, 1);
			ЕдЗнаменатель = ?(ЗначениеЗаполнено(СтрокаТовара.ЕдИзмЗнаменатель), СтрокаТовара.ЕдИзмЗнаменатель, 1);
			Если ЕдЗнаменатель = 0 Тогда
				ЕдЗнаменатель = 1;
			КонецЕсли;
			Коэф = ЕдЧислитель / ЕдЗнаменатель;
			Если Коэф = 0 Тогда
				Коэф = 1;
			КонецЕсли;
			БазоваяЕдиница    = СокрЛП(СтрокаТовара.БазоваяЕдиницаНаименование);
			Если ПустаяСтрока(БазоваяЕдиница) Тогда
				БазоваяЕдиница = ЕдИзмПродажа;
			КонецЕсли;
			БазовоеКоличество = СтрокаТовара.Количество * Коэф;
			КоличествоБаза    = Формат(БазовоеКоличество, "ЧДЦ=" + Формат(ДЦБазы, "ЧГ=0") + "; ЧРД=,") + " " + БазоваяЕдиница;

			// Вес позиции (если задан в карточке номенклатуры)
			Если СтрокаТовара.ВесИспользовать
				И ЗначениеЗаполнено(СтрокаТовара.ВесЧислитель) Тогда
				ЗнамВеса = ?(СтрокаТовара.ВесЗнаменатель = 0, 1, СтрокаТовара.ВесЗнаменатель);
				ВесПерБазу = СтрокаТовара.ВесЧислитель / ЗнамВеса;
				ВесОбщий   = ВесОбщий + БазовоеКоличество * ВесПерБазу;
				Если ПустаяСтрока(ЕдВеса) Тогда
					ЕдВеса = СокрЛП(СтрокаТовара.ВесЕдиницаНаименование);
				КонецЕсли;
			КонецЕсли;

			// Цена за базовую единицу (до скидки)
			ЦенаЗаБазу        = СтрокаТовара.Цена / Коэф;
			ЦенаЗаБазуТекст   = Формат(ЦенаЗаБазу, "ЧДЦ=2; ЧРД=,") + " / 1 " + БазоваяЕдиница;

			// Цена за базовую единицу (после скидки) и итоговая сумма
			ЦенаПослеСкидки   = ?(БазовоеКоличество = 0, 0, СтрокаТовара.Сумма / БазовоеКоличество);
			ЦенаПослеСкидкиТекст = Формат(ЦенаПослеСкидки, "ЧДЦ=2; ЧРД=,") + " / 1 " + БазоваяЕдиница;
			СуммаПослеСкидки  = Формат(СтрокаТовара.Сумма, "ЧДЦ=2; ЧРД=,");

			// База для расчёта процента — суммa строки до скидок/наценок
			СуммаДоСкидок = СтрокаТовара.Цена * СтрокаТовара.Количество;

			// Заранее находим строки СкидокНаценок этой позиции — они нужны и для решения,
			// показывать ли цену до скидки в Главной, и для самого вывода подстрок ниже.
			СтрокиСкидок = ТаблицаСкидок.НайтиСтроки(Новый Структура("Ссылка, КлючСвязи",
				ВыборкаШапки.Ссылка, СтрокаТовара.КлючСвязи));
			ЕстьСкидки = СтрокаТовара.ПроцентРучнойСкидки <> 0
				ИЛИ СтрокаТовара.СуммаРучнойСкидки <> 0;
			Если Не ЕстьСкидки Тогда
				Для Каждого СтрокаПроверки Из СтрокиСкидок Цикл
					Если СтрокаПроверки.Сумма <> 0 Тогда
						ЕстьСкидки = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;

			// --- Главная строка ---
			ОбластьГлавная.Параметры.НомерСтроки     = Формат(НомерВыводимойСтроки, "ЧГ=0");
			ОбластьГлавная.Параметры.Артикул         = СтрокаТовара.Артикул;
			ОбластьГлавная.Параметры.Наименование    = НаименованиеТовара;
			ОбластьГлавная.Параметры.КоличествоЕдИзм = КоличествоПродажа;
			// Цена в Главной строке всегда пуста — итог уходит в «Вартість» / «Загальна вартість» ниже.
			ОбластьГлавная.Параметры.ЦенаЕдИзм = "";
			// Расшифровка ячейки наименования — открывает карточку номенклатуры по клику.
			ОбластьГлавная.Область("R1C3").Расшифровка = СтрокаТовара.Номенклатура;
			ТабличныйДокумент.Вывести(ОбластьГлавная);

			// --- Цінова група (под именем, если задана у номенклатуры) ---
			Если ЗначениеЗаполнено(СтрокаТовара.ЦеноваяГруппаНаименование) Тогда
				ОбластьОписание.Параметры.Описание = НСтр("ru='Ценовая группа';uk='Цінова група'") + " "
					+ СокрЛП(СтрокаТовара.ЦеноваяГруппаНаименование);
				ТабличныйДокумент.Вывести(ОбластьОписание);
			КонецЕсли;

			// Общая площадь покраски (если у номенклатуры заполнена площадь).
			ЕстьПлощадь = СтрокаТовара.ПлощадьИспользовать
				И ЗначениеЗаполнено(СтрокаТовара.ПлощадьЧислитель)
				И СтрокаТовара.ПлощадьЧислитель > 0;
			ОбщаяПлощадь = 0;
			ЕдПлощади    = "";
			Если ЕстьПлощадь Тогда
				ЗнамПл = ?(СтрокаТовара.ПлощадьЗнаменатель = 0, 1, СтрокаТовара.ПлощадьЗнаменатель);
				ПлощадьЗаБазу = СтрокаТовара.ПлощадьЧислитель / ЗнамПл;
				ОбщаяПлощадь  = БазовоеКоличество * ПлощадьЗаБазу;
				ЕдПлощади     = СокрЛП(СтрокаТовара.ПлощадьЕдиницаНаименование);
			КонецЕсли;

			// Найдём (если есть) суммарную сумму наценки за покраску по этой строке —
			// её мы не выводим в стандартном формате СкидкиНаценки, а через специальные строки
			// «Вартість покриття» + «Загальна вартість» ниже. 1С хранит наценку как отрицательное
			// число (в Сумма табчасти СкидкиНаценки), поэтому Сумма_наценки_визуальная = -Sum.
			СуммаНаценкиПокраскиСигн = 0;  // signed — как в табчасти 1С (отрицат. для наценки)
			Для Каждого СтрокаПроверки Из СтрокиСкидок Цикл
				Если ЗначениеЗаполнено(ПроцессорНаценкаПокраска)
					И СтрокаПроверки.СпособПредоставления = ПроцессорНаценкаПокраска Тогда
					СуммаНаценкиПокраскиСигн = СуммаНаценкиПокраскиСигн + СтрокаПроверки.Сумма;
				КонецЕсли;
			КонецЦикла;
			ЭтоНаценкаПокраскиЕсть = СуммаНаценкиПокраскиСигн <> 0 И ОбщаяПлощадь > 0;

			// Авто-скидки/націнки (кроме покраски) и ручная скидка отдельной подстрокой не выводятся —
			// их эффект уже учтён в сумме «Вартість» / «Вартість позиції». Покраска обрабатывается ниже.

			// --- Итоги по строке ---
			Если ЭтоНаценкаПокраскиЕсть Тогда
				// Случай с покраской: три строки.
				// 1) «Вартість позиції» — сумма без покраски (без жирного).
				СуммаБезПокраски   = СтрокаТовара.Сумма + СуммаНаценкиПокраскиСигн; // покраска хранится как «-», прибавляем чтобы вычесть
				ЦенаБезПокраски    = ?(БазовоеКоличество = 0, 0, СуммаБезПокраски / БазовоеКоличество);
				ЦенаБезПокраскиТекст = Формат(ЦенаБезПокраски, "ЧДЦ=2; ЧРД=,") + " / 1 " + БазоваяЕдиница;
				ОбластьСтоимостьБезПокраски.Параметры.КоличествоВторичное = КоличествоБаза;
				ОбластьСтоимостьБезПокраски.Параметры.ЦенаЕдИзм           = ЦенаБезПокраскиТекст;
				ОбластьСтоимостьБезПокраски.Параметры.СтоимостьПозиции    = Формат(СуммаБезПокраски, "ЧДЦ=2; ЧРД=,");
				ТабличныйДокумент.Вывести(ОбластьСтоимостьБезПокраски);

				// 2) «Вартість покриття» — площадь × ціна за м² (без жирного).
				СуммаПокраскиВизуал = -СуммаНаценкиПокраскиСигн;
				ЦенаЗаПлощадь       = СуммаПокраскиВизуал / ОбщаяПлощадь;
				ОбластьВартістьПокриття.Параметры.ПлощадьПокрытия = Формат(ОбщаяПлощадь, "ЧДЦ=3; ЧРД=,") + " " + ЕдПлощади;
				ОбластьВартістьПокриття.Параметры.ЦенаПокрытия    = Формат(ЦенаЗаПлощадь, "ЧДЦ=2; ЧРД=,") + " / 1 " + ЕдПлощади;
				ОбластьВартістьПокриття.Параметры.СуммаПокрытия   = Формат(СуммаПокраскиВизуал, "ЧДЦ=2; ЧРД=,");
				ТабличныйДокумент.Вывести(ОбластьВартістьПокриття);

				// 3) «Загальна вартість» — финальная сумма (жирная).
				ОбластьЗагальнаВартість.Параметры.ЗагальнаВартість = Формат(СтрокаТовара.Сумма, "ЧДЦ=2; ЧРД=,");
				ТабличныйДокумент.Вывести(ОбластьЗагальнаВартість);
			Иначе
				// Без покраски: одна строка «Вартість» с жирной финальной суммой.
				ОбластьСтоимость.Параметры.КоличествоВторичное = КоличествоБаза;
				ОбластьСтоимость.Параметры.ЦенаЕдИзм           = ЦенаПослеСкидкиТекст;
				ОбластьСтоимость.Параметры.СтоимостьПозиции    = СуммаПослеСкидки;
				ТабличныйДокумент.Вывести(ОбластьСтоимость);
			КонецЕсли;

			// --- Длина: только если продаём в упаковке, а базовая единица — длинного типа.
			//             Тогда длина = (Числитель/Знаменатель) базовых единиц на одну упаковку.
			Если СтрокаТовара.ЕдиницаИзмерения <> СтрокаТовара.БазоваяЕдиницаСсылка
				И СтрокаТовара.БазовыйТипЕдиницы = Перечисления.ТипыИзмеряемыхВеличин.Длина
				И Коэф > 0 Тогда
				ДлинаТекст = НСтр("ru='Длина';uk='Довжина'") + " "
					+ Формат(Коэф, "ЧДЦ=" + Формат(ДЦБазы, "ЧГ=0") + "; ЧРД=,") + " " + БазоваяЕдиница;
				ОбластьОписание.Параметры.Описание = ДлинаТекст;
				ТабличныйДокумент.Вывести(ОбластьОписание);
			КонецЕсли;

			// --- Покраска (если задана через дополнительный реквизит характеристики) ---
			Если ЗначениеЗаполнено(СтрокаТовара.ПокраскаНаименование) Тогда
				ПокраскаТекст = НСтр("ru='Цвет';uk='Колір'") + " "
					+ СтрокаТовара.ПокраскаНаименование;
				ОбластьОписание.Параметры.Описание = ПокраскаТекст;
				ТабличныйДокумент.Вывести(ОбластьОписание);
			КонецЕсли;

			// --- Содержимое 1 паков (для номенклатур, продаваемых в паках) ---
			// ЕдИзмПродажа уже содержит классификаторное имя (с фолбэком на Description упаковки),
			// поэтому ловим случай, когда продажная единица — сам классификатор "паков".
			Если ЕдИзмПродажа = "паков" Тогда
				ПаковТекст = "";
				Если СтрокаТовара.ЕдиницаИзмерения <> СтрокаТовара.БазоваяЕдиницаСсылка Тогда
					// Случай A: продажная упаковка-паков, базовая единица другая.
					// Длинная подстрока уже выводит ту же информацию для базы типа Длина — не дублируем.
					Если Коэф > 0
						И СтрокаТовара.БазовыйТипЕдиницы <> Перечисления.ТипыИзмеряемыхВеличин.Длина Тогда
						ПаковТекст = "1 " + ЕдИзмПродажа + " = "
							+ Формат(Коэф, "ЧДЦ=" + Формат(ДЦБазы, "ЧГ=0") + "; ЧРД=,") + " " + БазоваяЕдиница;
					КонецЕсли;
				Иначе
					// Случай B: паков — это базовая единица. Ищем у номенклатуры
					// упаковку с типом КоличествоШтук (исключая саму паков).
					ИнфоШт = НайтиШтУпаковку(СтрокаТовара.Номенклатура, СтрокаТовара.НаборУпаковок,
						СтрокаТовара.ЕдиницаИзмерения);
					Если ИнфоШт <> Неопределено
						И ЗначениеЗаполнено(ИнфоШт.Числитель) И ИнфоШт.Числитель > 0 Тогда
						// Упаковка хранит "1 шт = (Числ/Знам) паков" — нам нужно обратное "1 паков = (Знам/Числ) шт".
						ПаковТекст = "1 " + ЕдИзмПродажа + " = "
							+ Формат(ИнфоШт.Знаменатель / ИнфоШт.Числитель, "ЧДЦ=0; ЧРД=,") + " "
							+ ?(ПустаяСтрока(ИнфоШт.Имя), НСтр("ru='шт';uk='шт'"), ИнфоШт.Имя);
					ИначеЕсли СтрокаТовара.ДлинаИспользовать
						И ЗначениеЗаполнено(СтрокаТовара.ДлинаЧислитель)
						И СтрокаТовара.ДлинаЧислитель > 0 Тогда
						// Случай C: длина номенклатуры.
						ЗнамДл = ?(СтрокаТовара.ДлинаЗнаменатель = 0, 1, СтрокаТовара.ДлинаЗнаменатель);
						ПаковТекст = "1 " + ЕдИзмПродажа + " = "
							+ Формат(СтрокаТовара.ДлинаЧислитель / ЗнамДл, "ЧДЦ=3; ЧРД=,") + " "
							+ СокрЛП(СтрокаТовара.ДлинаЕдиницаНаименование);
					КонецЕсли;
				КонецЕсли;
				Если Не ПустаяСтрока(ПаковТекст) Тогда
					ОбластьОписание.Параметры.Описание = ПаковТекст;
					ТабличныйДокумент.Вывести(ОбластьОписание);
				КонецЕсли;
			КонецЕсли;

		КонецЦикла;

		// --- Подвал таблицы ---
		СуммаСНДС = СуммаВсего + ?(ВыборкаШапки.ЦенаВключаетНДС, 0, СуммаВсегоНДС);

		ОбластьПодвалТаблицы.Параметры.ОбщаяСебестоимость = Формат(СуммаВсего, "ЧДЦ=2; ЧРД=,");
		ОбластьПодвалТаблицы.Параметры.СуммаНДС           = Формат(СуммаВсегоНДС, "ЧДЦ=2; ЧРД=,");
		ОбластьПодвалТаблицы.Параметры.ОбщаяСтоимостьСНДС = Формат(СуммаСНДС, "ЧДЦ=2; ЧРД=,");
		ОбластьПодвалТаблицы.Параметры.Валюта             = ПредставлениеВалюты;
		Если ВесОбщий > 0 Тогда
			Если ПустаяСтрока(ЕдВеса) Тогда
				ЕдВеса = "kg";
			КонецЕсли;
			ОбластьПодвалТаблицы.Параметры.Вес = Формат(ВесОбщий, "ЧДЦ=4; ЧРД=,") + " " + ЕдВеса + ".";
		Иначе
			ОбластьПодвалТаблицы.Параметры.Вес = "";
		КонецЕсли;

		ТабличныйДокумент.Вывести(ОбластьПодвалТаблицы);

		// --- Примечание ---
		ТекстПримечания = ВыборкаШапки.ПрочиеУсловия;
		Если ПустаяСтрока(ТекстПримечания) Тогда
			ТекстПримечания = "";
		КонецЕсли;
		ОбластьПримечание.Параметры.Примечание = ТекстПримечания;
		ТабличныйДокумент.Вывести(ОбластьПримечание);

		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент,
			НомерСтрокиНачало, ОбъектыПечати, ВыборкаШапки.Ссылка);

	КонецЦикла;

	Возврат ТабличныйДокумент;

КонецФункции

// Возвращает количество знаков после запятой для отображения количества по типу единицы измерения.
// Для типов «длина / вес / объём / площадь» — 3 знака; для «штук» / прочих — целое.
Функция ДЦДляТипаЕдиницы(ТипЕдиницы)

	Если ТипЕдиницы = Перечисления.ТипыИзмеряемыхВеличин.Длина
		ИЛИ ТипЕдиницы = Перечисления.ТипыИзмеряемыхВеличин.Вес
		ИЛИ ТипЕдиницы = Перечисления.ТипыИзмеряемыхВеличин.Объем
		ИЛИ ТипЕдиницы = Перечисления.ТипыИзмеряемыхВеличин.Площадь Тогда
		Возврат 3;
	КонецЕсли;
	Возврат 0;

КонецФункции

// Ищем дополнительный реквизит характеристики номенклатуры, тип которого включает Покраски_SCT.
// Возвращает данные первой найденной у номенклатуры упаковки с типом КоличествоШтук
// (исключая саму паков-упаковку, переданную в ИсключитьУпаковку). Используется при
// формировании подстроки «1 паков = N шт» для номенклатур, у которых паков — базовая
// единица. Возвращает Структуру { Числитель, Знаменатель, Имя } или Неопределено.
Функция НайтиШтУпаковку(Номенклатура, НаборУпаковок, ИсключитьУпаковку)

	// Ищем у самой номенклатуры (либо у её НабораУпаковок) упаковку,
	// чей классификатор называется «шт» — это и есть «упаковка со штуками».
	// Тип упаковки может быть как КоличествоШтук, так и Упаковка
	// (например, «шт (1/10 паков)» имеет тип «Упаковка»), поэтому фильтруем по имени классификатора.
	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Упак.Числитель                     КАК Числитель,
		|	Упак.Знаменатель                   КАК Знаменатель,
		|	Упак.ЕдиницаИзмерения.Наименование КАК Имя
		|ИЗ
		|	Справочник.УпаковкиЕдиницыИзмерения КАК Упак
		|ГДЕ
		|	Упак.Ссылка <> &Исключить
		|	И НЕ Упак.ПометкаУдаления
		|	И Упак.Числитель <> 0
		|	И Упак.Знаменатель <> 0
		|	И Упак.ЕдиницаИзмерения.Наименование = ""шт""
		|	И (Упак.Владелец = &Номенклатура ИЛИ Упак.Владелец = &НаборУпаковок)
		|УПОРЯДОЧИТЬ ПО Упак.Наименование");
	Запрос.УстановитьПараметр("Номенклатура",  Номенклатура);
	Запрос.УстановитьПараметр("НаборУпаковок", НаборУпаковок);
	Запрос.УстановитьПараметр("Исключить",     ИсключитьУпаковку);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Новый Структура("Числитель,Знаменатель,Имя",
			Выборка.Числитель, Выборка.Знаменатель, СокрЛП(Выборка.Имя));
	КонецЕсли;
	Возврат Неопределено;

КонецФункции

// Возвращает ссылку на запись справочника ДополнительныеОтчетыИОбработки для процессора
// «Schueco_НаценкаЗаПокраску_SCT». Ссылка хранится в `СкидкаНаценка.СпособПредоставления`
// у записей-наценок за покраску — по ней мы их распознаём в печатной форме.
// Возвращает Неопределено, если процессор не зарегистрирован.
Функция НайтиПроцессорНаценкаПокраска()

	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка
		|ИЗ Справочник.ДополнительныеОтчетыИОбработки
		|ГДЕ ИмяОбъекта = ""Schueco_НаценкаЗаПокраску_SCT""
		|	И НЕ ПометкаУдаления");
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	Возврат Неопределено;

КонецФункции

// Возвращает Неопределено, если не найден — тогда подстрока «Покраска» не печатается.
Функция НайтиСвойствоПокраска()

	Запрос = Новый Запрос(
		"ВЫБРАТЬ Ссылка, ТипЗначения
		|ИЗ ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения
		|ГДЕ НЕ ПометкаУдаления");
	Выборка = Запрос.Выполнить().Выбрать();
	ТипПокраски = Тип("СправочникСсылка.Покраски_SCT");
	Пока Выборка.Следующий() Цикл
		Описание = Выборка.ТипЗначения;
		Если Описание <> Неопределено И Описание.СодержитТип(ТипПокраски) Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;

КонецФункции

#КонецОбласти
