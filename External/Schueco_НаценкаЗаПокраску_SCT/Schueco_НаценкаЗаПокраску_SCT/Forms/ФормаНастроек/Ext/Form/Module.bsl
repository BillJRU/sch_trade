// Форма настроек внешней обработки "Schüco: Наценка за покраску".
// Открывается из формы элемента Catalog.СкидкиНаценки кнопкой
// "Показать форму настроек" (когда СпособПредоставления указывает на нашу
// обработку — см. СкидкиНаценки.ФормаЭлемента, обработчик
// "ПоказатьФормуНастроекВнешнейОбработки").
//
// Контракт интеграции (см. CommonModules.СкидкиНаценкиВызовСервера):
//  - Параметр формы "АдресНастроекВнешнейОбработки" — адрес ВО временного хранилища.
//      В нём лежит десериализованное содержимое ПараметрыВнешнейОбработки.Получить()
//      (Структура с СвойствоЦеныПокраски и СвойствоПризнакаПокраски, или Неопределено).
//  - На закрытии формы возвращаем Структуру с ОписаниеДействияВнешнейОбработки
//      и АвтонаименованиеВнешнейОбработки — родительская форма обновит свои
//      одноимённые поля и установит Модифицированность = Истина.
//  - Перед закрытием обновляем содержимое временного хранилища тем же адресом —
//      родительская форма при сохранении объекта запакует его в ХранилищеЗначения
//      (см. СкидкиНаценкиСервер.ПередЗаписьюНаСервере, строка 6873).

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	АдресНастроекВнешнейОбработки = "";
	Если Параметры.Свойство("АдресНастроекВнешнейОбработки") Тогда
		АдресНастроекВнешнейОбработки = Параметры.АдресНастроекВнешнейОбработки;
	КонецЕсли;

	ЗагрузитьНастройкиИзВременногоХранилища();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Сохранить(Команда)

	Если НЕ ЗначениеЗаполнено(СвойствоЦеныПокраски) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Укажите дополнительный реквизит цены покраски.';"
			+ "uk='Вкажіть додатковий реквізит ціни фарбування.'"));
		Возврат;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(СвойствоПризнакаПокраски) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Укажите дополнительный реквизит признака покраски.';"
			+ "uk='Вкажіть додатковий реквізит ознаки фарбування.'"));
		Возврат;
	КонецЕсли;

	РезультатЗакрытия = СохранитьВВременноеХранилищеНаСервере();
	Закрыть(РезультатЗакрытия);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗагрузитьНастройкиИзВременногоХранилища()

	СвойствоЦеныПокраски     = Неопределено;
	СвойствоПризнакаПокраски = Неопределено;

	Если НЕ ЗначениеЗаполнено(АдресНастроекВнешнейОбработки) Тогда
		Возврат;
	КонецЕсли;

	Содержимое = ПолучитьИзВременногоХранилища(АдресНастроекВнешнейОбработки);
	Если ТипЗнч(Содержимое) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;

	Значение = Неопределено;
	Если Содержимое.Свойство("СвойствоЦеныПокраски", Значение)
	   И ТипЗнч(Значение) = Тип("ПланВидовХарактеристикСсылка.ДополнительныеРеквизитыИСведения") Тогда
		СвойствоЦеныПокраски = Значение;
	КонецЕсли;

	Значение = Неопределено;
	Если Содержимое.Свойство("СвойствоПризнакаПокраски", Значение)
	   И ТипЗнч(Значение) = Тип("ПланВидовХарактеристикСсылка.ДополнительныеРеквизитыИСведения") Тогда
		СвойствоПризнакаПокраски = Значение;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция СохранитьВВременноеХранилищеНаСервере()

	Стр = Новый Структура;
	Стр.Вставить("СвойствоЦеныПокраски",     СвойствоЦеныПокраски);
	Стр.Вставить("СвойствоПризнакаПокраски", СвойствоПризнакаПокраски);

	// Записываем по тому же адресу — родительская форма сохранит в ХранилищеЗначения
	// при ПередЗаписьюНаСервере.
	ПоместитьВоВременноеХранилище(Стр, АдресНастроекВнешнейОбработки);

	// Родительская форма ожидает Структуру с этими двумя ключами в обработчике
	// ИзмененыНастройкиВнешнейОбработки (см. СкидкиНаценки.ФормаЭлемента, строка 1028).
	Возврат Новый Структура("ОписаниеДействияВнешнейОбработки, АвтонаименованиеВнешнейОбработки",
		ПостроитьОписаниеДействия(Стр),
		ПостроитьАвтонаименование(Стр));

КонецФункции

&НаСервереБезКонтекста
Функция ПостроитьОписаниеДействия(Стр)
	// Должно совпадать с логикой ОписаниеДействия() в ObjectModule.bsl.
	Если Стр = Неопределено ИЛИ НЕ ЗначениеЗаполнено(Стр.СвойствоЦеныПокраски) Тогда
		Возврат НСтр("ru='Не настроено';uk='Не налаштовано'");
	КонецЕсли;
	Возврат СтрШаблон(
		НСтр("ru='Наценка за покраску = %1 × Площадь × Длина × Количество "
			+ "(применяется при %2 = Истина).';"
			+ "uk='Націнка за фарбування = %1 × Площа × Довжина × Кількість "
			+ "(застосовується при %2 = Істина).'"),
		Строка(Стр.СвойствоЦеныПокраски),
		Строка(Стр.СвойствоПризнакаПокраски));
КонецФункции

&НаСервереБезКонтекста
Функция ПостроитьАвтонаименование(Стр)
	// Должно совпадать с Автонаименование() в ObjectModule.bsl.
	Возврат НСтр("ru='Schüco: Наценка за покраску';uk='Schüco: Націнка за фарбування'");
КонецФункции

#КонецОбласти
