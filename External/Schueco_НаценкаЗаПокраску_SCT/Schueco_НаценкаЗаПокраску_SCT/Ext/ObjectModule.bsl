// Внешняя обработка "Schüco: Наценка за покраску".
// Вид: РасчетСкидкиНаценки. Подключается через справочник ДополнительныеОтчетыИОбработки.
// Двигатель скидок-наценок (СкидкиНаценкиСервер) при расчёте автоматически вызывает
// функцию Рассчитать() для каждого элемента СкидкиНаценки, у которого СпособПредоставления
// указывает на эту обработку.
//
// Параметры обработки (две ссылки на ПВХ.ДополнительныеРеквизитыИСведения)
// хранятся в реквизите СкидкиНаценки.ПараметрыВнешнейОбработки (ХранилищеЗначения).
// Структура хранения:
//   Структура("СвойствоЦеныПокраски, СвойствоПризнакаПокраски",
//             ПВХСсылкаЦенаБезНДС, ПВХСсылкаПризнакПокраски)
//
// Настройка параметров — через команду "НастройкаДополнительныхРеквизитов",
// открывающую форму ФормаНастроек (см. справочник Дополнительные обработки).

#Область ПрограммныйИнтерфейс

// Возвращает сведения о внешней обработке для регистрации в справочнике
// ДополнительныеОтчетыИОбработки.
//
// Возвращаемое значение:
//  Структура - параметры регистрации (Вид, Версия, Назначение, Команды и т.д.).
//
Функция СведенияОВнешнейОбработке() Экспорт

	ПараметрыРегистрации = СкидкиНаценкиСервер.ПараметрыРегистрацииВнешнейОбработкиСкидкиНаценки(
		НСтр("ru='Schüco: Наценка за покраску';uk='Schüco: Націнка за фарбування'"),
		НСтр("ru='Расчёт наценки за покраску по строкам документа продажи. "
			+ "Берёт цену покраски (грн/м²) из дополнительного реквизита Характеристики, "
			+ "площадь окружности и длину пог. метра — из Номенклатуры, количество — из строки документа.';"
			+ "uk='Розрахунок націнки за фарбування по рядках документа продажу. "
			+ "Бере ціну фарбування (грн/м²) з додаткового реквізиту Характеристики, "
			+ "площу та довжину — з Номенклатури, кількість — з рядка документа.'"));

	// Версия — увеличиваем patch при каждой итерации, чтобы по UI можно было
	// убедиться, что 1С подгрузила свежий .epf, а не закешированную старую версию.
	ПараметрыРегистрации.Версия = "1.0.7";

	// Команда "Настройка дополнительных реквизитов" — открывает форму, где администратор
	// выбирает две ссылки на ПВХ.ДополнительныеРеквизитыИСведения и сохраняет их
	// в ПараметрыВнешнейОбработки выбранного элемента СкидкиНаценки.
	//
	// СкидкиНаценкиСервер.ПараметрыРегистрацииВнешнейОбработкиСкидкиНаценки() создаёт
	// Команды как пустую ТаблицаЗначений без колонок (в отличие от
	// ДополнительныеОтчетыИОбработки.СведенияОВнешнейОбработке()), поэтому колонки
	// нужно добавить вручную перед заполнением строки.
	КолонкиКоманд = ПараметрыРегистрации.Команды.Колонки;
	Если КолонкиКоманд.Найти("Идентификатор") = Неопределено Тогда
		КолонкиКоманд.Добавить("Идентификатор",        Новый ОписаниеТипов("Строка"));
		КолонкиКоманд.Добавить("Использование",        Новый ОписаниеТипов("Строка"));
		КолонкиКоманд.Добавить("Представление",        Новый ОписаниеТипов("Строка"));
		КолонкиКоманд.Добавить("ПоказыватьОповещение", Новый ОписаниеТипов("Булево"));
		КолонкиКоманд.Добавить("Модификатор",          Новый ОписаниеТипов("Строка"));
	КонецЕсли;

	НоваяКоманда = ПараметрыРегистрации.Команды.Добавить();
	НоваяКоманда.Идентификатор = "НастройкаДополнительныхРеквизитов";
	НоваяКоманда.Использование = ДополнительныеОтчетыИОбработкиКлиентСервер.ТипКомандыОткрытиеФормы();
	НоваяКоманда.Представление = НСтр("ru='Настройка дополнительных реквизитов';uk='Налаштування додаткових реквізитів'");
	НоваяКоманда.ПоказыватьОповещение = Ложь;

	Возврат ПараметрыРегистрации;

КонецФункции

// Возвращает способ применения наценки. Двигатель скидок-наценок вызывает эту
// функцию при формировании списка доступных способов предоставления, чтобы
// разделить обработки по веткам "СкидкиНаценки" / "БонусныеБаллы"
// (см. СкидкиНаценкиСервер.Модуль строки 145-154).
//
// Для нашей наценки за покраску — обычное применение в момент расчёта.
//
// Возвращаемое значение:
//  ПеречислениеСсылка.СпособыПримененияСкидокНаценок
//
Функция СпособПрименения() Экспорт

	Возврат Перечисления.СпособыПримененияСкидокНаценок.ПрименитьВМоментРасчетаСкидокНаценок;

КонецФункции

// Имя формы настроек. Двигатель открывает её на форме элемента СкидкиНаценки
// при нажатии "Показать форму настроек". Если вернуть пустую строку — кнопки нет.
//
// Возвращаемое значение:
//  Строка
//
Функция ИмяФормыНастроек() Экспорт

	Возврат "ФормаНастроек";

КонецФункции

// Текстовое описание действия (показывается в форме элемента СкидкиНаценки
// под заголовком "Описание скидки/наценки"). Зависит от текущих настроек
// (Параметры — Структура, как она сохранена в ПараметрыВнешнейОбработки,
// или Неопределено если ещё не настроено).
//
// Параметры:
//  Параметры - Структура, Неопределено
//
// Возвращаемое значение:
//  Строка
//
Функция ОписаниеДействия(Параметры) Экспорт

	Если Параметры = Неопределено
	   ИЛИ ТипЗнч(Параметры) <> Тип("Структура")
	   ИЛИ НЕ Параметры.Свойство("СвойствоЦеныПокраски")
	   ИЛИ НЕ ЗначениеЗаполнено(Параметры.СвойствоЦеныПокраски) Тогда
		Возврат НСтр("ru='Не настроено: нажмите ""Показать форму настроек"" "
			+ "и укажите два дополнительных реквизита Характеристики номенклатуры.';"
			+ "uk='Не налаштовано: натисніть ""Показати форму налаштувань"" "
			+ "та вкажіть два додаткові реквізити Характеристики номенклатури.'");
	КонецЕсли;

	Возврат СтрШаблон(
		НСтр("ru='Наценка за покраску = %1 × Площадь × Длина × Количество "
			+ "(применяется при %2 = Истина).';"
			+ "uk='Націнка за фарбування = %1 × Площа × Довжина × Кількість "
			+ "(застосовується при %2 = Істина).'"),
		Строка(Параметры.СвойствоЦеныПокраски),
		Строка(Параметры.СвойствоПризнакаПокраски));

КонецФункции

// Автонаименование для элемента СкидкиНаценки. Двигатель использует это значение,
// когда пользователь нажимает "Обновить автонаименование" в форме элемента.
//
// Параметры:
//  Параметры - Структура, Неопределено
//
// Возвращаемое значение:
//  Строка
//
Функция Автонаименование(Параметры) Экспорт

	Возврат НСтр("ru='Schüco: Наценка за покраску';uk='Schüco: Націнка за фарбування'");

КонецФункции

// Рассчитывает наценку за покраску для каждой строки переданного товарного списка.
// Вызывается двигателем СкидкиНаценкиСервер во время расчёта скидок (наценок) документа.
//
// Знак возвращаемой суммы:
//   Документация BAS UT 3.5: "+ = знижка, − = націнка". Возвращаем отрицательную сумму.
//
// Параметры:
//  СтрокаДерева              - Структура - текущий узел дерева скидок (содержит СкидкаНаценка,
//                              СпособПредоставления, ПараметрыВнешнейОбработки и пр.).
//  ПараметрыВнешнейОбработки - Произвольный - десериализованное содержимое ХранилищаЗначения
//                              (как правило Структура с ключами СвойствоЦеныПокраски и
//                              СвойствоПризнакаПокраски).
//  Товары                    - ТаблицаЗначений - строки документа (Номенклатура, Характеристика,
//                              Количество, Цена, КлючСвязи и т.д.).
//  ПараметрыРасчета          - Структура - контекст расчёта (используется для
//                              ПустаяТаблицаСкидокСРасшифровкой и ПустаяТаблицаРасшифровка).
//
// Возвращаемое значение:
//  ТаблицаЗначений - КлючСвязи / Расшифровка / Сумма / Действует
//                    (см. СкидкиНаценкиСервер.ПустаяТаблицаСкидокСРасшифровкой).
//
Функция Рассчитать(СтрокаДерева, ПараметрыВнешнейОбработки, Товары, ПараметрыРасчета) Экспорт

	Результат = СкидкиНаценкиСервер.ПустаяТаблицаСкидокСРасшифровкой(ПараметрыРасчета);

	// 1. Прочитать настройки (две ссылки на ПВХ).
	НастройкиДопРеквизитов = ИзвлечьНастройки(ПараметрыВнешнейОбработки);
	Если НастройкиДопРеквизитов = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	СвойствоЦены    = НастройкиДопРеквизитов.СвойствоЦеныПокраски;
	СвойствоПризнак = НастройкиДопРеквизитов.СвойствоПризнакаПокраски;

	// 2. Собрать ссылки Характеристик и Номенклатур из Товаров.
	МассивХарактеристик = Новый Массив;
	МассивНоменклатур   = Новый Массив;
	Для Каждого СтрокаТовара Из Товары Цикл
		Если ЗначениеЗаполнено(СтрокаТовара.Характеристика)
		   И МассивХарактеристик.Найти(СтрокаТовара.Характеристика) = Неопределено Тогда
			МассивХарактеристик.Добавить(СтрокаТовара.Характеристика);
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаТовара.Номенклатура)
		   И МассивНоменклатур.Найти(СтрокаТовара.Номенклатура) = Неопределено Тогда
			МассивНоменклатур.Добавить(СтрокаТовара.Номенклатура);
		КонецЕсли;
	КонецЦикла;

	Если МассивХарактеристик.Количество() = 0 ИЛИ МассивНоменклатур.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	// 2.1. Прочитать ЦенаВключаетНДС и СтавкаНДС по строкам из самого документа.
	//   ЦенаПокраски на Характеристике хранится БЕЗ НДС. Если документ оформлен
	//   с ЦенаВключаетНДС=Истина, поле строки Сумма (и СуммаАвтоматическойСкидки)
	//   ожидается уже С НДС, поэтому нашу нетто-сумму нужно увеличить на ставку.
	//   Иначе — возвращаем нетто, и движок сам разложит СуммаНДС/СуммаСНДС.
	ЦенаВключаетНДС  = Ложь;
	СтавкиПоСтрокам = Новый Соответствие;
	Если ТипЗнч(ПараметрыРасчета) = Тип("Структура")
	   И ПараметрыРасчета.Свойство("Объект")
	   И ПараметрыРасчета.Объект <> Неопределено Тогда
		Попытка
			ЦенаВключаетНДС = ПараметрыРасчета.Объект.ЦенаВключаетНДС;
		Исключение
			ЦенаВключаетНДС = Ложь;
		КонецПопытки;
		Попытка
			Для Каждого СтрокаДок Из ПараметрыРасчета.Объект.Товары Цикл
				СтавкиПоСтрокам.Вставить(СтрокаДок.КлючСвязи, СтрокаДок.СтавкаНДС);
			КонецЦикла;
		Исключение
			// Пусто — ставку не сможем определить, останется нетто (best-effort).
		КонецПопытки;
	КонецЕсли;

	КэшСтавокНДС = Новый Соответствие;

	// 3. Один пакетный запрос за дополнительными реквизитами Характеристик.
	ДанныеПокраски = ПрочитатьДопРеквизитыХарактеристик(
		МассивХарактеристик, СвойствоЦены, СвойствоПризнак);

	// 4. Один пакетный запрос за геометрией Номенклатуры (Площадь × Длина).
	ДанныеНоменклатуры = ПрочитатьГеометриюНоменклатуры(МассивНоменклатур);

	// 5. По каждой строке считаем наценку.
	Для Каждого СтрокаТовара Из Товары Цикл

		Если НЕ ЗначениеЗаполнено(СтрокаТовара.Характеристика) Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(СтрокаТовара.Номенклатура) Тогда
			Продолжить;
		КонецЕсли;

		ПокраскаДанные = ДанныеПокраски.Получить(СтрокаТовара.Характеристика);
		Если ПокраскаДанные = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ ПокраскаДанные.ЕстьПокраска Тогда
			Продолжить;
		КонецЕсли;
		Если ПокраскаДанные.ЦенаБезНДС <= 0 Тогда
			Продолжить;
		КонецЕсли;

		Геометрия = ДанныеНоменклатуры.Получить(СтрокаТовара.Номенклатура);
		Если Геометрия = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Если Геометрия.ПлощадьМ2ПерМ <= 0 ИЛИ Геометрия.ДлинаМ <= 0 Тогда
			Продолжить;
		КонецЕсли;

		// Базовое количество. Двигатель строит таблицу Товары по-разному для разных
		// типов документов:
		//   ЗК: Количество = базовая ед. (м), КоличествоУпаковок = пакетная ед. (шт упаковок)
		//   КП: Количество и КоличествоУпаковок ОБА = пакетная ед. (СкидкиНаценкиЛокализация
		//       строит запрос с одной колонкой Товары.Количество для обоих полей).
		// Чтобы формула работала одинаково в обоих случаях, считаем базовое количество
		// явно: пакетная ед. × коэффициент Упаковки (Числитель/Знаменатель).
		// Если Упаковка пуста — Количество уже в базовых единицах.
		Упаковка = СтрокаТовара.Упаковка;
		Если ЗначениеЗаполнено(Упаковка) Тогда
			Числ = ?(Упаковка.Числитель  = 0, 1, Упаковка.Числитель);
			Знам = ?(Упаковка.Знаменатель = 0, 1, Упаковка.Знаменатель);
			БазовоеКоличество = СтрокаТовара.КоличествоУпаковок * Числ / Знам;
		Иначе
			БазовоеКоличество = СтрокаТовара.Количество;
		КонецЕсли;

		ПлощадьЗаБазовуюЕдиницу = Геометрия.ПлощадьМ2ПерМ * Геометрия.ДлинаМ;  // м² на 1 баз. ед.
		СуммаНаценкиНетто       = ПокраскаДанные.ЦенаБезНДС
			* ПлощадьЗаБазовуюЕдиницу
			* БазовоеКоличество;

		// Если в документе ЦенаВключаетНДС=Истина — увеличиваем нетто-наценку на ставку
		// строки, чтобы СуммаАвтоматическойСкидки оказалась в той же gross-валюте,
		// что и Цена/Сумма документа. Иначе оставляем нетто (движок сам разложит НДС).
		СуммаНаценки = СуммаНаценкиНетто;
		Если ЦенаВключаетНДС Тогда
			СтавкаНДС = СтавкиПоСтрокам.Получить(СтрокаТовара.КлючСвязи);
			Если ЗначениеЗаполнено(СтавкаНДС) Тогда
				ПроцентНДС = КэшСтавокНДС.Получить(СтавкаНДС);
				Если ПроцентНДС = Неопределено Тогда
					ПроцентНДС = УчетНДСУПВызовСервера.ЗначениеСтавкиНДС(СтавкаНДС);
					КэшСтавокНДС.Вставить(СтавкаНДС, ПроцентНДС);
				КонецЕсли;
				Если ПроцентНДС > 0 Тогда
					СуммаНаценки = СуммаНаценкиНетто * (1 + ПроцентНДС / 100);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;

		Если СуммаНаценки = 0 Тогда
			Продолжить;
		КонецЕсли;

		// Знак минус: + = скидка, − = наценка (BAS UT 3.5).
		ЗначениеДляЗаписи = -СуммаНаценки;

		НоваяСтрока             = Результат.Добавить();
		НоваяСтрока.КлючСвязи   = СтрокаТовара.КлючСвязи;
		НоваяСтрока.Сумма       = ЗначениеДляЗаписи;
		НоваяСтрока.Действует   = Истина;
		НоваяСтрока.Расшифровка = ПостроитьРасшифровку(СтрокаДерева, ЗначениеДляЗаписи, ПараметрыРасчета);

	КонецЦикла;

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Вытаскивает две ссылки на ПВХ из ПараметрыВнешнейОбработки.
// Если параметры не заданы или ссылки пустые — возвращает Неопределено
// (это значит "обработка не настроена" — наценка не считается).
//
// Параметры:
//  ПараметрыВнешнейОбработки - Произвольный - значение, переданное двигателем
//                              (двигатель уже вызвал .Получить() на ХранилищеЗначения).
//
// Возвращаемое значение:
//  Структура - содержит СвойствоЦеныПокраски и СвойствоПризнакаПокраски,
//              или Неопределено если не настроено.
//
Функция ИзвлечьНастройки(ПараметрыВнешнейОбработки)

	Если ТипЗнч(ПараметрыВнешнейОбработки) <> Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;

	СвойствоЦены    = Неопределено;
	СвойствоПризнак = Неопределено;
	ПараметрыВнешнейОбработки.Свойство("СвойствоЦеныПокраски",    СвойствоЦены);
	ПараметрыВнешнейОбработки.Свойство("СвойствоПризнакаПокраски", СвойствоПризнак);

	Если НЕ ЗначениеЗаполнено(СвойствоЦены) ИЛИ НЕ ЗначениеЗаполнено(СвойствоПризнак) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Новый Структура("СвойствоЦеныПокраски, СвойствоПризнакаПокраски",
		СвойствоЦены, СвойствоПризнак);

КонецФункции

// Один пакетный запрос за двумя дополнительными реквизитами Характеристик
// для всех Характеристик из массива.
//
// Возвращаемое значение:
//  Соответствие - Ключ = ХарактеристикаСсылка, Значение = Структура("ЕстьПокраска, ЦенаБезНДС").
//
Функция ПрочитатьДопРеквизитыХарактеристик(МассивХарактеристик, СвойствоЦены, СвойствоПризнак)

	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ДопРек.Ссылка    КАК Характеристика,
		|	ДопРек.Свойство  КАК Свойство,
		|	ДопРек.Значение  КАК Значение
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры.ДополнительныеРеквизиты КАК ДопРек
		|ГДЕ
		|	ДопРек.Ссылка В (&МассивХарактеристик)
		|	И ДопРек.Свойство В (&СвойствоЦены, &СвойствоПризнак)");
	Запрос.УстановитьПараметр("МассивХарактеристик", МассивХарактеристик);
	Запрос.УстановитьПараметр("СвойствоЦены",        СвойствоЦены);
	Запрос.УстановитьПараметр("СвойствоПризнак",     СвойствоПризнак);

	Результат = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл

		Данные = Результат.Получить(Выборка.Характеристика);
		Если Данные = Неопределено Тогда
			Данные = Новый Структура("ЕстьПокраска, ЦенаБезНДС", Ложь, 0);
			Результат.Вставить(Выборка.Характеристика, Данные);
		КонецЕсли;

		Если Выборка.Свойство = СвойствоПризнак Тогда
			Если ТипЗнч(Выборка.Значение) = Тип("Булево") Тогда
				Данные.ЕстьПокраска = Выборка.Значение;
			КонецЕсли;
		ИначеЕсли Выборка.Свойство = СвойствоЦены Тогда
			Если ТипЗнч(Выборка.Значение) = Тип("Число") Тогда
				Данные.ЦенаБезНДС = Выборка.Значение;
			КонецЕсли;
		КонецЕсли;

	КонецЦикла;

	Возврат Результат;

КонецФункции

// Один пакетный запрос за полями Площадь* и Длина* для всех Номенклатур из массива.
// Возвращает уже посчитанные ПлощадьМ2ПерМ (м²/м) и ДлинаМ (м/шт) с zero-safe делением.
//
// Возвращаемое значение:
//  Соответствие - Ключ = НоменклатураСсылка, Значение = Структура("ПлощадьМ2ПерМ, ДлинаМ").
//
Функция ПрочитатьГеометриюНоменклатуры(МассивНоменклатур)

	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Ном.Ссылка                КАК Номенклатура,
		|	Ном.ПлощадьИспользовать   КАК ПлощадьИспользовать,
		|	Ном.ПлощадьЧислитель      КАК ПлощадьЧислитель,
		|	Ном.ПлощадьЗнаменатель    КАК ПлощадьЗнаменатель,
		|	Ном.ДлинаИспользовать     КАК ДлинаИспользовать,
		|	Ном.ДлинаЧислитель        КАК ДлинаЧислитель,
		|	Ном.ДлинаЗнаменатель      КАК ДлинаЗнаменатель
		|ИЗ
		|	Справочник.Номенклатура КАК Ном
		|ГДЕ
		|	Ном.Ссылка В (&МассивНоменклатур)");
	Запрос.УстановитьПараметр("МассивНоменклатур", МассивНоменклатур);

	Результат = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл

		ПлощадьМ2ПерМ = 0;
		Если Выборка.ПлощадьИспользовать
		   И Выборка.ПлощадьЗнаменатель <> 0 Тогда
			ПлощадьМ2ПерМ = Выборка.ПлощадьЧислитель / Выборка.ПлощадьЗнаменатель;
		КонецЕсли;

		ДлинаМ = 0;
		Если Выборка.ДлинаИспользовать
		   И Выборка.ДлинаЗнаменатель <> 0 Тогда
			ДлинаМ = Выборка.ДлинаЧислитель / Выборка.ДлинаЗнаменатель;
		КонецЕсли;

		Результат.Вставить(Выборка.Номенклатура,
			Новый Структура("ПлощадьМ2ПерМ, ДлинаМ", ПлощадьМ2ПерМ, ДлинаМ));

	КонецЦикла;

	Возврат Результат;

КонецФункции

// Создаёт расшифровку (одну строку) для возвращаемого результата расчёта.
// Структура расшифровки совпадает с СкидкиНаценкиСервер.ПустаяТаблицаРасшифровка()
// (функция в типовом модуле НЕ экспортная, поэтому собираем колонки вручную либо
// копируем шаблон из ПараметрыРасчета, если он там предоставлен).
//
Функция ПостроитьРасшифровку(СтрокаДерева, Сумма, ПараметрыРасчета)

	Если ТипЗнч(ПараметрыРасчета) = Тип("Структура")
	   И ПараметрыРасчета.Свойство("ПустаяТаблицаРасшифровка")
	   И ТипЗнч(ПараметрыРасчета.ПустаяТаблицаРасшифровка) = Тип("ТаблицаЗначений") Тогда
		Расшифровка = ПараметрыРасчета.ПустаяТаблицаРасшифровка.СкопироватьКолонки();
	Иначе
		Расшифровка = Новый ТаблицаЗначений;
		Расшифровка.Колонки.Добавить("СкидкаНаценка",
			Новый ОписаниеТипов("СправочникСсылка.СкидкиНаценки"));
		Расшифровка.Колонки.Добавить("Сумма",        Новый ОписаниеТипов("Число"));
		Расшифровка.Колонки.Добавить("ЭтоСообщение", Новый ОписаниеТипов("Булево"));
	КонецЕсли;

	Стр                = Расшифровка.Добавить();
	Стр.СкидкаНаценка  = СтрокаДерева.Ссылка;
	Стр.Сумма          = Сумма;
	Стр.ЭтоСообщение   = Ложь;
	Возврат Расшифровка;

КонецФункции

#КонецОбласти
