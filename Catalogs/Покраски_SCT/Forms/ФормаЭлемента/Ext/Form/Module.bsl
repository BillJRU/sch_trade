&НаКлиенте
Процедура ЗаполнитьНаименование(Команда)
	ЗаполнитьНаименованиеНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаименованиеНаСервере()
	
	ОбъектОбр = РеквизитФормыВЗначение("Объект");
	Сформированное = ОбъектОбр.СформироватьНаименованиеПоРеквизитам();
	
	Если ЗначениеЗаполнено(Сформированное) Тогда
		Объект.Description = Лев(Сформированное, 100);
	Иначе
		Сообщить(НСтр("ru='Заполните хотя бы один из реквизитов: Цвет, Бренд, Объект заказчика';uk='Заповніть хоча б один з реквізитів: Колір, Бренд, Об''єкт замовника'"));
	КонецЕсли;
	
КонецПроцедуры
