#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ФормироватьНаименование =
		Не ДополнительныеСвойства.Свойство("РабочееНаименованиеСформировано")
		И НЕ ЗначениеЗаполнено(Наименование);

	Если ФормироватьНаименование Тогда
		СформированноеНаименование = СформироватьНаименованиеПоРеквизитам();
		Если ЗначениеЗаполнено(СформированноеНаименование) Тогда
			Наименование = Лев(СформированноеНаименование, 100);
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Наименование) Тогда
		ТекстИсключения = НСтр("ru='Для покраски необходимо указать хотя бы Цвет, Бренд или Объект заказчика — Наименование формируется автоматически из этих реквизитов';uk='Для фарбування потрібно вказати хоча б Колір, Бренд або Об''єкт замовника — Найменування формується автоматично з цих реквізитів'");
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Собирает Наименование из заполненных реквизитов по шаблону "Цвет — Бренд — ОбъектЗаказчика".
// Пустые реквизиты пропускаются; разделитель " — " применяется только между фактически заполненными частями.
Функция СформироватьНаименованиеПоРеквизитам() Экспорт
	
	Части = Новый Массив;
	Если ЗначениеЗаполнено(ОбъектЗаказчика) Тогда
		Части.Добавить(СокрЛП(Строка(ОбъектЗаказчика)));
	КонецЕсли;
	Если ЗначениеЗаполнено(Бренд) Тогда
		Части.Добавить(СокрЛП(Строка(Бренд)));
	КонецЕсли;
	Если ЗначениеЗаполнено(Цвет) Тогда
		Части.Добавить(СокрЛП(Строка(Цвет)));
	КонецЕсли;

	Возврат СтрСоединить(Части, " ");
	
КонецФункции

#КонецОбласти

#КонецЕсли
