Процедура УстановитьПараметрыФормированияРегистровУчетаПартийНДС(Запрос)
	
    Если Запрос.Параметры.Свойство("ФормироватьДетализацияПартийТоваровДляНДС")
    	И Запрос.Параметры.Свойство("ФормироватьДетализацияПартийТоваровДляНДС2_4") Тогда
    	Возврат;
    КонецЕсли;
	
    ФормироватьДетализацияПартийТоваровДляНДС = Ложь;
    ФормироватьДетализацияПартийТоваровДляНДС2_4 = Ложь;
	ИмяРегистраУчетаПартийНДС = РасчетСебестоимостиНДС.ИмяРегистраУчетаПартийНДС(Запрос.Параметры.Организация, Запрос.Параметры.Период);
	
    Если ИмяРегистраУчетаПартийНДС = "ДетализацияПартийТоваровДляНДС" Тогда
    	ФормироватьДетализацияПартийТоваровДляНДС = Истина;
    ИначеЕсли ИмяРегистраУчетаПартийНДС = "ДетализацияПартийТоваровДляНДС2_4" Тогда
    	ФормироватьДетализацияПартийТоваровДляНДС2_4 = Истина;
    КонецЕсли;
	
    Запрос.УстановитьПараметр("ФормироватьДетализацияПартийТоваровДляНДС",    ФормироватьДетализацияПартийТоваровДляНДС);
    Запрос.УстановитьПараметр("ФормироватьДетализацияПартийТоваровДляНДС2_4", ФормироватьДетализацияПартийТоваровДляНДС2_4);
	
КонецПроцедуры
