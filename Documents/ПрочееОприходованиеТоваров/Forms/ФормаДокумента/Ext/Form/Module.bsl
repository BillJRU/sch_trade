		"Документ.ПрочееОприходованиеТоваров.ФормаДокумента.Команда.ПерезаполнитьПоПриемке");
	
	ПерезаполнитьПоОрдерам();
	ПоказатьОповещениеПользователя(НСтр("ru='Перезаполнение по приемке';uk='Перезаповнення за прийманням'"),,
		НСтр("ru='Количество перезаполнено.';uk='Кількість перезаповнено.'"), БиблиотекаКартинок.Информация32);

	
